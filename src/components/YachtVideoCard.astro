---
/**
 * YachtVideoCard — универсальная карточка яхты с вертикальным видео и прайс-листом.
 *
 * ИСПОЛЬЗОВАНИЕ:
 * <YachtVideoCard
 *   id="yacht-x" // <-- ВАЖНО: Уникальный ID для якорной ссылки
 *   videoUrl="..."
 *   posterUrl="..."
 *   videoName="..."
 *   videoDescription="..."
 *   uploadDate="2026-03-12"
 *   ...
 * />
 */

import CloudinaryVideo from "./CloudinaryVideo.astro";

interface Props {
  /** Уникальный ID для якорной ссылки (например: "yacht-atlantis-45") */
  id: string;
  /** URL видеофайла (mp4) */
  videoUrl: string;
  /** URL постера/превью видео */
  posterUrl: string;
  /** Название видео для Schema.org */
  videoName: string;
  /** Описание видео для Schema.org */
  videoDescription: string;
  /** Дата загрузки (YYYY-MM-DD) */
  uploadDate?: string;
  /** Текст тега (например: "הרצליה" или "חיפה") */
  tagText: string;
  /** Цвет тега и акцента карточки (hex) */
  tagColor?: string;
  /** Emoji-иконка в шапке карточки */
  icon?: string;
  /** Заголовок карточки */
  title: string;
  /** Маленькая сноска внизу (например: про НДС) */
  note?: string;
  /** Номер WhatsApp (без +, например: 972533403449) */
  whatsappNumber: string;
  /** Текст кнопки WhatsApp */
  whatsappLabel?: string;
  /** Скрытый RAG-хинт для бота — невидим на странице */
  ragHint?: string;
}

const {
  id,
  videoUrl,
  posterUrl,
  videoName,
  videoDescription,
  uploadDate,
  tagText,
  tagColor = "#0f7ab0",
  icon = "⛵",
  title,
  note,
  whatsappNumber,
  whatsappLabel = "להזמנה בוואטסאפ",
  ragHint,
} = Astro.props;

// Преобразуем дату в полный формат ISO 8601, если она передана
const isoUploadDate = uploadDate ? new Date(uploadDate).toISOString() : undefined;

// --- НОВЫЙ БЛОК ДЛЯ ССЫЛКИ WHATSAPP ---
// 1. Получаем полный URL текущей страницы
const pageUrl = Astro.url.href.split('#')[0]; // Убираем существующий хэш, если есть

// 2. Создаем прямую ссылку на эту карточку
const cardLink = `${pageUrl}#${id}`;

// 3. Создаем текст сообщения для WhatsApp
const messageText = `Здравствуйте! Меня интересует "${title}".\n\nПодробнее здесь: ${cardLink}`;

// 4. Кодируем текст для URL и формируем финальную ссылку
const encodedMessage = encodeURIComponent(messageText);
const whatsappUrl = `https://wa.me/send?phone=${whatsappNumber}&text=${encodedMessage}`;
// --- КОНЕЦ НОВОГО БЛОКА ---
---

{/* Скрытый RAG-хинт — подхватывается парсером бота, невидим пользователям */}
{ragHint && <div style="display:none" aria-hidden="true">{ragHint}</div>}

{/* Добавляем `id` к главному оберточному элементу */}
<div class="yvc-wrapper" id={id}>
  <div class="yvc-card service-card" style={`--c:${tagColor}; --i:0`}>
    {/* ── Верхняя часть: видео + тег ── */}
    <div class="sc-img-wrap yvc-img-wrap">
      <div class="yvc-video-wrap">
        <CloudinaryVideo
          videoUrl={videoUrl}
          posterUrl={posterUrl}
          name={videoName}
          description={videoDescription}
          uploadDate={isoUploadDate}
          isVertical={true}
        />
      </div>
      <div class="sc-tag" style={`background:${tagColor}; color:#fff`}>
        {tagText}
      </div>
    </div>

    {/* ── Тело карточки: иконка + заголовок + контент + кнопка ── */}
    <div class="sc-body">
      <div class="sc-icon">{icon}</div>
      <h3>{title}</h3>

      {/* Прайс-лист и всё остальное — передаётся со страницы через slot */}
      <slot />

      {note && <p class="pricing-note">{note}</p>}

      {/* Обновляем href для ссылки WhatsApp */}
      <a
        href={whatsappUrl}
        class="sc-arrow yvc-wa-link"
        style="color:#25D366"
        target="_blank"
        rel="noopener"
      >
        {whatsappLabel}
        <svg
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          width="15"
          height="15"><polyline points="15 18 9 12 15 6"></polyline></svg
        >
      </a>
    </div>
  </div>
</div>

<style>
  /* Стили остаются без изменений */
  .yvc-wrapper {
    display: grid;
    grid-template-columns: minmax(auto, 350px);
    justify-content: center;
    margin-top: 3rem;
    margin-bottom: 2rem;
  }
  .yvc-img-wrap {
    aspect-ratio: 9 / 16 !important;
    height: auto !important;
  }
  .yvc-video-wrap {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }
  .yvc-video-wrap :global(.cloudinary-video-facade) {
    margin: 0;
    max-width: 100%;
    border-radius: 0;
    width: 100%;
    height: 100%;
    aspect-ratio: unset;
  }
  .yvc-wa-link {
    text-decoration: none;
    cursor: pointer;
  }
</style>