---
interface Props {
  videoUrl: string;
  posterUrl: string;
  name: string;
  description: string;
  uploadDate?: string;
  isVertical?: boolean;
}

const { 
  videoUrl, 
  posterUrl, 
  name, 
  description, 
  uploadDate = new Date().toISOString().split('T')[0], 
  isVertical = false 
} = Astro.props;

const schemaInfo = {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  name: name,
  description: description,
  thumbnailUrl: posterUrl,
  contentUrl: videoUrl,
  uploadDate: uploadDate
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(schemaInfo)} />

<div class={`cloudinary-video-facade ${isVertical ? 'is-vertical' : ''}`} data-video={videoUrl}>
  <img 
    src={posterUrl} 
    alt={name} 
    class="video-poster" 
    loading="lazy" 
    width={isVertical ? "450" : "800"} 
    height={isVertical ? "800" : "450"} 
  />
  <button class="play-button" aria-label="Play Video">
    <svg viewBox="0 0 24 24" width="48" height="48" fill="white">
      <path d="M8 5v14l11-7z" />
    </svg>
  </button>
</div>

<style>
  .cloudinary-video-facade {
    position: relative;
    width: 100%;
    max-width: 800px;
    margin: 3rem auto;
    cursor: pointer;
    overflow: hidden;
    border-radius: 12px;
    aspect-ratio: 16 / 9;
    background-color: #000;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
  }
  .cloudinary-video-facade.is-vertical {
    max-width: 450px;
    aspect-ratio: 9 / 16;
  }
  .video-poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s ease;
  }
  .play-button {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(0, 0, 0, 0.6);
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 2;
  }
  .cloudinary-video-facade:hover .play-button {
    background: rgba(0, 0, 0, 0.8);
    transform: translate(-50%, -50%) scale(1.1);
    border-color: rgba(255, 255, 255, 0.5);
  }
  .play-button svg {
    margin-left: 5px; /* Adjust optical center */
  }
  .cloudinary-video-facade.is-playing .video-poster,
  .cloudinary-video-facade.is-playing .play-button {
    display: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const facades = document.querySelectorAll('.cloudinary-video-facade');
    facades.forEach(facade => {
      facade.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        if (!target || target.classList.contains('is-playing')) return;
        
        const videoUrl = target.getAttribute('data-video');
        if (!videoUrl) return;

        const isVert = target.classList.contains('is-vertical');
        const video = document.createElement('video');
        
        video.src = videoUrl;
        video.controls = true;
        video.autoplay = true;
        video.playsInline = true;
        
        // --- НАШИ НОВЫЕ НАСТРОЙКИ ЗВУКА И РАЗМЕРА ---
        video.muted = true; 
        video.setAttribute('width', isVert ? '450' : '800');
        video.setAttribute('height', isVert ? '800' : '450');
        // -------------------------------------------

        video.style.width = '100%';
        video.style.height = '100%';
        video.style.objectFit = 'cover';
        video.style.position = 'absolute';
        video.style.top = '0';
        video.style.left = '0';
        video.style.zIndex = '1';

        target.appendChild(video);
        target.classList.add('is-playing');
      }, { once: true });
    });
  });
</script>