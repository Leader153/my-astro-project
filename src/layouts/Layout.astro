---
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import AccessibilityWidget from "../components/AccessibilityWidget.astro";
import "../styles/global.css";
import CookieBanner from "../components/CookieBanner.astro";
import ChatWidget from "../components/ChatWidget.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string; // URL картинки для соцсетей (необязательно)
  ogType?: string; // 'website' | 'article' — по умолчанию 'website'
}

const {
  title,
  description = "הפלגות יאכטה פרטיות בחיפה ובהרצליה — שייט רומנטי, מסיבות, ימי גיבוש ואירועי חברה. 10+ שנות ניסיון, סקיפרים מוסמכים.",
  ogImage = "/og-image.jpg",
  ogType = "website",
} = Astro.props;

const siteUrl = "https://aflagot-haifa.com";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageAbsolute = ogImage.startsWith("http")
  ? ogImage
  : `${siteUrl}${ogImage}`;

// Schema.org — LocalBusiness (общий для всего сайта)
const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Leader הפלגות",
  description:
    "הפלגות יאכטה פרטיות בחיפה ובהרצליה — שייט רומנטי, מסיבות, ימי גיבוש ואירועי חברה.",
  url: siteUrl,
  telephone: "+972-53-340-3449",
  image: ogImageAbsolute,
  priceRange: "₪₪",
  address: [
    {
      "@type": "PostalAddress",
      streetAddress: "הדייגים 3, חיפה",
      addressLocality: "מעגן שביט, פארק קישון",
      addressCountry: "IL",
    },
    {
      "@type": "PostalAddress",
      streetAddress: "יורדי ים 1, הרצליה",
      addressLocality: "מרינה הרצליה",
      addressCountry: "IL",
    },
  ],
  geo: [
    {
      "@type": "GeoCoordinates",
      name: "מעגן שביט, פארק קישון – חיפה",
      latitude: 32.8069,
      longitude: 35.0322,
    },
    {
      "@type": "GeoCoordinates",
      name: "מרינה הרצליה",
      latitude: 32.1641,
      longitude: 34.7985,
    },
  ],
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: [
      "Sunday",
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday",
    ],
    opens: "08:00",
    closes: "22:00",
  },
  sameAs: [
    "https://www.facebook.com/leadership.haifa",
    "https://www.instagram.com/leader.aflagot?igsh=YnAzcThrbDExd2o5",
    "https://www.youtube.com/channel/UCzEOzFcGu8zSeFtFrif4cYw",
  ],
};
---

<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Fonts preload (Non-blocking) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript
      ><link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;600;700;800;900&display=swap"
      /></noscript
    >

    <!-- SEO Base -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="he_IL" />
    <meta property="og:site_name" content="Leader הפלגות" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Schema.org JSON-LD -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(schemaOrg)}
    />

    <!-- Google Analytics & Ads via Partytown -->
    <script
      is:inline
      type="text/partytown"
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-S72RCPM0G2"></script>
    <script is:inline type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-S72RCPM0G2"); // Google Analytics
      gtag("config", "AW-16769482607"); // Google Ads
    </script>

    <!-- Google Tag Manager (GTM) -->
    <script is:inline type="text/partytown">
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-ML2RKBS");

      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-PDP6ZZXF");
    </script>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-ML2RKBS"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-PDP6ZZXF"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <Navigation />
    <main class="page-content">
      <slot />
    </main>
    <Footer />
    <AccessibilityWidget />
    <CookieBanner />
    <ChatWidget />
  </body>
</html>
