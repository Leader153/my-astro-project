---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import Heroimg from "../assets/LeaCatamaran.png";
import img1 from "../assets/LeaCatamaran.png";
import midImg from "../assets/lea-back.png";
import botImg from "../assets/Lea-up.jpg";
import FleetSelectionCta from "../components/FleetSelectionCta.astro";
import PremiumSwitch from "../components/PremiumSwitch.astro";
import "../styles/pricing-card.css";
---

<Layout
  title="לאה - יאכטה קטמרן מפרשית (עד 14 איש) בהרצליה | Leader הפלגות"
  description="השכרת יאכטה לאה קטמרן מפרשית בהרצליה ל-14 מפליגים. החל מ-2,490 ₪ לשעה. מושלם לחגיגות ומשפחות. כולל סקיפר, בלונים ואבוב. שייט מפואר ויציב בים."
>
  <div class="service-page" dir="rtl">
    <section class="sp-hero">
      <Image
        src={Heroimg}
        alt="יאכטה קטמרן מפוארת"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg desktop-hero"
      />
      <Image
        src={Heroimg}
        alt="יאכטה קטמרן מפוארת"
        widths={[400, 768]}
        sizes="100vw"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg mobile-hero"
        style="object-position: 50% 50%;"
      />
    </section>

    <section class="sp-content">
      <div class="sp-inner">
        <h1>לאה - יאכטה קטמרן מפרשית מפוארת מדגם Lagoon 40</h1>
        <p>
          חוויית הפלגה שקטה וחלקה על קטמרן מפרשית יציבה המציעה מקסימום רווח
          ויוקרה אמיתית בים.
        </p>

        <h3>✨ שקט של מפרש ויוקרה של קטמרן</h3>
        <p>
          ליאכטות קטמרן מסוג מפרשית יש קסם מיוחד - הן מרחפות על המים ביציבות
          חסרת פשרות בשל שני הבידונים הענקיים שלהן. כשהמפרש עולה והמנועים
          דוממים, זוהי חוויית השקט והבריזה הטהורה של הים. הקטמרן שלנו מאובזרת
          בכל מה שצריך להפלגת שיא עם החברים או המשפחה, ואזורי שיזוף קדמיים
          מרגשים שישאירו טעם של עוד.
        </p>
        <p>
          יאכטה קטמרן מפרשית בעלת שני בידונים של חברת Lagoon הצרפתית<br />
          <strong>שנת יצור:</strong> 2020<br />
          <strong>אורך קטמרן:</strong> 12 מטר<br />
          הדגם כולל 4 קבינות שינה ו- 4 שירותים ומקלחות.
        </p>

        <Image
          src={img1}
          alt="יאכטה קטמרן מבחוץ"
          class="sp-gallery-img"
          style="aspect-ratio: 3/2; object-fit: cover;"
          format="webp"
        />

        <h3>💎 אידיאלית למשפחות וחגיגות</h3>
        <p>
          ספינה נוחה ומפנקת ומותאמת במיוחד להפלגות משפחתיות והפלגות חברים.
          מושלמת לאירועים וחגיגות.
        </p>
        <p>
          הרשת הקדמית והסיפון האחורי מרווחים ונוחים ומעניקים מרחב אידיאלי
          להתרווחות תחת קרני השמש, ואידיאלית לקבוצות של עד 14 מפליגים.
        </p>

        <Image
          src={midImg}
          alt="סיפון אלגנטי ויציב"
          class="sp-gallery-img"
          style="aspect-ratio: 3/2; object-fit: cover;"
          format="webp"
        />

        <h3>⭐ חוויה של פעם בחיים</h3>
        <p>
          השילוב של סיפון ענק, יציבות מקסימלית ותנאי מלון אמיתיים על הים, הופכים
          כל הפלגה על הקטמרן שלנו לחוויה עוצרת נשימה.
        </p>

        <Image
          src={botImg}
          alt="מבט נוסף על הקוקפיט"
          class="sp-gallery-img"
          style="aspect-ratio: 3/2; object-fit: cover;"
          format="webp"
        />

        <p class="sp-closing">
          רוצים להפליג? הקטמרן המפוארת מחכה לכם!<br />
          התקשרו להזמין עכשיו: 053-3403449
        </p>
      </div>

      <div class="services-grid">
        <a
          href="https://wa.me/972533403449"
          class="service-card"
          style="--c:#d4a017; --i:0"
          target="_blank"
          rel="noopener"
        >
          <div class="sc-img-wrap">
            <Image
              src={Heroimg}
              width={600}
              height={400}
              format="webp"
              alt="קטמרן"
              class="sc-img"
              loading="lazy"
              style="object-position: center;"
            />
            <div class="sc-tag" style="background:#d4a017; color:#fff">
              הרצליה
            </div>
          </div>
          <div class="sc-body">
            <div class="sc-icon">⛵</div>
            <h3>מחירון לאה - יאכטה קטמרן מפרשית</h3>
            <p><strong>מחירון השכרת קטמרן מפרשית:</strong></p>
            <ul class="pricing-list no-bullets">
              <li><strong>שעה הפלגה:</strong> 2,490 ₪</li>
              <li><strong>שעתיים הפלגה:</strong> 3,100 ₪</li>
              <li><strong>3 שעות הפלגה:</strong> 4,090 ₪</li>
              <li>כל שעה נוספת: 990 ₪</li>
              <li>👑 עד 14 מפליגים מאושרים</li>
            </ul>

            <h4 class="pricing-title">המחיר כולל:</h4>
            <ul class="pricing-list">
              <li>שלט מזל טוב</li>
              <li>בלונים בתוך היאכטה</li>
              <li>מוזיקה (רמקול בלוטוס)</li>
              <li>שתייה מים</li>
              <li>ביטוח לכל משתתף</li>
              <li>שירות של סקיפר מקצועי לאורך כל הדרך</li>
            </ul>

            <h4 class="pricing-title">בהזמנה של 3 שעות:</h4>
            <ul class="pricing-list">
              <li>ירידה לים עם אבוב 🌊</li>
            </ul>

            <p class="pricing-note">* מחיר כולל מע"מ, תקף לסוף שבוע</p>
            <div class="sc-arrow" style="color:#25D366">
              להזמנה בוואטסאפ
              <svg
                aria-hidden="true"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                width="15"
                height="15"><polyline points="15 18 9 12 15 6"></polyline></svg
              >
            </div>
          </div>
        </a>
      </div>

      <PremiumSwitch
        href="/yachts-herzliya"
        title="בחזרה ליאכטות הרצליה"
        subtitle="לצפייה בצי שלנו ולבחירת היאכטה המושלמת"
      />
    </section>
  </div>
  <FleetSelectionCta
    ctaInstruction="נא להמשיך להזמנה או לצפות בעוד יאכטות בהרצליה:"
  />

  <!-- Schema.org Data API -->
  <script is:inline type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      name: "לאה יאכטה קטמרן מפרשית הרצליה",
      description:
        "השכרת יאכטה קטמרן מפרשית לאה במרינה הרצליה עד 14 מפליגים, כולל סקיפר, ירידה לים עם אבוב, בלונים ומוזיקה.",
      image: "https://aflagot-haifa.com/seo/seo-Leader-cruise.jpg",
      brand: { "@type": "Brand", name: "Leader שייט & הפלגות" },
      seller: {
        "@type": "TravelAgency",
        "@id": "https://aflagot-haifa.com/",
        name: "Leader שייט & הפלגות",
        legalName: "לידר",
        alternateName: [
          "Leader Haflagot",
          "לידר הפלגות שייט",
          "Leader Yachting",
        ],
        telephone: "+972533403449",
        url: "https://aflagot-haifa.com/",
        sameAs: [
          "https://www.facebook.com/leadership.haifa",
          "https://www.instagram.com/leader.aflagot?igsh=YnAzcThrbDExd2o5",
          "https://www.youtube.com/channel/UCzEOzFcGu8zSeFtFrif4cYw",
        ],
      },
      offers: {
        "@type": "AggregateOffer",
        priceCurrency: "ILS",
        lowPrice: "2490",
        highPrice: "4090",
        offerCount: "3",
        offers: [
          {
            "@type": "Offer",
            name: "הפלגה לשעה אחת",
            price: "2490",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/catamaran-Lea",
          },
          {
            "@type": "Offer",
            name: "הפלגה לשעתיים",
            price: "3100",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/catamaran-Lea",
          },
          {
            "@type": "Offer",
            name: "הפלגה ל-3 שעות",
            price: "4090",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/catamaran-Lea",
          },
        ],
      },
    })}
  />
</Layout>
