---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import PremiumSwitch from "../components/PremiumSwitch.astro";
import cardImg from "../assets/Romantic cruise 2.webp";
import dinnerCardImg from "../assets/couple-romantic-dinner.jpeg";
import fishingCardImg from "../assets/original-high-res.png";
import zimmerCardImg from "../assets/dinner-couple-cabin-herzelia.jpeg";
import marinaImg from "../assets/marina-herzelia.webp";
import marunaImg from "../assets/maruna-herzelia.webp";
import skiperImg from "../assets/skipper-for-a-day-learning-to-steer-yacht.jpeg";
import catamaranimg from "../assets/Dolfin.jpeg";
import leaderYacht from "../assets/leaderYacht.jpeg";
import MeryMeimg from "../assets/MeryMe.png";
import LeacatImg from "../assets/birthday-celebration-yacht-cake-herzliya.webp";
import "../styles/catalog-page.css";

const services = [
  {
    icon: "⛵",
    title: "צי יאכטות הרצליה",
    desc: "צי היאכטות הגדול ביותר במרינה הרצליה",
    tag: "הכי גדול",
    color: "#e91e8c",
    alt: "צי היאכטות הגדול ביותר במרינה הרצליה",
    href: "/yachts-herzliya",
    img: leaderYacht,
  },
  {
    icon: "⛵",
    title: "קטמרן עד 21 מפליגים",
    desc: "יאכטת קטמרן ענקית ומרווחת להפלגות קבוצתיות גדולות, ימי הולדת ומסיבות מרובות משתתפים",
    tag: "לקבוצות",
    color: "#059669",
    alt: "הפלגת קטמרן עד 21 איש במרינה הרצליה",
    href: "/catamaran-21",
    img: catamaranimg,
  },
  {
    icon: "🥂",
    title: "שייט רומנטי",
    desc: "חוויה אינטימית ומושלמת לזוגות אוהבים בשקיעה, כולל יין ומוזיקה לבחירתכם",
    tag: "לזוגות",
    color: "#e91e8c",
    alt: "שייט רומנטי במרינה הרצליה",
    href: "/romantic-sailing",
    img: cardImg,
  },
  {
    icon: "🍽️",
    title: "ארוחה רומנטית על יאכטה",
    desc: "ארוחה זוגית מפנקת על סיפון היאכטה עם נוף לים, נרות, שמפניה ואווירה שלא תשכחו",
    tag: "רומנטי",
    color: "#e91e8c",
    alt: "זוג נהנה מארוחה רומנטית על גשר יאכטה מול מרינה הרצליה",
    href: "/yacht-dining-herzliya",
    img: dinnerCardImg,
  },
  {
    icon: "🎣",
    title: "דייג",
    desc: "יום דייג מהנה בים — ללא צורך ברישיון דייג. הכל כלול: ציוד, הדרכה וסקיפר מנוסה",
    tag: "חוויה",
    color: "#0f7ab0",
    alt: "דייג חוויתי מיאכטה במרינה הרצליה ללא רישיון",
    href: "/fishing",
    img: fishingCardImg,
  },
  {
    icon: "⛵",
    title: "הפלגת סקיפר ליום אחד",
    desc: "יום שלם בים עם סקיפר מקצועי — שיזוף, נוף, מוזיקה ויין. חוויה מהסרטים",
    tag: "פופולרי",
    color: "#7c3aed",
    alt: "הפלגה ביאכטה עם סקיפר מקצועי ליום אחד מהרצליה",
    href: "/skipper-day-cruise",
    img: skiperImg,
  },
  {
    icon: "🌙",
    title: "צימר על הים",
    desc: "לינה על יאכטה — חוויה יוקרתית וייחודית ממש בים. בקתה צפה עם כל הפינוקים",
    tag: "יוקרה",
    color: "#d4a017",
    alt: "לינת צימר על יאכטה פרטית בלילה מול מרינה הרצליה",
    href: "/sea-cabin",
    img: zimmerCardImg,
  },
  {
    icon: "⛵",
    title: "הצעת נישואין על יאכטה",
    desc: "הפקה מושלמת להצעת נישואין מרגשת בלב ים. כולל עיצוב רומנטי, שטיח אדום, וצילום מקצועי",
    tag: "מרגש",
    color: "#e11d48",
    alt: "הצעת נישואין מרגשת על יאכטה במרינה הרצליה",
    href: "/marriage-proposal",
    img: MeryMeimg,
  },
  {
    icon: "⛵",
    title: "מסיבת יום הולדת",
    desc: "חגיגת יום הולדת מטורפת על יאכטה עם כל החברים, מוזיקה מעולה, בלונים ושתייה עם אווירה מחשמלת",
    tag: "מסיבה",
    color: "#f59e0b",
    alt: "חגיגת יום הולדת על יאכטה במרינה הרצליה",
    href: "/birthday",
    img: LeacatImg,
  },
];

const textSections = [
  {
    icon: "👨‍✈️",
    title: "קבלת פנים אישית",
    text: "בבואכם למרינה הרצליה הסקיפר יקבל את פניכם בחיוך, ילווה אתכם ליאכטה, יגיש לכם ארוחות, שתייה, יקשט, יפנק, וישיט אתכם במקצועיות בטיחות והנאה רבה. תרגישו את הבריזה מהים, תשאפו אוויר ים צלול ותיצרו זיכרונות שיישארו אתכם לנצח.",
  },
  {
    icon: "⚓",
    title: "מיקום יוקרתי ופרטי",
    text: "היאכטות שלנו עוגנות מול טיילת המסעדות, במעלה הרציף אליו רק מורשים יכולים להיכנס. כך שמצד אחד אתם בלב העניינים ומצד שני תקבלו פרטיות יוקרתית. כל אירוח אצלנו כולל בקבוק שמפניה גדול, מוזיקה מגוונת ואווירה ייחודית.",
  },
  {
    icon: "🥂",
    title: "הפלגה פרטית וחלומית",
    text: 'חברת <span class="brand-leader">לידר הפלגות &amp; שייט</span> מזמינה אותכם להנות מהפלגות בוטיק יוקרתיות — חוויה פרטית וחלומית שתיזכרו בה כל החיים. בהפלגה תצאו עם סקיפר מקצועי ותוכלו להתפנק מהנופים, להשתזף בשמש, ללגום מהיין האיכותי, להנות מהמוזיקה — ולחוות פינוק מושלם מהרגע הראשון ועד האחרון.',
  },
  {
    icon: "👥",
    title: "יום כיף לארגונים וקבוצות",
    text: "מחפשים להעביר יום כיף בים עם החברים או עובדי החברה? אנחנו מזמינים אותכם ליום כיף שכולו שייט מהנה!",
  },
  {
    icon: "💬",
    title: "שירות שמתחיל כבר עכשיו",
    text: "מבחינתנו השירות מתחיל בעודכם קוראים שורות אלו, ממשיך בשיחת הטלפון שבה נשמע אתכם, נכיר אתכם, מה אתם חולמים וכיצד ניתן להגשים את רצונכם ולהתאים לכם חווית שייט אישית בדיוק עבורכם.",
  },
  {
    icon: "📍",
    title: "מרינה הרצליה",
    text: "אנו ממוקמים במרינה המפוארת בהרצליה המשמשת כפלטפורמה ייחודית ויוקרתית ונגישה לכל אירוע. היאכטות שלנו מאובזרות בכל הנדרש על מנת לדאוג לנוחות, להנאה, ולפרטיות שלכם.",
  },
];
---

<Layout
  title="הפלגה בהרצליה - השכרת יאכטות ואירועי בוטיק בים ⚓ | Leader הפלגות"
  description="חולמים על שייט והפלגה במרינה הרצליה? בואו לחגוג על יאכטה פרטית! הפלגות בוטיק יוקרתיות לזוגות, ימי הולדת וגיבוש. צי היאכטות הגדול והמפנק ביותר בשרון."
>
  <div class="hz-page" dir="rtl">
    <!-- ══ HERO ══ -->
    <section class="hz-hero">
      <div class="hz-hero-bg"></div>
      <div class="hz-hero-inner">
        <div class="hz-eyebrow">
          <span class="dot"></span>
          מרינה הרצליה
        </div>
        <h1>שייט בהרצליה</h1>
        <p>
          הפלגות יאכטה פרטיות, ארוחות על הים, דייג חוויתי וצימר ימי — הכל בלב
          מרינה הרצליה היוקרתית
        </p>
        <div class="hz-hero-btns">
          <a href="/contact" class="hz-btn primary">לפרטים והזמנה</a>
          <a
            href="https://wa.me/972533403449"
            target="_blank"
            rel="noopener"
            class="hz-btn wa"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              width="18"
              height="18"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path></svg
            >
            WhatsApp
          </a>
        </div>
      </div>
    </section>

    <!-- ══ SERVICES CARDS ══ -->
    <section class="hz-services">
      <div class="hz-inner">
        <div class="hz-section-header">
          <div class="hz-eyebrow-sm">מה אנחנו מציעים</div>
          <h2>חוויות שלא תשכחו</h2>
          <p>בחרו את ההפלגה המושלמת עבורכם — אנחנו נדאג לשאר</p>
        </div>

        <div class="hz-grid">
          {
            services.slice(0, 3).map((s, i) => (
              <a
                href={s.href}
                class="hz-card"
                style={`--c:${s.color}; --i:${i}`}
              >
                <div class="hz-card-img">
                  <Image
                    src={s.img}
                    width={600}
                    height={400}
                    format="webp"
                    alt={s.alt}
                    class="hz-img"
                    loading={i < 2 ? "eager" : "lazy"}
                  />
                  <div class="hz-badge" style={`background:${s.color}`}>
                    {s.tag}
                  </div>
                </div>
                <div class="hz-card-body">
                  <div class="hz-card-icon">{s.icon}</div>
                  <h3>{s.title}</h3>
                  <p>{s.desc}</p>
                  <span class="hz-card-cta" style={`color:${s.color}`}>
                    לפרטים
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      width="14"
                      height="14"
                    >
                      <polyline points="15 18 9 12 15 6" />
                    </svg>
                  </span>
                </div>
                <div class="hz-glow" style={`background:${s.color}`} />
              </a>
            ))
          }
        </div>

        <div class="hz-mid-text" style="margin: 3rem auto 2rem auto;">
          <p class="hmt-main">
            <strong>מרינה הרצליה</strong><br />
            אנו ממוקמים במרינה המפוארת בהרצליה המשמשת כפלטפורמה ייחודית ויוקרתית ונגישה
            לכל אירוע. היאכטות שלנו מאובזרות בכל הנדרש על מנת לדאוג לנוחות, להנאה,
            ולפרטיות שלכם.
          </p>
        </div>

        <div class="hz-maruna-out-of-frame">
          <Image
            src={marunaImg}
            width={1200}
            height={675}
            format="webp"
            alt="מבט מרחפן על מרינה הרצליה מי ים"
            class="hz-maruna-img-stretch"
            loading="lazy"
          />
        </div>

        <div class="hz-grid">
          {
            services.slice(3, 6).map((s, i) => (
              <a
                href={s.href}
                class="hz-card"
                style={`--c:${s.color}; --i:${i + 3}`}
              >
                <div class="hz-card-img">
                  <Image
                    src={s.img}
                    width={600}
                    height={400}
                    format="webp"
                    alt={s.alt}
                    class="hz-img"
                    loading="lazy"
                  />
                  <div class="hz-badge" style={`background:${s.color}`}>
                    {s.tag}
                  </div>
                </div>
                <div class="hz-card-body">
                  <div class="hz-card-icon">{s.icon}</div>
                  <h3>{s.title}</h3>
                  <p>{s.desc}</p>
                  <span class="hz-card-cta" style={`color:${s.color}`}>
                    לפרטים
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      width="14"
                      height="14"
                    >
                      <polyline points="15 18 9 12 15 6" />
                    </svg>
                  </span>
                </div>
                <div class="hz-glow" style={`background:${s.color}`} />
              </a>
            ))
          }
        </div>

        <div class="hz-mid-text" style="margin: 3rem auto;">
          <p class="hmt-main">
            <strong>מיקום יוקרתי ופרטי</strong><br />
            היאכטות שלנו עוגנות מול טיילת המסעדות, במעלה הרציף אליו רק מורשים יכולים
            להיכנס. כך שמצד אחד אתם בלב העניינים ומצד שני תקבלו פרטיות יוקרתית. כל
            אירוח אצלנו כולל בקבוק שמפניה גדול, מוזיקה מגוונת ואווירה ייחודית.
          </p>
        </div>

        <div class="hz-grid">
          {
            services.slice(6).map((s, i) => (
              <a
                href={s.href}
                class="hz-card"
                style={`--c:${s.color}; --i:${i + 6}`}
              >
                <div class="hz-card-img">
                  <Image
                    src={s.img}
                    width={600}
                    height={400}
                    format="webp"
                    alt={s.alt}
                    class="hz-img"
                    loading="lazy"
                  />
                  <div class="hz-badge" style={`background:${s.color}`}>
                    {s.tag}
                  </div>
                </div>
                <div class="hz-card-body">
                  <div class="hz-card-icon">{s.icon}</div>
                  <h3>{s.title}</h3>
                  <p>{s.desc}</p>
                  <span class="hz-card-cta" style={`color:${s.color}`}>
                    לפרטים
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      width="14"
                      height="14"
                    >
                      <polyline points="15 18 9 12 15 6" />
                    </svg>
                  </span>
                </div>
                <div class="hz-glow" style={`background:${s.color}`} />
              </a>
            ))
          }
        </div>

        <div class="hz-mid-text" style="margin-top: 3rem;">
          <p class="hmt-main">
            <strong>הפלגה פרטית וחלומית</strong><br />
            חברת <span class="brand-leader">לידר הפלגות &amp; שייט</span> מזמינה אותכם
            להנות מהפלגה פרטית וחלומית. בהפלגה תצאו עם סקיפר מקצועי על אחת היאכטות
            שלנו ותוכלו להתפנק מהנופים, להשתזף בשמש, ללגום מהיין האיכותי, להנות מהמוזיקה
            שלכם ברקע.
          </p>
        </div>
      </div>
    </section>

    <!-- ══ TEXT SECTIONS ══ -->
    <section class="hz-about">
      <div class="hz-inner">
        <div class="hz-section-header">
          <div class="hz-eyebrow-sm">על השירות שלנו</div>
          <h2>הרבה יותר מסתם הפלגה</h2>
        </div>

        <div class="hz-about-grid">
          {
            textSections.map((sec, i) => (
              <div class="hz-about-card" style={`--i:${i}`}>
                <div class="hz-about-icon">{sec.icon}</div>
                <div>
                  <h3>{sec.title}</h3>
                  <p set:html={sec.text} />
                </div>
              </div>
            ))
          }
        </div>

        <PremiumSwitch
          href="/yachts-herzliya"
          title="היאכטות שלנו בהרצליה"
          subtitle="לצפייה בצי שלנו ולבחירת היאכטה המושלמת"
        />
      </div>
    </section>

    <!-- ══ MARINA PHOTO ══ -->
    <section class="hz-marina-container">
      <div class="hz-marina-wrap">
        <Image
          src={marinaImg}
          widths={[768, 1280, 1920]}
          sizes="100vw"
          format="webp"
          alt="נוף אווירי של מרינה הרצליה — עגינות יאכטות ורחובות המרינה היוקרתיים"
          class="hz-marina-img"
          loading="lazy"
        />
      </div>
      <div class="hz-marina-info">
        <div class="hz-marina-eyebrow-dark">📍 המיקום שלנו</div>
        <h2>מרינה הרצליה</h2>
        <p>
          אנו ממוקמים בלב המרינה המפוארת — רציף E, מול שער A, צמוד לקניון ארנה
        </p>
        <a
          href="https://maps.google.com/?q=מרינה+הרצליה"
          target="_blank"
          rel="noopener noreferrer"
          class="hz-btn primary"
        >
          פתח במפה ↗
        </a>
      </div>
    </section>

    <!-- ══ CTA ══ -->
    <section class="hz-cta">
      <div class="hz-cta-bg"></div>
      <div class="hz-cta-inner">
        <h2>מוכנים לצאת לים מהרצליה?</h2>
