---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import heroImage from "../assets/Massage-and-dinner-for-couples-on-a-yacht.jpg";
import img1 from "../assets/Massage-and-dinner-for-couples-on-a-yacht.jpg";
import midImg from "../assets/romantic-dinner-couple-cabin-herzelia.jpeg";
import botImg from "../assets/Massage-and-dinner-for-couples.jpeg";
import FleetSelectionCta from "../components/FleetSelectionCta.astro";
---

<Layout
  title="חבילת ספא פלטיניום – ספא, הפלגה, עיסוי וארוחה זוגית ביאכטה פרטית"
  description="חבילת ספא פלטיניום מפנקת: עיסוי זוגי ביאכטה, הפלגה חווייתית בים וארוחה זוגית עשירה. המתנה הרומנטית המושלמת לבן הזוג שלכם. הזמינו עכשיו!"
>
  <div class="spa-page" dir="rtl">
    <!-- ══ HERO ══ -->
    <section class="spa-hero">
      <Image
        src={heroImage}
        alt="יאכטה פרטית לחבילת ספא פלטיניום עם הפלגה ועיסוי זוגי"
        width={1920}
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="hero-img"
      />
    </section>

    <!-- MOBILE HERO -->
    <div class="spa-hero-mobile-wrap">
      <Image
        src={heroImage}
        widths={[400, 768]}
        sizes="100vw"
        format="webp"
        alt="חבילת ספא פלטיניום – הפלגה ועיסוי זוגי ביאכטה"
        class="mobile-hero-img"
        loading="eager"
        fetchpriority="high"
      />
    </div>

    <!-- ══ INTRO ══ -->
    <section class="spa-section">
      <div class="spa-inner">
        <div class="spa-section-header">
          <h1>חבילת ספא פלטיניום ביאכטה</h1>
          <p class="spa-section-sub">💍 ספא · הפלגה · עיסוי זוגי · ארוחה</p>
        </div>
        <div class="spa-text-article">
          <p>
            אם אתם מחפשים מתנה מפתיעה ומרגיעה במיוחד לבן הזוג שלכם – תנו לנו
            להציע לכם את <strong>חבילת הפלטיניום המפנקת</strong> שלנו.
          </p>
          <p>
            שילוב של <strong>ספא והפלגה חווייתית בים</strong>, עיסוי מפנק ומרגיע
            וארוחה עשירה – מה צריך יותר מזה?
          </p>
          <p>
            חבילת הפלטיניום שלנו היא חבילה של <strong>ארבע שעות</strong> הכוללת: עיסוי
            של שעה וחצי (45 דקות לכל אחד מבני הזוג בנפרד בחדר חרטום של היאכטה), זמן
            איכות לבד ביאכטה ויציאה להפלגה של שעה וחצי עם
            <strong>ארוחה זוגית עשירה לבחירתכם.</strong>
          </p>
          <p class="spa-tagline">תנו לנו לפנק אתכם באירוח ספא מושלם 💫</p>
        </div>
      </div>
    </section>

    <!-- ══ BREAK IMAGE 1 ══ -->
    <div class="spa-break-img-wrapper">
      <Image
        src={img1}
        alt="זוג נהנה מחוויית ספא ביאכטה פרטית"
        class="spa-break-img"
        format="webp"
      />
    </div>

    <!-- ══ WHAT'S INCLUDED ══ -->
    <section class="spa-section spa-section--alt">
      <div class="spa-inner">
        <div class="spa-section-header">
          <h2>מה אתם מקבלים בחבילה?</h2>
          <p class="spa-section-sub">🎁 כל מה שצריך לחוויה בלתי נשכחת</p>
        </div>

        <div class="spa-gifts-grid">
          <div class="spa-gift-card">
            <div class="spa-gift-icon">🍷</div>
            <h3>בקבוק יין</h3>
            <p>בקבוק יין מובחר שיחכה לכם בעת עלייתכם ליאכטה</p>
          </div>
          <div class="spa-gift-card">
            <div class="spa-gift-icon">🌹</div>
            <h3>קישוט רומנטי</h3>
            <p>לב מעלי כותרת על המיטה, סוכריות ואווירה מיוחדת לכבודכם</p>
          </div>
          <div class="spa-gift-card">
            <div class="spa-gift-icon">☕</div>
            <h3>שתייה חמה וקרה</h3>
            <p>שתייה חמה וקלה חופשית לאורך כל החוויה</p>
          </div>
          <div class="spa-gift-card">
            <div class="spa-gift-icon">📸</div>
            <h3>צילום מקצועי</h3>
            <p>תיעוד מקצועי של הרגעים המיוחדים (יש לציין בעת ההזמנה)</p>
          </div>
          <div class="spa-gift-card">
            <div class="spa-gift-icon">🍽️</div>
            <h3>ארוחה לבחירתכם</h3>
            <p>אפשרות לארוחת בוקר, צהריים או ערב עשירה לבחירתכם</p>
          </div>
          <div class="spa-gift-card">
            <div class="spa-gift-icon">⛵</div>
            <h3>הפלגה זוגית</h3>
            <p>שעה וחצי של הפלגה פרטית בלב ים בצמוד לארוחה</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ BREAK IMAGE 2 ══ -->
    <div class="spa-break-img-wrapper" style="max-width: 700px;">
      <Image
        src={midImg}
        alt="ביאכטה פרטית עם סלון ממוזג ואווירה מפנקת"
        class="spa-break-img"
        format="webp"
        style="aspect-ratio: 1 / 1; max-height: 700px;"
      />
    </div>

    <!-- ══ YACHT AMENITIES ══ -->
    <section class="spa-section">
      <div class="spa-inner">
        <div class="spa-section-header">
          <h2>מה יהיה לנו ביאכטה?</h2>
          <p class="spa-section-sub">
            ⚓ אבזור מלא · סלון · מוזיקה · ים של כיף
          </p>
        </div>
        <div class="spa-text-article">
          <p>
            היאכטות שלנו <strong>מאובזרות וממוזגות</strong>. בכל יאכטה יש סלון,
            שני חדרי שינה, מטבח מאובזר, מקלחת ושירותים.
          </p>
          <p>
            אנחנו <strong>מקשטים את היאכטה לכבודכם</strong> כדי שתהיה לכם חוויה בלתי
            נשכחת עם מוסיקה טובה, בלונים, שלטים של מזל-טוב, אבוב לטבילה בים, מזרון
            שיזוף בחרטום היאכטה וכל מה שצריך כדי שיהיה לכם
            <strong>ים של כיף</strong>.
          </p>
          <ul class="spa-features-list">
            <li>
              <strong>מוזיקה:</strong> מערכות סאונד למוזיקה עם אפשרות חיבור לכל סוג
              מדיה שתביאו
            </li>
            <li>
              <strong>בלונים ושלטים:</strong> קישוטי חגיגה, שלטי מזל-טוב ואווירה חגיגית
            </li>
            <li>
              <strong>טבילה בים:</strong> אבוב לטבילה מרעננת ומזרון שיזוף בחרטום
            </li>
            <li>
              <strong>פרטיות מלאה:</strong> זמן לבד ביאכטה לפני ואחרי ההפלגה
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ══ BREAK IMAGE 3 ══ -->
    <div class="spa-break-img-wrapper">
      <Image
        src={botImg}
        alt="זוג מבלה ביאכטה פרטית עם נוף לים"
        class="spa-break-img"
        format="webp"
      />
    </div>

    <!-- ══ PRICING ══ -->
    <section class="spa-section spa-section--alt">
      <div class="spa-inner">
        <div class="spa-section-header">
          <h2>מחירון ספא פלטינום ביאכטה</h2>
          <p class="spa-section-sub">💰 בחרו את החבילה המתאימה לכם</p>
        </div>

        <div class="spa-pricing-grid">
          <!-- Package 1: Platinum -->
          <div class="spa-pricing-card spa-pricing-card--featured">
            <div class="spa-pkg-badge">⭐ מומלץ</div>
            <div class="spa-pkg-icon">💎</div>
            <h3>ספא פלטיניום</h3>
            <div class="spa-pkg-duration">4 שעות</div>
            <div class="spa-pkg-description">
              <p>רבע שעה ראשונה: קבלת פנים והתארגנות</p>
              <p>90 דקות עיסוי (45 כל אחד)</p>
              <p>אחרי העיסוי: 45 דקות זמן פרטי ביאכטה</p>
              <p>שעה וחצי האחרונות: הפלגה + ארוחה</p>
            </div>
            <div class="spa-pkg-pricing">
              <div class="spa-price-row">
                <span class="spa-price-label">אמצע שבוע</span>
                <span class="spa-price-value">2,200 ₪</span>
              </div>
              <div class="spa-price-row spa-price-row--weekend">
                <span class="spa-price-label">סוף שבוע וחגים</span>
                <span class="spa-price-value">לפי בקשה</span>
              </div>
            </div>
          </div>

          <!-- Package 2: Gold -->
          <div class="spa-pricing-card">
            <div class="spa-pkg-icon">🥇</div>
            <h3>ספא זהב</h3>
            <div class="spa-pkg-duration">3 שעות</div>
            <div class="spa-pkg-description">
              <p>רבע שעה ראשונה: קבלת פנים והתארגנות</p>
              <p>60 דקות עיסוי (30 כל אחד)</p>
              <p>אחרי העיסוי: 15 דקות זמן פרטי ביאכטה</p>
              <p>שעה וחצי האחרונות: הפלגה + ארוחה</p>
            </div>
            <div class="spa-pkg-pricing">
              <div class="spa-price-row">
                <span class="spa-price-label">אמצע שבוע</span>
                <span class="spa-price-value">1,700 ₪</span>
              </div>
              <div class="spa-price-row spa-price-row--weekend">
                <span class="spa-price-label">סוף שבוע וחגים</span>
                <span class="spa-price-value">לפי בקשה</span>
              </div>
            </div>
          </div>

          <!-- Package 3: Silver -->
          <div class="spa-pricing-card">
            <div class="spa-pkg-icon">🥈</div>
            <h3>ספא כסף</h3>
            <div class="spa-pkg-duration">2.5 שעות</div>
            <div class="spa-pkg-description">
              <p>רבע שעה ראשונה: קבלת פנים והתארגנות</p>
              <p>60 דקות עיסוי (30 כל אחד)</p>
              <p>אחרי העיסוי: 15 דקות זמן פרטי ביאכטה</p>
              <p>השעה האחרונה: הפלגה</p>
            </div>
            <div class="spa-pkg-pricing">
              <div class="spa-price-row">
                <span class="spa-price-label">אמצע שבוע בלבד**</span>
                <span class="spa-price-value">1,400 ₪</span>
              </div>
            </div>
          </div>
        </div>

        <p class="spa-note">** ימי חול ואמצע שבוע בלבד</p>
      </div>
    </section>

    <!-- ══ CTA ══ -->
    <FleetSelectionCta
      ctaInstruction="נא להיכנס לעמוד יאכטות ולתאם את חבילת הספא שלכם:"
    />
  </div>
</Layout>

<!-- Schema.org Data API -->
<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TouristTrip",
    name: "חבילת ספא פלטיניום ביאכטה פרטית",
    description:
      "חבילת ספא פלטיניום: עיסוי זוגי, הפלגה חווייתית וארוחה זוגית ביאכטה פרטית. המתנה הרומנטית המושלמת.",
    url: "https://aflagot-haifa.com/spa",
    image: "https://aflagot-haifa.com/seo/seo-Leader-cruise.jpg",
    touristType: { "@type": "Audience", audienceType: "זוגות" },
    offers: {
      "@type": "AggregateOffer",
      priceCurrency: "ILS",
      lowPrice: "1400",
      highPrice: "2200",
      availability: "https://schema.org/InStock",
    },
    provider: {
      "@type": "TravelAgency",
      name: "לידר הפלגות",
      "@id": "https://aflagot-haifa.com/",
      telephone: "+972533403449",
      sameAs: [
        "https://www.facebook.com/leadership.haifa",
        "https://www.instagram.com/leader.aflagot?igsh=YnAzcThrbDExd2o5",
        "https://www.youtube.com/channel/UCzEOzFcGu8zSeFtFrif4cYw",
      ],
    },
  })}
/>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;600;700;800;900&display=swap");

  .spa-page {
    --navy: #08047e;
    --sea: #0f7ab0;
    --gold: #d4a017;
    --gold-l: #f0c040;
    --bg: #f2f5fb;
    --white: #ffffff;
    --text: #000000;
    --text-m: #111111;
    --text-l: #222222;
    font-family: "Rubik", "Segoe UI", Arial, sans-serif;
    color: var(--text);
    background: var(--bg);
    overflow-x: hidden;
  }

  /* ══ HERO ══ */
  .spa-hero {
    position: relative;
    min-height: 75vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .spa-hero .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .spa-hero-overlay {
    position: relative;
    z-index: 1;
    width: 100%;
    background: linear-gradient(
      to top,
      rgba(8, 4, 126, 0.75) 0%,
      transparent 100%
    );
    padding: 4rem 2rem 3rem;
    text-align: center;
  }
  .spa-hero-content {
    max-width: 700px;
    margin: 0 auto;
  }
  .spa-hero-badge {
    display: inline-block;
    background: var(--gold);
    color: #fff;
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0.35rem 1rem;
    border-radius: 50px;
    margin-bottom: 1rem;
    letter-spacing: 0.5px;
  }
  .spa-hero-content h1 {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 900;
    color: #fff;
    margin: 0 0 0.5rem;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.4);
  }
  .spa-hero-content p {
    font-size: 1.3rem;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
    font-weight: 500;
  }

  .spa-hero-mobile-wrap {
    display: none;
  }

  @media (max-width: 768px) {
    .spa-hero {
      display: none;
    }
    .spa-hero-mobile-wrap {
      display: block;
      width: 100%;
      margin-top: -80px;
      margin-bottom: -30px;
      overflow: hidden;
    }
    .mobile-hero-img {
      width: 100%;
      height: auto;
      min-height: 250px;
      display: block;
      object-fit: cover;
    }
  }

  /* ══ SHARED ══ */
  .spa-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 5rem 1.5rem;
  }
  .spa-section {
    background: var(--bg);
  }
  .spa-section--alt {
    background: #edf1f9;
  }
  .spa-section-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .spa-section-header h1 {
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 900;
    color: var(--navy);
    margin: 0 0 0.5rem;
  }
  .spa-section-header h2 {
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
    font-weight: 800;
    color: var(--text);
    margin: 0 0 0.5rem;
  }
  .spa-section-sub {
    font-size: 1.1rem;
    color: var(--sea);
    font-weight: 500;
    margin: 0.2rem 0 0;
  }

  @media (max-width: 768px) {
    .spa-inner {
      padding-top: 2.5rem;
      padding-bottom: 2.5rem;
    }
    .spa-section-header {
      margin-bottom: 1.5rem;
    }
  }

  /* ══ TEXT ARTICLE ══ */
  .spa-text-article {
    max-width: 800px;
    margin: 0 auto;
    background: var(--white);
    padding: 3.5rem 4rem;
    border-radius: 20px;
    box-shadow: 0 10px 40px rgba(8, 4, 126, 0.05);
    border: 1px solid rgba(8, 4, 126, 0.05);
  }
  .spa-text-article p {
    font-size: 1.15rem;
    line-height: 1.85;
    color: var(--text-m);
    margin-bottom: 1.4rem;
  }
  .spa-tagline {
    font-size: 1.25rem !important;
    font-weight: 700;
    color: var(--navy) !important;
    text-align: center;
    margin-top: 1.5rem;
    margin-bottom: 0 !important;
  }

  .spa-features-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
  }
  .spa-features-list li {
    font-size: 1.1rem;
    color: var(--text-m);
    margin-bottom: 1rem;
    padding-right: 1.8rem;
    position: relative;
    line-height: 1.6;
  }
  .spa-features-list li::before {
    content: "✦";
    position: absolute;
    right: 0;
    top: 2px;
    font-size: 0.9rem;
    color: var(--gold);
  }
  .spa-features-list strong {
    color: var(--navy);
  }

  @media (max-width: 768px) {
    .spa-text-article {
      padding: 2rem 1.25rem;
    }
  }

  /* ══ GIFTS GRID ══ */
  .spa-gifts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 900px) {
    .spa-gifts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 550px) {
    .spa-gifts-grid {
      grid-template-columns: 1fr;
    }
  }

  .spa-gift-card {
    background: var(--white);
    border-radius: 18px;
    padding: 2rem 1.5rem;
    text-align: center;
    box-shadow: 0 6px 24px rgba(8, 4, 126, 0.07);
    border: 1px solid rgba(8, 4, 126, 0.06);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }
  .spa-gift-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(8, 4, 126, 0.13);
  }
  .spa-gift-icon {
    font-size: 2.5rem;
    margin-bottom: 0.8rem;
  }
  .spa-gift-card h3 {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--navy);
    margin: 0 0 0.5rem;
  }
  .spa-gift-card p {
    font-size: 0.95rem;
    color: var(--text-l);
    line-height: 1.6;
    margin: 0;
  }

  /* ══ BREAK IMAGES ══ */
  .spa-break-img-wrapper {
    max-width: 1000px;
    margin: 4rem auto;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 15px 40px rgba(8, 4, 126, 0.15);
  }
  .spa-break-img {
    width: 100%;
    height: auto;
    max-height: 550px;
    object-fit: cover;
    display: block;
    aspect-ratio: 16 / 9;
  }

  @media (max-width: 768px) {
    .spa-break-img-wrapper {
      margin: 2.5rem -1.5rem;
      border-radius: 0;
    }
    .spa-break-img {
      aspect-ratio: 4 / 3;
      max-height: 400px;
    }
  }

  /* ══ PRICING CARDS ══ */
  .spa-pricing-grid {
    display: grid;
