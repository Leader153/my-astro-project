---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import Heroimg from "../assets/louse-hero.png";
import img1 from "../assets/Louse.jpg";
import midImg from "../assets/louse-salon.png";
import botImg from "../assets/louse-hartom.jpg";
import FleetSelectionCta from "../components/FleetSelectionCta.astro";
import PremiumSwitch from "../components/PremiumSwitch.astro";
import "../styles/pricing-card.css";
import YachtVideoCard from "../components/YachtVideoCard.astro";
const isoUploadDate = new Date("2026-03-12").toISOString();
---

<Layout
  title="יאכטה לואיז (עד 6 איש) הרצליה | Leader הפלגות"
  description="השכרת יאכטה בוטיק חמימה לואיז (Louise) במרינה הרצליה לעז 6 איש. החל מ-670 ₪ לשעה. מושלמת לרומנטיקה. כולל שמפניה, בלונים ואבוב."
>
  <div class="service-page" dir="rtl">
    <section class="sp-hero">
      <Image
        src={Heroimg}
        alt="יאכטה לואיז בהרצליה"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg desktop-hero"
      />
      <Image
        src={Heroimg}
        alt="יאכטה לואיז בהרצליה"
        widths={[400, 768]}
        sizes="100vw"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg mobile-hero"
        style="object-position: 50% 50%;"
      />
    </section>

    <section class="sp-content">
      <div class="sp-inner">
        <h1>⚓ יאכטה מפרשית לואיז – LOUISE</h1>
        <p>יאכטה מתוקה ואינטימית, מושלמת להפלגות זוגיות ולקבוצות קטנות.</p>

        <h3>✨ בחירה קלאסית לפעילות בים</h3>
        <p>
          יאכטה מפרשית שנבנתה על ידי יצרנית היאכטות הצרפתית <strong
            >Beneteau</strong
          >, הדגם הוא <strong>Oceanis 331</strong>. אורך היאכטה 33.1 פיט (כ-10.5
          מטר).
        </p>
        <p>
          כמות האנשים המותרת להפלגה היא עד 11 מפליגים מלבד הסקיפר, אך אנחנו
          ממליצים לעלות עליה עד כ-8 אנשים. בתוך היאכטה יש שני חדרי שינה,
          שירותים, מקלחת עם מים חמים, מטבח מאובזר וסלון.
        </p>

        <Image
          src={img1}
          alt="יאכטה לואיז בים"
          class="sp-gallery-img"
          style="aspect-ratio: 3/2; object-fit: cover;"
          format="webp"
        />

        <h3>💎 פינוק ונוחות</h3>
        <p>
          סלון מרווח ומואר המאפשר שהייה נעימה. מושלם לבילוי זוגי או עם חברים
          קרובים. מקום מפנק לחוויה באווירה אחרת.
        </p>

        <Image
          src={midImg}
          alt="סלון יאכטה לואיז"
          class="sp-gallery-img"
          style="aspect-ratio: 3/2; object-fit: cover;"
          format="webp"
        />
        <p class="sp-closing">
          רוצים להפליג? יאכטה לואיז מחכה לכם!<br />
          התקשרו להזמין עכשיו: 053-3403449
        </p>
      </div>
                 <YachtVideoCard
  id="yacht-louise-herzliya"
  videoUrl="https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20240318-WA0009_snrqtj.mp4"
  posterUrl="https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20240318-WA0009_snrqtj.jpg"
  videoName="Yacht Louise Herzliya"
  videoDescription="יאכטה מפרשית עד 6 משתתפים מהרצליה"
  uploadDate={isoUploadDate}
  tagText="הרצליה"
  tagColor="#d4a017"
  icon="⛵"
  title="מחירון יאכטה לואיז"
  note="* מחיר כולל מע&quot;מ, תקף לסוף שבוע"
  whatsappNumber="972533403449"
  ragHint="[מידע לבוט על יאכטה לואיז] שם: יאכטה לואיז. מיקום: הרצליה. קיבולת: עד 6 מפליגים. מחירון מקוצר: שעה 670₪, שעה וחצי 840₪, שעתיים 1,100₪, 3 שעות 1,450₪, שעה נוספת 350₪. המחיר כולל: סקיפר, שתייה מים, שמפניה, בלונים, שלט, מוזיקה, ביטוח. בהפלגה של שעתיים ומעלה: אבוב. כאשר לקוח שואל על יאכטה זו, שלח לו את הקישור הישיר לדף: /yacht-louise. ציין שיש שם וידאו, תמונות ומחירון מלא."
>
  <p><strong>מחירון השכרת יאכטה לואיז:</strong></p>
  <ul class="pricing-list no-bullets">
    <li><strong>שעה הפלגה:</strong> 670 ₪</li>
    <li><strong>שעה וחצי הפלגה:</strong> 840 ₪</li>
    <li><strong>שעתיים הפלגה:</strong> 1,100 ₪</li>
    <li><strong>3 שעות הפלגה:</strong> 1,450 ₪</li>
    <li>כל שעה נוספת: 350 ₪</li>
    <li>👑 עד 6 מפליגים מאושרים (עם סקיפר)</li>
  </ul>

  <h4 class="pricing-title">המחיר כולל:</h4>
  <ul class="pricing-list">
    <li>שלט מזל טוב</li>
    <li>בלונים בתוך היאכטה</li>
    <li>מוזיקה (רמקול בלוטוס)</li>
    <li>שתייה מים</li>
    <li>בקבוק שמפניה 🥂</li>
    <li>ביטוח לכל משתתף</li>
    <li>שירות של סקיפר מקצועי לאורך כל הדרך</li>
  </ul>

  <h4 class="pricing-title">בהזמנה של שעתיים:</h4>
  <ul class="pricing-list">
    <li>ירידה לים עם אבוב 🌊</li>
  </ul>
</YachtVideoCard>
      <PremiumSwitch
        href="/yachts-herzliya"
        title="בחזרה ליאכטות הרצליה"
        subtitle="לצפייה בצי שלנו ולבחירת היאכטה המושלמת"
      />
    </section>
  </div>
  <FleetSelectionCta ctaInstruction="נא להמשיך להזמנה או לצפות בעוד יאכטות:" />

  <!-- Schema.org Data API -->
  <script is:inline type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      name: "יאכטה לואיז הרצליה",
      description:
        "השכרת יאכטה בוטיק לואיז במרינה הרצליה לעד 6 מפליגים. רומנטיקה ויוקרה, כולל בלונים, שמפניה, ואבוב.",
      image: "https://aflagot-haifa.com/seo/seo-Leader-cruise.jpg",
      brand: { "@type": "Brand", name: "Leader שייט & הפלגות" },
      seller: {
        "@type": "TravelAgency",
        "@id": "https://aflagot-haifa.com/",
        name: "Leader שייט & הפלגות",
        legalName: "לידר",
        alternateName: [
          "Leader Haflagot",
          "לידר הפלגות שייט",
          "Leader Yachting",
        ],
        telephone: "+972533403449",
        url: "https://aflagot-haifa.com/",
        sameAs: [
          "https://www.facebook.com/leadership.haifa",
          "https://www.instagram.com/leader.aflagot?igsh=YnAzcThrbDExd2o5",
          "https://www.youtube.com/channel/UCzEOzFcGu8zSeFtFrif4cYw",
        ],
      },
      offers: {
        "@type": "AggregateOffer",
        priceCurrency: "ILS",
        lowPrice: "670",
        highPrice: "1450",
        offerCount: "4",
        offers: [
          {
            "@type": "Offer",
            name: "הפלגה לשעה אחת",
            price: "670",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/yacht-louise",
          },
          {
            "@type": "Offer",
            name: "הפלגה לשעה וחצי",
            price: "840",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/yacht-louise",
          },
          {
            "@type": "Offer",
            name: "הפלגה לשעתיים",
            price: "1100",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/yacht-louise",
          },
          {
            "@type": "Offer",
            name: "הפלגה ל-3 שעות",
            price: "1450",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/yacht-louise",
          },
        ],
      },
       subjectOf: {
        "@type": "VideoObject",
        name: "יאכטה לואיז הרצליה",
        description: "יאכטה מפרשית עד 6 משתתפים מהרצליה",
        thumbnailUrl: "https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20240318-WA0009_snrqtj.jpg",
        contentUrl: "https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20240318-WA0009_snrqtj.mp4",
        uploadDate: isoUploadDate,
        embedUrl: "https://aflagot-haifa.com/yacht-louise",
      },
    })}
  />
</Layout>
