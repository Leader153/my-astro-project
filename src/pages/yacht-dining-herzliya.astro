---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import romanticDinner from "../assets/couple-romantic-dinner-table-yacht.jpeg";
import mobileDinnerI from "../assets/couple-romantic-dinner.jpeg";
import roomImg from "../assets/ארוחת-בוקר-חדשה.jpg";
import salonImg from "../assets/dinner-table-yacht.jpg";
import PremiumSwitch from "../components/PremiumSwitch.astro";
---

<Layout
  title="ארוחה רומנטית על יאכטה בהרצליה: חוויה קולינרית בים"
  description="חולמים על ארוחה רומנטית? ⚓ שייט קולינרי על יאכטה בהרצליה מחכה לכם! אוכל משובח, בריזת ים 🐬 ופינוק מושלם 🥂"
>
  <div class="service-page" dir="rtl">
    <section class="sp-hero">
      <Image
        src={romanticDinner}
        alt="זוג נהנה מארוחה רומנטית על יאכטה בהרצליה"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg desktop-hero"
      />
      <Image
        src={mobileDinnerI}
        alt="זוג נהנה מארוחת ערב רומנטית עשירה על סיפון יאכטה במרינה בחיפה"
        widths={[400, 768]}
        sizes="100vw"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg mobile-hero"
      />
    </section>

    <section class="sp-content">
      <div class="sp-inner">
        <h1>השכרת יאכטה לארוחה רומנטית בהרצליה – <br />חוויה קולינרית בים</h1>
        <p class="sp-service-note">
          (שימו לב: שירות הארוחות המפנק שלנו ניתן כתוספת בלעדית להשכרת היאכטה
          ואינו נמכר בנפרד).
        </p>

        <p>
          <strong>חולמים על ארוחה רומנטית?</strong> דמיינו את הרגע הזה: אתם יושבים
          יחד בירכתי היאכטה של <span class="brand-leader">לידר (Leader)</span>,
          השמש מתחילה לרדת, ואתם נהנים מ<strong>בריזת ים</strong> מלטפת. השולחן מולכם
          ערוך בצורה רומנטית ומוקפדת עם <strong>אוכל משובח</strong>. יין צונן
          כבר נמזג לכוסות שלכם, וברקע מתנגנת הזמרת שאתם הכי אוהבים. הסקיפר האדיב
          והדיסקרטי שלנו מעניק לכם <strong>פינוק מושלם</strong>, מגיש את המנות
          ישירות לסיפון, ואז חוזר לעמדתו ומשאיר אתכם ליהנות מהרגע במסגרת <strong
            >שייט קולינרי</strong
          > בלתי נשכח.
          <strong>רק אתם, הים, והטעמים המשובחים.</strong>
        </p>

        <!-- תמונה 1 -->
        <Image
          src={salonImg}
          alt="סלון מעוצב ומרגיע בתוך יאכטת יוקרה ללינה"
          format="webp"
          width={600}
          height={400}
          loading="lazy"
          class="sp-gallery-img"
        />

        <h2>🍽️ חוויית מסעדת שף פרטית – רק בלי התור והרעש</h2>
        <p>
          ארוחה רומנטית על יאכטה היא חוויה שונה לחלוטין מכל בילוי במסעדה שגרתית.
          למה? כי כאן, כל החוויה מותאמת בדיוק לקצב ולרצונות שלכם. אין מלצרים
          שרצים סביבכם, אין שולחנות צפופים, ואין רעש של סועדים אחרים.
          <strong
            >ב<span class="brand-leader">לידר השכרת יאכטות</span>, הנוחות שלכם
            היא המשימה שלנו.</strong
          >
        </p>
        <p>
          אתם אוכלים בקצב שלכם, נהנים משייט זוגי חווייתי ופרטי לחלוטין. התעייפתם
          מהישיבה ליד השולחן? אין בעיה! פשוט קחו את כוסות היין הצונן והשוקולדים,
          עברו להתפנק על מזרני הזולה והשיזוף בחרטום היאכטה, והתחבקו מול השקיעה
          המרהיבה של מרינה הרצליה או מרינה חיפה.
        </p>

        <!-- תמונה 2 -->
        <Image
          src={roomImg}
          alt="חדר שינה מפנק ויוקרתי בחרטום היאכטה"
          format="webp"
          width={600}
          height={400}
          loading="lazy"
          class="sp-gallery-img"
        />

        <h2>תפריט ארוחות זוגיות ביאכטה</h2>
        <p>
          אנו עובדים עם המסעדות המובילות במרינה כדי להבטיח איכות ללא פשרות. כל
          הארוחות מגיעות טריות וחמות ישירות לסיפון היאכטה!
        </p>
        <p class="sp-small-note">(התפריט עשוי להשתנות מעת לעת בהתאם למסעדות)</p>

        <div class="menu-table-wrap">
          <table class="menu-table">
            <thead>
              <tr>
                <th>סוג הארוחה</th>
                <th>מסעדה</th>
                <th>שעות הגשה</th>
                <th>מחיר לארוחה זוגית</th>
                <th>מה בתפריט?</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>ארוחת בוקר מפנקת</strong></td>
                <td>מרינה ביי</td>
                <td>08:30&nbsp;-&nbsp;16:00</td>
                <td class="price-cell">180 ₪</td>
                <td
                  >שתי ביצים לבחירה לכל סועד, סלט ירקות עשיר, מבחר מטבלים משתנים
                  ולחם כפרי חם וטרי.</td
                >
              </tr>
              <tr>
                <td><strong>ארוחת צהריים / ערב</strong></td>
                <td>דרבי בר</td>
                <td>12:30&nbsp;-&nbsp;23:30</td>
                <td class="price-cell">280 ₪</td>
                <td>
                  <strong>מנה עיקרית לבחירה:</strong> דג פילה דניס / פרגית / שניצל
                  / חזה עוף / פירות ים (מטוגן או בחמאה ושמנת).<br />
                  <strong>תוספות:</strong> סלטי הבית (טחינה, איקרה, תבולה, גזר, כרוב,
                  סלק, דג מלוח, צזיקי, כרובית וחציל מטוגנים), תפוח אדמה אפוי / פירה,
                  ולחם הבית.
                </td>
              </tr>
              <tr>
                <td><strong>קינוח מתוק</strong></td>
                <td>דרבי בר</td>
                <td>12:30&nbsp;-&nbsp;23:30</td>
                <td class="price-cell">55 ₪</td>
                <td>עוגת שוקולד עשירה או עוגת גבינה פירורים נימוחה.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h2>
          ⛵ צי היאכטות של <span class="brand-leader">לידר</span> – לכל מטרה
        </h2>
        <p>
          הארוחות הרומנטיות מתאימות במיוחד לזוגות או קבוצות קטנות ואינטימיות (עד
          6 אנשים). עם זאת, חשוב שתדעו שהצי המפואר שלנו בחיפה ובהרצליה כולל גם
          יאכטות ענק המותאמות לאירוח קבוצות של 21, 30, 40 ואפילו 55 משתתפים, עם
          פתרונות קייטרינג מותאמים אישית לאירועים גדולים, ימי הולדת וימי גיבוש!
        </p>

        <p class="sp-closing">
          רגעים שלא תשכחו לעולם מחכים לכם על סיפון היאכטה.<br />
          הזמינו עכשיו ותיהנו מפינוק קולינרי ורומנטי בלב ים!
        </p>
      </div>
      <!-- Закрываем sp-inner (ИМЕННО ЗДЕСЬ) -->

      <div class="services-grid">
        <a href="/yacht-li-yam" class="service-card" style="--c:#0ea5e9; --i:0">
          <div class="sc-img-wrap">
            <Image
              src={mobileDinnerI}
              width={600}
              height={400}
              format="webp"
              alt="זוג נהנה מארוחת ערב רומנטית עשירה על סיפון יאכטה במרינה בחיפה"
              class="sc-img"
              loading="lazy"
            />
            <div class="sc-tag" style="background:#0ea5e9; color:#fff">
              הרצליה
            </div>
          </div>
          <div class="sc-body">
            <div class="sc-icon">⚓</div>
            <h3>צימר על המים</h3>
            <p>
              <strong>בסיס:</strong> זוגי (אפשרות עד 2 ילדים)<br />
              <strong>מחיר חבילה:</strong> 2,200 ₪<br />
              <strong>כולל:</strong> ארוחת בוקר, בקבוק שמפניה, ולינה יוקרתית ביאכטה.<br
              />
              <span style="font-size: 0.85em; color: #000000;"
                >ניתן לשדרג לשעות נוספות מוקדמות לפני השקיעה</span
              >
            </p>
            <div class="sc-arrow" style="color:#0ea5e9">
              קבלו פרטים
              <svg
                aria-hidden="true"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                width="15"
                height="15"><polyline points="15 18 9 12 15 6"></polyline></svg
              >
            </div>
          </div>
        </a>
      </div>

      <PremiumSwitch
        href="/yachts-herzliya"
        title="היאכטות שלנו בהרצליה"
        subtitle="לצפייה בצי שלנו ולבחירת היאכטה המושלמת"
      />
    </section>
  </div>
</Layout>

<!-- Schema.org Data API -->
<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TouristTrip",
    name: "ארוחה רומנטית על יאכטה בהרצליה",
    description:
      "שייט קולינרי רומנטי על יאכטה פרטית במרינה הרצליה. אוכל משובח מהמסעדות המובילות מוגש ישירות לסיפון.",
    url: "https://aflagot-haifa.com/yacht-dining-herzliya",
    image: "https://aflagot-haifa.com/seo/seo-Leader-cruise.jpg",
    touristType: { "@type": "Audience", audienceType: "זוגות" },
    offers: {
      "@type": "AggregateOffer",
      priceCurrency: "ILS",
      lowPrice: "180",
      highPrice: "280",
      availability: "https://schema.org/InStock",
    },
    provider: {
      "@type": "TravelAgency",
      "@id": "https://aflagot-haifa.com/",
      name: "Leader שייט & הפלגות",
      legalName: "לידר",
      alternateName: ["Leader Haflagot", "לידר הפלגות שייט", "Leader Yachting"],
      url: "https://aflagot-haifa.com/",
      telephone: "+972533403449",
      address: {
        "@type": "PostalAddress",
        streetAddress: "מרינה הרצליה",
        addressLocality: "הרצליה",
        addressCountry: "IL",
      },
      location: [
        {
          "@type": "Place",
          address: {
            "@type": "PostalAddress",
            streetAddress: "מרינה הרצליה",
            addressLocality: "הרצליה",
            addressCountry: "IL",
          },
          geo: {
            "@type": "GeoCoordinates",
            latitude: 32.162443,
            longitude: 34.796172,
          },
        },
        {
          "@type": "Place",
          address: {
            "@type": "PostalAddress",
            streetAddress: "מעגן שביט, פארק קישון",
            addressLocality: "חיפה",
            addressCountry: "IL",
          },
          geo: {
            "@type": "GeoCoordinates",
            latitude: 32.8069075,
            longitude: 35.0322383,
          },
        },
      ],
      sameAs: [
        "https://www.facebook.com/leadership.haifa",
        "https://www.instagram.com/leader.aflagot?igsh=YnAzcThrbDExd2o5",
        "https://www.youtube.com/channel/UCzEOzFcGu8zSeFtFrif4cYw",
      ],
    },
  })}
/>
