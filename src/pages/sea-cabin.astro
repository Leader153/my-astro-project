---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import heroImage from "../assets/original-high-res.png";
import romanticDinnerImg from "../assets/romantic-dinner-couple-cabin-herzelia.jpeg";
import mobileDinnerImg from "../assets/dinner-couple-cabin-herzelia.jpeg";
import roomImg from "../assets/לי-ים-חדר-חרטום.jpg";
import salonImg from "../assets/סלון-ביאכטה.jpeg";
import spaImg from "../assets/Massage-and-dinner-for-couples-on-a-yacht.jpg";
import PremiumSwitch from "../components/PremiumSwitch.astro";
---

<Layout
  title="צימר על הים בהרצליה | Leader הפלגות"
  description="חוויה יוקרתית של לינה ביאכטה פרטית במרינה הרצליה. כל הפינוקים של מלון בוטיק צף כולל מיטה מוצעת ונוף פנורמי."
>
  <div class="service-page" dir="rtl">
    <section class="sp-hero">
      <Image
        src={romanticDinnerImg}
        alt="זוג נהנה מארוחה רומנטית ויין בתוך סיפון יאכטה בהרצליה"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg desktop-hero"
      />
      <Image
        src={mobileDinnerImg}
        alt="זוג נהנה מארוחה רומנטית ויין בתוך סיפון יאכטה בהרצליה"
        widths={[400, 768]}
        sizes="100vw"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg mobile-hero"
      />
    </section>

    <section class="sp-content">
      <!-- Начинается контейнер, ограничивающий ширину контента и картинок (sp-inner) -->
      <div class="sp-inner">
        <h1>⚓ צימר על המים – חופשת בוטיק צפה שטרם הכרתם!</h1>
        <p>
          מחפשים חופשה שונה, מרגשת וייחודית שוברת שגרה? עזבו את בתי המלון
          הסטנדרטיים! "צימר על המים" של <span class="brand-leader"
            >לידר השכרת יאכטות</span
          > מציע לכם את השילוב המושלם: לינה מפנקת ויוקרתית בתוך המרינה בלילה, והפלגת
          בוקר קסומה ומרעננת אל עבר האופק.
        </p>

        <h3>📍 לבחירתכם: מרינה חיפה או מרינה הרצליה</h3>
        <p>
          הצי המפואר של <span class="brand-leader">לידר</span> מחכה לכם בשני הלוקיישנים
          המבוקשים בישראל. בין אם תבחרו בנוף האורבני והתוסס של הרצליה או ברומנטיקה
          של מרינה חיפה למרגלות הכרמל – החוויה תהיה בלתי נשכחת.
        </p>

        <!-- Картинка салона (теперь внутри sp-inner) -->
        <Image
          src={salonImg}
          alt="סלון מעוצב ומרגיע בתוך יאכטת יוקרה ללינה"
          format="webp"
          width={600}
          height={400}
          loading="lazy"
          class="sp-gallery-img"
        />

        <h3>🌙 מה מחכה לכם בחבילה? (לו"ז של פינוק)</h3>
        <ul class="sp-list">
          <li>
            <strong>הגעה אל תוך הלילה:</strong> החוויה מתחילה כחצי שעה לאחר השקיעה.
            נלווה אתכם ליאכטה, תכירו את "הצימר" החדש שלכם ותתכוננו לערב שכולו שקט,
            פרטיות ורומנטיקה.
          </li>
          <li>
            <strong>לינת VIP יוקרתית:</strong> היאכטות שלנו מאובזרות ברמה של חמישה
            כוכבים. תמצאו בהן חדר שינה מרווח ומצעים מלטפים, סלון מעוצב, מקלחת עם מים
            חמים ומוצרי טיפוח מפנקים, ושירותים נקיים.
          </li>
          <li>
            <strong>ארוחת ערב על הסיפון? ברור!</strong> המטבח שלנו מאובזר קומפלט.
            תוכלו להביא איתכם אוכל, לבשל, או אפילו – לעשות בשרים על האש (גריל) ממש
            על סיפון היאכטה! מי צריך מסעדה כשיש לכם את הנוף הכי יפה בארץ?
          </li>
          <li>
            <strong
              >הפינוקים של <span class="brand-leader">"לידר"</span>:</strong
            > כדי שהערב יהיה מושלם, יחכו לכם בקבוק שמפניה צונן, מים מינרליים, בקבוק
            מיץ תפוזים, ומכונת קפה איכותית. היאכטה ממוזגת במלואה, וכוללת מערכת סאונד
            מעולה וטלוויזיה עם נטפליקס לבינג' של לילה.
          </li>
          <li>
            <strong>בוקר של קסם בלב ים:</strong> מתעוררים לקול פכפוך הגלים. בשעה 9:00
            נתניע את המנועים ונצא להפלגת בוקר מדהימה בת שעה וחצי. אל דאגה, אתם לא
            תהיו רעבים – ההפלגה מלווה בארוחת בוקר עשירה ומפנקת המוגשת לכם ישירות לסיפון!
          </li>
        </ul>

        <!-- Картинка комнаты (теперь внутри sp-inner) -->
        <Image
          src={roomImg}
          alt="חדר שינה מפנק ויוקרתי בחרטום היאכטה"
          format="webp"
          width={600}
          height={400}
          loading="lazy"
          class="sp-gallery-img"
        />

        <h3>👨‍👩‍👧‍👦 למי החבילה מתאימה?</h3>
        <p>
          <strong>לזוגות:</strong> המחפשים חוויה רומנטית, אינטימית ומקורית לחגוג אהבה,
          יום נישואין או יום הולדת.
        </p>
        <p>
          <strong>למשפחות:</strong> חוויה מגבשת שהילדים לא ישכחו! (הלינה בצימר מתאימה
          להרכב של זוג + עד 2 ילדים).
        </p>
        <p class="sp-note">
          (הערה: ל<span class="brand-leader">"לידר"</span> יש צי ענק הכולל גם יאכטות
          של 21, 30, 40 ו-55 משתתפים לאירועי יום ענקיים, אך חווית הלינה בצימר שומרת
          על אינטימיות ופרטיות מושלמת).
        </p>

        <h3>💰 מחירון הצימר (תקף למזמינים עד סוף מרץ 2026):</h3>
        <ul class="sp-pricing">
          <li>מחיר חבילת צימר על המים (זוגית): <strong>2,200 ₪</strong></li>
          <li>תוספת לילד (עד 2 ילדים): <strong>200 ₪</strong> לילד</li>
          <li>
            <strong>שדרוג "מקדימים לחגוג":</strong> רוצים להתחיל את החוויה מוקדם יותר?
            בתוספת של <strong>300 ₪</strong> תוכלו לעלות ליאכטה כבר 3 שעות לפני השקיעה!
          </li>
          <li>תוספת סופ"ש (שישי-שבת): <strong>300 ₪</strong></li>
        </ul>

        <p class="sp-closing">
          אל תפספסו את ההזדמנות לחופשה שעוד לא חוויתם. חוויה רומנטית או משפחתית
          מושלמת מחכה לכם ב<span class="brand-leader">לידר השכרת יאכטות</span>.
          הזמינו עכשיו ותיהנו מרגעים שלווים ובלתי נשכחים.
        </p>
      </div>
      <!-- Закрываем sp-inner (ИМЕННО ЗДЕСЬ) -->

      <div class="services-grid">
        <a href="/yacht-li-yam" class="service-card" style="--c:#0ea5e9; --i:0">
          <div class="sc-img-wrap">
            <Image
              src={mobileDinnerImg}
              width={600}
              height={400}
              format="webp"
              alt="צימר על המים"
              class="sc-img"
              loading="lazy"
            />
            <div class="sc-tag" style="background:#0ea5e9; color:#fff">
              הרצליה
            </div>
          </div>
          <div class="sc-body">
            <div class="sc-icon">⚓</div>
            <h3>צימר על המים</h3>
            <p>
              <strong>בסיס:</strong> זוגי (אפשרות עד 2 ילדים)<br />
              <strong>מחיר חבילה:</strong> 2,200 ₪<br />
              <strong>כולל:</strong> ארוחת בוקר, בקבוק שמפניה, ולינה יוקרתית ביאכטה.<br
              />
              <span style="font-size: 0.85em; color: #000000;"
                >ניתן לשדרג לשעות נוספות מוקדמות לפני השקיעה</span
              >
            </p>
            <div class="sc-arrow" style="color:#0ea5e9">
              קבלו פרטים
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                width="15"
                height="15"><polyline points="15 18 9 12 15 6"></polyline></svg
              >
            </div>
          </div>
        </a>
      </div>

      <PremiumSwitch
        href="/yachts-herzliya"
        title="היאכטות שלנו בהרצליה"
        subtitle="לצפייה בצי שלנו ולבחירת היאכטה המושלמת"
      />

      <!-- ═══ FAQ SECTION ═══ -->
      <div class="faq-wrapper">
        <h2 class="faq-title">
          ❓ שאלות ותשובות נפוצות – צימר על המים עם "לידר"
        </h2>

        <div class="accordion">
          <div class="accordion-item">
            <button
              class="accordion-trigger"
              aria-expanded="false"
              aria-controls="faq-a0"
            >
              <span class="q-num">1</span>
              <span class="q-text"
                >האם היאכטה מתנדנדת בלילה? יש סיכוי למחלת ים?</span
              >
              <span class="q-chevron" aria-hidden="true">
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  width="18"
                  height="18"><polyline points="6 9 12 15 18 9"></polyline></svg
                >
              </span>
            </button>
            <div class="accordion-body" id="faq-a0" hidden>
              <div class="accordion-answer">
                <div class="answer-bar"></div>
                <p>
                  ממש לא! במהלך הלילה היאכטה עוגנת בבטחה בתוך המרינה (בחיפה או
                  בהרצליה), במקום שקט, יציב ומוגן מגלים. החוויה שקטה לחלוטין
                  ומרגישה ממש כמו חדר מלון צף. ההפלגה עצמה, שבה נרגיש את תנועת
                  הגלים, מתקיימת רק בבוקר לאחר שמתעוררים.
                </p>
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <button
              class="accordion-trigger"
              aria-expanded="false"
              aria-controls="faq-a1"
            >
              <span class="q-num">2</span>
              <span class="q-text">מה חשוב להביא איתנו ללילה ביאכטה?</span>
              <span class="q-chevron" aria-hidden="true">
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  width="18"
                  height="18"><polyline points="6 9 12 15 18 9"></polyline></svg
                >
              </span>
            </button>
            <div class="accordion-body" id="faq-a1" hidden>
              <div class="accordion-answer">
                <div class="answer-bar"></div>
                <p>
                  בדיוק מה שהייתם מביאים לצימר רגיל או לבית מלון: בגדים נוחים
                  לערב, כלי רחצה אישיים (מברשת שיניים וכו'), בגדי ים להפלגת
                  הבוקר, ואם מתחשק לכם – אוכל ונשנושים שאתם אוהבים. אנחנו בלידר
                  כבר נדאג לכל השאר: מגבות נקיות, מצעים מלטפים, מוצרי טיפוח
                  במקלחת, שמפניה וקפה.
                </p>
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <button
              class="accordion-trigger"
              aria-expanded="false"
              aria-controls="faq-a2"
            >
              <span class="q-num">3</span>
              <span class="q-text"
                >רגע, הבנו שאפשר לעשות "על האש" על היאכטה. זה נכון?</span
              >
              <span class="q-chevron" aria-hidden="true">
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  width="18"
                  height="18"><polyline points="6 9 12 15 18 9"></polyline></svg
                >
              </span>
            </button>
            <div class="accordion-body" id="faq-a2" hidden>
              <div class="accordion-answer">
                <div class="answer-bar"></div>
                <p>
                  בהחלט! זה אחד השדרוגים הכי שווים אצלנו. תוכלו להביא איתכם
                  בשרים, דגים או ירקות, ולצלות אותם על הגריל שלנו באוויר הפתוח
                  מול נוף המרינה המהפנט. המטבח של היאכטה מאובזר ועומד לרשותכם
                  במלואו להכנת ארוחת הערב המושלמת שלכם.
                </p>
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <button
              class="accordion-trigger"
              aria-expanded="false"
              aria-controls="faq-a3"
            >
              <span class="q-num">4</span>
              <span class="q-text">האם יש מקלחת ושירותים נוחים ביאכטה?</span>
              <span class="q-chevron" aria-hidden="true">
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  width="18"
                  height="18"><polyline points="6 9 12 15 18 9"></polyline></svg
                >
              </span>
            </button>
            <div class="accordion-body" id="faq-a3" hidden>
              <div class="accordion-answer">
                <div class="answer-bar"></div>
                <p>
                  ברור! היאכטות של לידר מאובזרות ברמת VIP מתוך מחשבה על הנוחות
                  המקסימלית שלכם. תמצאו בהן שירותים חשמליים נקיים ומקלחת נוחה עם
                  מים חמים, בדיוק כמו בבית.
                </p>
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <button
              class="accordion-trigger"
              aria-expanded="false"
              aria-controls="faq-a4"
            >
              <span class="q-num">5</span>
              <span class="q-text">איך מעבירים את הערב ביאכטה?</span>
              <span class="q-chevron" aria-hidden="true">
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  width="18"
                  height="18"><polyline points="6 9 12 15 18 9"></polyline></svg
                >
              </span>
            </button>
            <div class="accordion-body" id="faq-a4" hidden>
              <div class="accordion-answer">
                <div class="answer-bar"></div>
                <p>
                  מעבר לרומנטיקה, לארוחה הטובה ולכוס השמפניה על הסיפון תחת כיפת
                  השמיים – הדאגנו לכם גם לבידור בפנים! הסלון וחדר השינה ממוזגים,
                  ותמצאו בהם טלוויזיה חכמה עם נטפליקס ומערכת סאונד מעולה
                  (בלוטות'). תוכלו להעביר את הערב בבינג' מפנק מתחת לפוך או פשוט
                  לשמוע את המוזיקה שאתם הכי אוהבים.
                </p>
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <button
              class="accordion-trigger"
              aria-expanded="false"
              aria-controls="faq-a5"
            >
              <span class="q-num">6</span>
              <span class="q-text">מאיפה יוצאים ואיפה מחנים את הרכב?</span>
              <span class="q-chevron" aria-hidden="true">
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  width="18"
                  height="18"><polyline points="6 9 12 15 18 9"></polyline></svg
                >
              </span>
            </button>
            <div class="accordion-body" id="faq-a5" hidden>
              <div class="accordion-answer">
                <div class="answer-bar"></div>
                <p>
                  אנו מציעים את חווית "הצימר על המים" בשני הלוקיישנים המרכזיים
                  שלנו: מרינה הרצליה התוססת ומרינה חיפה הפסטורלית. בשתי המרינות
                  ישנם חניונים מסודרים, בטוחים ונוחים במרחק הליכה קצר מאוד
                  מהרציף הפרטי שלנו.
                </p>
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <button
              class="accordion-trigger"
              aria-expanded="false"
              aria-controls="faq-a6"
            >
              <span class="q-num">7</span>
              <span class="q-text"
                >האם הצימר מתאים גם למשפחות או רק לזוגות?</span
              >
              <span class="q-chevron" aria-hidden="true">
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  width="18"
                  height="18"><polyline points="6 9 12 15 18 9"></polyline></svg
                >
              </span>
            </button>
            <div class="accordion-body" id="faq-a6" hidden>
              <div class="accordion-answer">
                <div class="answer-bar"></div>
                <p>
                  החוויה הקלאסית והמבוקשת ביותר היא חופשה זוגית רומנטית. עם זאת,
                  היאכטות שלנו מרווחות מספיק כדי לארח בנוחות גם זוג + עד 2
                  ילדים, כך שזו יכולה להיות חוויית גיבוש משפחתית בלתי נשכחת
                  ללילה אחד מיוחד!
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <h3
        style="text-align: center; margin-top: 4rem; margin-bottom: 1rem; color: #08047e;"
      >
        בטוח שתתעניינו גם בהצעה הזאת:
      </h3>
      <div class="services-grid" style="margin-top: 0; margin-bottom: 4rem;">
        <a href="/spa" class="service-card" style="--c:#f43f5e; --i:1">
          <div class="sc-img-wrap">
            <Image
              src={spaImg}
              width={600}
              height={400}
              format="webp"
              alt="טיפול ספא מרגיע על סיפון יאכטה אקסקלוסיבית"
              class="sc-img"
              loading="lazy"
            />
            <div class="sc-tag" style="background:#f43f5e; color:#fff">
              פינוק
            </div>
          </div>
          <div class="sc-body">
            <div class="sc-icon">💆‍♀️</div>
            <h3>חבילת ספא על יאכטה</h3>
            <p>
              חוויית פינוק מושלמת הכוללת טיפולי ספא מרגיעים מול נוף הים הפתוח
            </p>
            <div class="sc-arrow" style="color:#f43f5e">
              קבלו פרטים
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                width="15"
                height="15"><polyline points="15 18 9 12 15 6"></polyline></svg
              >
            </div>
          </div>
        </a>
      </div>
    </section>
  </div>
</Layout>

<script>
  document
    .querySelectorAll<HTMLButtonElement>(".accordion-trigger")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        const bodyId = btn.getAttribute("aria-controls")!;
        const body = document.getElementById(bodyId)!;
        const item = btn.closest(".accordion-item")!;

        // close siblings
        btn
          .closest(".accordion")!
          .querySelectorAll<HTMLButtonElement>(".accordion-trigger")
          .forEach((b) => {
            if (b !== btn) {
              b.setAttribute("aria-expanded", "false");
              b.closest(".accordion-item")!.classList.remove("open");
              const sid = b.getAttribute("aria-controls")!;
              const sb = document.getElementById(sid)!;
              sb.hidden = true;
              sb.style.maxHeight = "0";
            }
          });

        if (expanded) {
          btn.setAttribute("aria-expanded", "false");
          item.classList.remove("open");
          body.hidden = true;
          body.style.maxHeight = "0";
        } else {
          btn.setAttribute("aria-expanded", "true");
          item.classList.add("open");
          body.hidden = false;
          body.style.maxHeight = body.scrollHeight + "px";
        }
      });
    });
</script>
