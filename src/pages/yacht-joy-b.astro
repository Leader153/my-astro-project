---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import Heroimg from "../assets/Joy-Be-Yacht.jpeg";
import img1 from "../assets/Joy-right-side.jpeg";
import midImg from "../assets/JoyBeDeck.jpg";
import botImg from "../assets/kokpit.jpg";
import FleetSelectionCta from "../components/FleetSelectionCta.astro";
import PremiumSwitch from "../components/PremiumSwitch.astro";
import YachtVideoCard from "../components/YachtVideoCard.astro";
const isoUploadDate = new Date("2026-03-12").toISOString();
import "../styles/pricing-card.css";

---

<Layout
  title="יאכטה ג'וי בי (עד 13 איש) הרצליה | Leader הפלגות"
  description="השכרת יאכטה ג'וי בי (Joy B) מרווחת ומפנקת במרינה הרצליה לעד 13 איש. החל מ-910 ₪ לשעה. מושלמת למשפחות וחגיגות. כולל סקיפר מקצועי, מוזיקה ובלונים."
>
  <div class="service-page" dir="rtl">
    <section class="sp-hero">
      <Image
        src={Heroimg}
        alt="יאכטה ג'וי בי בהרצליה"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg desktop-hero"
      />
      <Image
        src={Heroimg}
        alt="יאכטה ג'וי בי בהרצליה"
        widths={[400, 768]}
        sizes="100vw"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg mobile-hero"
        style="object-position: 50% 50%;"
      />
    </section>

    <section class="sp-content">
      <div class="sp-inner">
        <h1>⚓ יאכטה מפרשית (LIRI) גוי-בי joy-B</h1>
        <p>
          יאכטה קלאסית ומפנקת עד 13 מפליגים, מושלמת למסיבות יום הולדת, משפחות,
          ושייט איכותי במי הים התיכון.
        </p>

        <h3>✨ בחירה קלאסית לפעילות בים</h3>
        <p>
          יאכטה ג'וי בי (Joy B) היא הבחירה הקלאסית והבולטת לפעילות בים למשפחות
          וקבוצות של עד 13 אנשים. עם סיפון קדמי להשתזפות, סלון יוקרתי, מערכת
          סאונד טובה ואווירה קסומה - מובטחת לכם הפלגת חלומות שיש בה הכל. סקיפר
          מקצועי שלנו יידאג להשיט אתכם מול חופי הרצליה ותל אביב מתוך פסטורליה
          מלאה ונוחות עילאית.
        </p>
        <p>
          היא יאכטה מפרשית שהגיעה לישראל בהפלגה. שם הדגם <strong
            >Bavaria Cruiser 41</strong
          >.<br />
          אורך היאכטה 40.5 פיט (כ-12 מטר).<br />
          בתוך היאכטה יש שלושה חדרי שינה, שירותים, מקלחת, מטבח מאובזר וסלון.
        </p>
        <p>
          על הסיפון יש איזור ישיבה סביב שולחן, בחלקה האחורי של היאכטה (ירכתיים)
          ומזרון שיזוף בחרטום. היאכטה מצויידת במזגן, שירותים חשמליים, מערכת
          סאונד טובה עם רמקולים על הסיפון ובתוך בסלון היאכטה, ניתן להתחבר למערכת
          הסאונד עם כל נגן חיצוני (טלפונים, מחשב…).
        </p>

        <Image
          src={img1}
          alt="יאכטה ג'וי בי מהצד"
          class="sp-gallery-img is-square"
          format="webp"
        />

        <h3>💎 עיצוב וחוויה ייחודית</h3>
        <p>
          יאכטה לירי היא בנויה בסגנון ייחודי, כפי שאפשר לראות בתמונות, המתבטא
          בעיצוב פנים מריהוט עץ. העיצוב מעניק חמימות וביתיות, מבנה הגוף מעניק
          לספינה מראה ותחושה נעימה בהפלגה.
        </p>

        <Image
          src={midImg}
          alt="סיפון יאכטה ג'וי בי"
          class="sp-gallery-img is-square"
          format="webp"
        />

        <h3>⭐ מה מיוחד ביאכטה ג'וי בי?</h3>
        <p>
          יאכטה ג'וי בי נבנתה במיוחד להפלגות של מספר ימים, אזור ה-cockpit (אזור
          הישיבה) רחב ונוח, בעלת ירידה נוחה לירידה למים. מצוידת במקלחת סיפון עם
          מים חמים. יאכטה מפנקת במיוחד לאורחים שלנו.
        </p>

        <Image
          src={botImg}
          alt="קוקפיט יאכטה ג'וי בי"
          class="sp-gallery-img is-square"
          format="webp"
        />

        <p class="sp-closing">
          רוצים להפליג? יאכטה ג'וי בי מחכה לכם!<br />
          התקשרו להזמין עכשיו: 053-3403449
        </p>
      </div>
<YachtVideoCard
  id="yacht-joy-b-herzliya"
  videoUrl="https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20240318-WA0007_1_gexpta.mp4"
  posterUrl="https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20240318-WA0007_1_gexpta.jpg"
  videoName="Yacht JoyBe Herzliya"
  videoDescription="יאכטה מפרשית עד 13 משתתפים מהרצליה"
  uploadDate={isoUploadDate}
  tagText="הרצליה"
  tagColor="#d4a017"
  icon="⛵"
  title="מחירון יאכטה ג'וי בי"
  note="* מחיר כולל מע&quot;מ, תקף לסוף שבוע"
  whatsappNumber="972533403449"
  ragHint="[מידע לבוט על יאכטה ג'וי בי] שם: יאכטה ג'וי בי. מיקום: הרצליה. קיבולת: עד 13 מפליגים. מחירון מקוצר: שעה 910₪, שעתיים 1,350₪, 3 שעות 1,860₪. המחיר כולל: סקיפר, שתיה, שמפניה, ביטוח, אבוב (בהפלגה של שעתיים ומעלה). כאשר לקוח שואל על יאכטה זו, שלח לו את הקישור הישיר לדף: /yacht-joy-b. ציין שיש שם וידאו, תמונות ומחירון מלא."
>
  <p><strong>מחירון השכרת יאכטה ג&#39;וי בי:</strong></p>
  <ul class="pricing-list no-bullets">
    <li><strong>שעה הפלגה:</strong> 910 ₪</li>
    <li><strong>שעה וחצי הפלגה:</strong> 1,090 ₪</li>
    <li><strong>שעתיים הפלגה:</strong> 1,350 ₪</li>
    <li><strong>3 שעות הפלגה:</strong> 1,860 ₪</li>
    <li>כל שעה נוספת: 510 ₪</li>
    <li>👑 עד 13 מפליגים מאושרים (עם סקיפר)</li>
  </ul>

  <h4 class="pricing-title">המחיר כולל:</h4>
  <ul class="pricing-list">
    <li>שלט מזל טוב</li>
    <li>בלונים בתוך היאכטה</li>
    <li>מוזיקה (רמקול בלוטוס)</li>
    <li>שתייה מים</li>
    <li>בקבוק שמפניה 🥂</li>
    <li>ביטוח לכל משתתף</li>
    <li>שירות של סקיפר מקצועי לאורך כל הדרך</li>
  </ul>

  <h4 class="pricing-title">בהזמנה של שעתיים:</h4>
  <ul class="pricing-list">
    <li>ירידה לים עם אבוב 🌊</li>
  </ul>
</YachtVideoCard>

      <PremiumSwitch
        href="/yachts-herzliya"
        title="בחזרה ליאכטות הרצליה"
        subtitle="לצפייה בצי שלנו ולבחירת היאכטה המושלמת"
      />
    </section>
  </div>
  <FleetSelectionCta ctaInstruction="נא להמשיך להזמנה או לצפות בעוד יאכטות:" />

  <!-- Schema.org Data API -->
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      name: "יאכטה ג'וי בי הרצליה",
      description:
        "השכרת יאכטה מפרשית ג'וי בי במרינה הרצליה לעד 13 מפליגים. כוללת צוות מקצועי, בלונים, מוזיקה וירידה לאבוב.",
      image: "https://aflagot-haifa.com/seo/seo-Leader-cruise.jpg",

      // Блок 1: Общий рейтинг (звездочки в Google)
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: "4.9",
        reviewCount: "34"
      },

      // Блок 2: Текстовые отзывы клиентов
      review: [
        {
          "@type": "Review",
          author: {
            "@type": "Person",
            name: "ישראל כהן" // Имя клиента 1
          },
          datePublished: "2025-08-15",
          reviewRating: {
