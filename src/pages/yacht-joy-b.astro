        ],
      },
      subjectOf: {
        "@type": "VideoObject",
        name: "יאכטה ג'וי בי הרצליה",
        description: "יאכטה מפרשית עד 13 משתתפים מהרצליה",
        thumbnailUrl: "https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20240318-WA0007_1_gexpta.jpg",
        contentUrl: "https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20240318-WA0007_1_gexpta.mp4",
        uploadDate: isoUploadDate,
        embedUrl: "https://aflagot-haifa.com/yacht-joy-b",
      },
    })}
  />
</Layout>
