---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import Heroimg from "../assets/Marga-bot.png";
import img1 from "../assets/margafish.png";
import FleetSelectionCta from "../components/FleetSelectionCta.astro";
import PremiumSwitch from "../components/PremiumSwitch.astro";
import YachtVideoCard from "../components/YachtVideoCard.astro";
const isoUploadDate = new Date("2026-03-12").toISOString();
import "../styles/pricing-card.css";
---

<Layout
  title="סירת מנוע מרגע (עד 6 איש): אקסטרים בחיפה | Leader הפלגות"
  description="השכרת סירת מנוע מהירה במפרץ חיפה לעד 6 מפליגים. החל מ-1,290 ₪ לשעה. מושלם לחובבי אדרנלין ואקסטרים. כולל מוזיקה, סקיפר, וירידה לאבוב בהזמנת שעתיים."
>
  <div class="service-page" dir="rtl">
    <section class="sp-hero">
      <Image
        src={Heroimg}
        alt="סירת מנוע מרגע חיפה"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg desktop-hero"
      />
      <Image
        src={Heroimg}
        alt="סירת מנוע מרגע חיפה"
        widths={[400, 768]}
        sizes="100vw"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg mobile-hero"
        style="object-position: 50% 50%;"
      />
    </section>

    <section class="sp-content">
      <div class="sp-inner">
        <h1>השכרת סירת מנוע אקסטרים בחיפה – סירת מרגע עד 6 איש</h1>
        <p>
          קבוצה קטנה ומהירה חובבת אקסטרים? עד 6 איש על סירת מנוע לבילוי חותך
          גלים מסחרר במימי חיפה.
        </p>

        <h2>🌊 אדרנלין ומהירות ללא פשרות</h2>
        <p>
          סירת המנוע שלנו ("מרגע" - מיראז') נבנתה למי שלא אוהב לשבת במקום ורוצה
          להרגיש את הים במלוא העוצמה! אידיאלית עד ל-6 חברים קרובים שמחפשים
          הרפתקת אקסטרים ספורטיבית. הטיסה מעל הגלים, השפריצים הקרים של המים
          והסיבובים המהירים עם סקיפר מנוסה שעושה שמח בלב. יציאה מחיפה לטירוף של
          מהירות ואדרנלין פתוח.
        </p>

        <h2>🎣 סירת דייג בחיפה</h2>
        <p>
          בנוסף למהירות אקסטרים, הסירה מרווחת, נוחה, ומושלמת לחוויית דיג מקצועית
          או למתחילים במימי מפרץ חיפה! בואו עם החכות שלכם, ואנחנו ניקח אתכם
          לנקודות הטובות ביותר בלב ים.
        </p>

        <Image
          src={img1}
          alt="סירת דייג במפרץ חיפה"
          class="sp-gallery-img is-square"
          format="webp"
        />

        <p class="sp-closing">
          מוכנים לאקסטרים? סירת מרגע מחכה לכם!<br />
          התקשרו להזמין עכשיו: 053-3403449
        </p>
      </div>

      <YachtVideoCard
        id="motorboat-marga-haifa"
        videoUrl="https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20251031-WA0004_zbfyvz.mp4"
        posterUrl="https://res.cloudinary.com/dmbdadurw/video/upload/so_1,f_auto,q_auto/VID-20251031-WA0004_zbfyvz.jpg"
        videoName="Motorboat Marga Haifa"
        videoDescription="סירת מנוע מהירה מרגע עד 6 משתתפים מחיפה"
        uploadDate={isoUploadDate}
        tagText="חיפה"
        tagColor="#d4a017"
        icon="🚤"
        title="מחירון סירת מרגע"
        note='* מחיר כולל מע"מ, תקף לסוף שבוע'
        whatsappNumber="972533403449"
        width="450"
        height="800"
        muted="true"
        ragHint="[מידע לבוט על סירת מנוע מרגע] שם: סירת מרגע (מיראז'). מיקום: חיפה. סוג: סירת מנוע אקסטרים / סירת דייג. קיבולת: עד 6 מפליגים. מחירון מקוצר: שעה 1,290₪, שעתיים 1,390₪, 3 שעות 1,890₪, שעה נוספת 990₪. המחיר כולל: סקיפר מקצועי, מוזיקה (בלוטוס), שתייה מים, ביטוח. בהפלגה של שעתיים ומעלה: ירידה לים עם אבוב. מתאים לחובבי אקסטרים, מהירות ודייג (ניתן להביא חכות). כאשר לקוח שואל על סירה זו, שלח לו את הקישור הישיר לדף: /motorboat-6. ציין שיש שם וידאו, תמונות ומחירון מלא."
      >
        <p><strong>מחירון השכרת סירת אקסטרים:</strong></p>
        <ul class="pricing-list no-bullets">
          <li><strong>שעה הפלגה:</strong> 1,290 ₪</li>
          <li><strong>שעתיים הפלגה:</strong> 1,390 ₪</li>
          <li><strong>3 שעות הפלגה:</strong> 1,890 ₪</li>
          <li>כל שעה נוספת: 990 ₪</li>
          <li>👑 מתאים לעד 6 מפליגים</li>
        </ul>

        <h4 class="pricing-title">המחיר כולל:</h4>
        <ul class="pricing-list">
          <li>מוזיקה (רמקול בלוטוס)</li>
          <li>שתייה מים</li>
          <li>ביטוח לכל משתתף</li>
          <li>שירות של סקיפר מקצועי לאורך כל הדרך</li>
        </ul>

        <h4 class="pricing-title">בהזמנה של שעתיים:</h4>
        <ul class="pricing-list">
          <li>ירידה לים עם אבוב 🌊</li>
        </ul>
      </YachtVideoCard>

      <PremiumSwitch
        href="/haifa"
        title="בחזרה להפלגות חיפה"
        subtitle="לצפייה בצי שלנו ולבחירת סירה או יאכטה נוספת"
      />
    </section>
  </div>
  <FleetSelectionCta
    ctaInstruction="נא להמשיך להזמנה או לצפות בעוד סירות בחיפה:"
  />

  <!-- Schema.org Data API -->
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      name: "סירת מנוע מרגע חיפה",
      description:
        "השכרת סירת מנוע מהירה באקסטרים במפרץ חיפה עד 6 מפליגים, כולל סקיפר מקצועי, מוזיקה וירידה לאבוב.",
      image: "https://aflagot-haifa.com/seo/seo-Leader-cruise.jpg",
      brand: { "@type": "Brand", name: "Leader שייט & הפלגות" },
      seller: {
        "@type": "TravelAgency",
        "@id": "https://aflagot-haifa.com/",
        name: "Leader שייט & הפלגות",
        legalName: "לידר",
        alternateName: [
          "Leader Haflagot",
          "לידר הפלגות שייט",
          "Leader Yachting",
        ],
        telephone: "+972533403449",
        url: "https://aflagot-haifa.com/",
        location: [
          {
            "@type": "Place",
            address: {
              "@type": "PostalAddress",
              streetAddress: "מרינה הרצליה",
              addressLocality: "הרצליה",
              addressCountry: "IL",
            },
            geo: {
              "@type": "GeoCoordinates",
              latitude: 32.162443,
              longitude: 34.796172,
            },
          },
          {
            "@type": "Place",
            address: {
              "@type": "PostalAddress",
              streetAddress: "מעגן שביט, פארק קישון",
              addressLocality: "חיפה",
              addressCountry: "IL",
            },
            geo: {
              "@type": "GeoCoordinates",
              latitude: 32.8069075,
              longitude: 35.0322383,
            },
          },
        ],
        sameAs: [
          "https://www.facebook.com/leadership.haifa",
          "https://www.instagram.com/leader.aflagot?igsh=YnAzcThrbDExd2o5",
          "https://www.youtube.com/channel/UCzEOzFcGu8zSeFtFrif4cYw",
        ],
      },
      offers: {
        "@type": "AggregateOffer",
        priceCurrency: "ILS",
        lowPrice: "1290",
        highPrice: "1890",
        offerCount: "3",
        offers: [
          {
            "@type": "Offer",
            name: "הפלגה לשעה אחת",
            price: "1290",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/motorboat-6",
          },
          {
            "@type": "Offer",
            name: "הפלגה לשעתיים",
            price: "1390",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/motorboat-6",
          },
          {
            "@type": "Offer",
            name: "הפלגה ל-3 שעות",
            price: "1890",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/motorboat-6",
          },
        ],
      },
      subjectOf: {
        "@type": "VideoObject",
        name: "סירת מנוע מרגע חיפה",
        description: "סירת מנוע מהירה באקסטרים במפרץ חיפה עד 6 מפליגים",
        thumbnailUrl:
          "https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20251031-WA0004_zbfyvz.jpg",
        contentUrl:
          "https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20251031-WA0004_zbfyvz.mp4",
        uploadDate: isoUploadDate,
        embedUrl: "https://aflagot-haifa.com/motorboat-6",
      },
    })}
  />
</Layout>
