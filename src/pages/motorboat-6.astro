---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import Heroimg from "../assets/Marga-bot.png";
import img1 from "../assets/margafish.png";
import FleetSelectionCta from "../components/FleetSelectionCta.astro";
import PremiumSwitch from "../components/PremiumSwitch.astro";
import "../styles/pricing-card.css";
---

<Layout
  title="סירת מנוע מרגע (עד 6 איש): אקסטרים בחיפה | Leader הפלגות"
  description="השכרת סירת מנוע מהירה במפרץ חיפה לעד 6 מפליגים. החל מ-1,290 ₪ לשעה. מושלם לחובבי אדרנלין ואקסטרים. כולל מוזיקה, סקיפר, וירידה לאבוב בהזמנת שעתיים."
>
  <div class="service-page" dir="rtl">
    <section class="sp-hero">
      <Image
        src={Heroimg}
        alt="סירת מנוע מרגע חיפה"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg desktop-hero"
      />
      <Image
        src={Heroimg}
        alt="סירת מנוע מרגע חיפה"
        widths={[400, 768]}
        sizes="100vw"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg mobile-hero"
        style="object-position: 50% 50%;"
      />
    </section>

    <section class="sp-content">
      <div class="sp-inner">
        <h1>סירת מנוע מרגע</h1>
        <p>
          קבוצה קטנה ומהירה חובבת אקסטרים? עד 6 איש על סירת מנוע לבילוי חותך
          גלים מסחרר במימי חיפה.
        </p>

        <h3>🌊 אדרנלין ומהירות ללא פשרות</h3>
        <p>
          סירת המנוע שלנו ("מרגע" - מיראז') נבנתה למי שלא אוהב לשבת במקום ורוצה
          להרגיש את הים במלוא העוצמה! אידיאלית עד ל-6 חברים קרובים שמחפשים
          הרפתקת אקסטרים ספורטיבית. הטיסה מעל הגלים, השפריצים הקרים של המים
          והסיבובים המהירים עם סקיפר מנוסה שעושה שמח בלב. יציאה מחיפה לטירוף של
          מהירות ואדרנלין פתוח.
        </p>

        <h3>🎣 סירת דייג בחיפה</h3>
        <p>
          בנוסף למהירות אקסטרים, הסירה מרווחת, נוחה, ומושלמת לחוויית דיג מקצועית
          או למתחילים במימי מפרץ חיפה! בואו עם החכות שלכם, ואנחנו ניקח אתכם
          לנקודות הטובות ביותר בלב ים.
        </p>

        <Image
          src={img1}
          alt="סירת דייג במפרץ חיפה"
          class="sp-gallery-img is-square"
          format="webp"
        />

        <p class="sp-closing">
          מוכנים לאקסטרים? סירת מרגע מחכה לכם!<br />
          התקשרו להזמין עכשיו: 053-3403449
        </p>
      </div>

      <div class="services-grid">
        <a
          href="https://wa.me/972533403449"
          class="service-card"
          style="--c:#d4a017; --i:0"
          target="_blank"
        >
          <div class="sc-img-wrap">
            <Image
              src={Heroimg}
              width={600}
              height={400}
              format="webp"
              alt="סירת מרגע"
              class="sc-img"
              loading="lazy"
              style="object-position: center;"
            />
            <div class="sc-tag" style="background:#d4a017; color:#fff">
              חיפה
            </div>
          </div>
          <div class="sc-body">
            <div class="sc-icon">🚤</div>
            <h3>סירת מרגע אקסטרים למנוע</h3>
            <p><strong>מחירון השכרת סירת אקסטרים:</strong></p>
            <ul class="pricing-list no-bullets">
              <li><strong>שעה הפלגה:</strong> 1,290 ₪</li>
              <li><strong>שעתיים הפלגה:</strong> 1,390 ₪</li>
              <li><strong>3 שעות הפלגה:</strong> 1,890 ₪</li>
              <li>כל שעה נוספת: 990 ₪</li>
              <li>👑 מתאים לעד 6 מפליגים</li>
            </ul>

            <h4 class="pricing-title">המחיר כולל:</h4>
            <ul class="pricing-list">
              <li>מוזיקה (רמקול בלוטוס)</li>
              <li>שתייה מים</li>
              <li>ביטוח לכל משתתף</li>
              <li>שירות של סקיפר מקצועי לאורך כל הדרך</li>
            </ul>

            <h4 class="pricing-title">בהזמנה של שעתיים:</h4>
            <ul class="pricing-list">
              <li>ירידה לים עם אבוב 🌊</li>
            </ul>

            <p class="pricing-note">* מחיר כולל מע"מ, תקף לסוף שבוע</p>
            <div class="sc-arrow" style="color:#d4a017">
              להזמנה בוואטסאפ
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                width="15"
                height="15"><polyline points="15 18 9 12 15 6"></polyline></svg
              >
            </div>
          </div>
        </a>
      </div>

      <PremiumSwitch
        href="/haifa"
        title="בחזרה להפלגות חיפה"
        subtitle="לצפייה בצי שלנו ולבחירת סירה או יאכטה נוספת"
      />
    </section>
  </div>
  <FleetSelectionCta
    ctaInstruction="נא להמשיך להזמנה או לצפות בעוד סירות בחיפה:"
  />

  <!-- Schema.org Data API -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      name: "סירת מנוע מרגע חיפה",
      description:
        "השכרת סירת מנוע מהירה באקסטרים במפרץ חיפה עד 6 מפליגים, כולל סקיפר מקצועי, מוזיקה וירידה לאבוב.",
      brand: { "@type": "Brand", name: "Leader הפלגות" },
      offers: {
        "@type": "AggregateOffer",
        priceCurrency: "ILS",
        lowPrice: "1290",
        highPrice: "1890",
        offerCount: "3",
        offers: [
          {
            "@type": "Offer",
            name: "הפלגה לשעה אחת",
            price: "1290",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/motorboat-6",
          },
          {
            "@type": "Offer",
            name: "הפלגה לשעתיים",
            price: "1390",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/motorboat-6",
          },
          {
            "@type": "Offer",
            name: "הפלגה ל-3 שעות",
            price: "1890",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/motorboat-6",
          },
        ],
      },
    })}
  />
</Layout>
