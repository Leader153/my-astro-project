---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import heroImage from "../assets/king.png";
import img1 from "../assets/king-yacht-Dolfin.png";
import midImg2 from "../assets/king.png";
import FleetSelectionCta from "../components/FleetSelectionCta.astro";
import PremiumSwitch from "../components/PremiumSwitch.astro";
import "../styles/pricing-card.css";
---

<Layout
  title="ספינת קינג (עד 40 איש): יאכטה לאירועים בחיפה | Leader הפלגות"
  description="השכרת ספינת קינג במפרץ חיפה לאירועים ומסיבות ענק עד 40 מפליגים. החל מ-1,990 ₪ לשעה. אוכל, מוזיקה, מנגל וצוות מקצועי לחוויה מושלמת."
>
  <div class="service-page" dir="rtl">
    <section class="sp-hero">
      <Image
        src={heroImage}
        alt="ספינת קינג בחיפה"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg desktop-hero"
      />
      <Image
        src={heroImage}
        alt="ספינת קינג בחיפה"
        widths={[400, 768]}
        sizes="100vw"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg mobile-hero"
        style="object-position: 80% 0%;"
      />
    </section>

    <section class="sp-content">
      <div class="sp-inner">
        <h1>⚓ ספינת קינג – יאכטה לאירועים בחיפה עד 40 מפליגים</h1>
        <p>
          מסיבות, ימי הולדת, ימי גיבוש ואירועים פרטיים<br />
          שייט חוויתי 🐬 עם רחבת ריקודים, מנגל ופינוק מושלם 🥂
        </p>

        <h3>🎉 חוגגים אירוע? הקינג הוא הבמה שלכם!</h3>
        <p>
          מחפשים אירוע שאף אחד לא ישכח? <strong>ספינת קינג בחיפה</strong> היא הבחירה
          המושלמת לכל מי שרוצה לחגוג בסטייל בלב ים. יום הולדת, מסיבת רווקות, יום גיבוש
          קבוצתי או כל אירוע פרטי – אצלנו כל רגע הופך לחוויה שתישאר בזיכרון לתמיד.
        </p>
        <p>
          <strong>ספינת קינג</strong> מכילה <strong>עד 40 מפליגים</strong> ומציעה
          שייט חוויתי לאורך מפרץ חיפה. רחבת ריקודים, מנגל פחמים, מוזיקה, ים – כל מה
          שצריך לאירוע מושלם כבר על הסיפון. פנקו את האורחים שלכם כמו שמגיע להם!
        </p>

        <Image
          src={img1}
          alt="מסיבה על ספינת קינג בחיפה"
          class="sp-gallery-img"
          style="aspect-ratio: 3/2;"
          format="webp"
        />

        <h3>🚢 על הסיפון – מרחב פינוק מושלם לאירוע</h3>
        <p>
          <strong>ספינת קינג</strong> מחולקת למספר אזורים שתוכננו במיוחד כדי לשדרג
          כל אירוע: מטבחון, מקרר, כיור, שירותים, חדר עם מיטה, מנוע עוצמתי וכמובן הגה
          אמיתי של ספינה!
        </p>
        <ul class="sp-list">
          <li>
            <strong>אזור החרטום (קדימה):</strong> 6 מושבים נוחים במרחב מבודד ושקט.
            המקום המושלם לצילומים דרמטיים מול הגלים ולרגעים אינטימיים בלב ים.
          </li>
          <li>
            <strong>רחבת הריקודים ואזור הבילוי:</strong> שולחן ענק, מושבים נוחים וגג
            צל על כל האזור – עם מקרר, <strong>מנגל פחמים</strong> ורחבה ענקית לרקוד,
            לשמוח ולחגוג כמו שצריך!
          </li>
          <li>
            <strong>אזור ירכתיים וצוות:</strong> הצוות המקצועי שלנו מנהל את ההשטה
            הבטוחה כך שאתם מתפנים רק ליהנות.
          </li>
        </ul>

        <h3>אוכל ושתיה – פינוק מושלם על הסיפון!</h3>
        <p>
          <strong>מביאים אוכל ושתיה מהבית?</strong> בכיף! ללא תוספת מחיר. הביאו בשרים
          ופחמים ואנחנו נבשל לכם על המנגל – התפנו ליהנות מהשייט החוויתי בזמן שהריח
          הנהדר עולה מהאש.
        </p>
        <p>
          <strong>מעדיפים שנארגן הכל?</strong> תגידו מה אתם אוהבים ונדאג לתפריט מפנק
          בהתאם לאירוע. מנות יפות, פינוקים ומשקאות – הכל מסודר עבורכם.
        </p>

        <Image
          src={midImg2}
          alt="צוות הספינה"
          class="sp-gallery-img"
          style="aspect-ratio: 3/2;"
          format="webp"
        />

        <h3>⚓ שייט חוויתי לאורך מפרץ חיפה</h3>
        <p>
          השייט מתבצע לאורך <strong>מפרץ חיפה</strong> הציורי – נוף עוצר נשימה לכל
          עבר, עם עגינה מרגיעה ב<strong>מפרץ פולינום</strong>, במרחק של כ-35
          דקות שייט מנקודת היציאה (פארק קישון). חוויה שאסור לפספס!
        </p>

        <h3>קפיצה לים – בונוס לאירוע!</h3>
        <p>
          רוצים לשדרג את האירוע? יש לנו סולם לירידה למים ומקפצה! בתנאי ים
          מתאימים, הקבוצה יכולה להיכנס למים ולהפוך את האירוע לחוויה מושלמת
          לחלוטין.
        </p>
        <ul class="sp-list">
          <li>הרחצה על אחריות המתרחצים בלבד.</li>
          <li>הירידה למים מותנית באישור הסקיפר.</li>
          <li>הכניסה למים רק לאנשים שיודעים לשחות.</li>
        </ul>

        <h3>👨‍✈️ הצוות המקצועי שלנו</h3>
        <p>
          2–3 אנשי צוות מנוסים – מלחים שיודעים לפנק ולתת שירות מחייך, וסקיפרים
          מורשים שמבטיחים שייט בטוח ומהנה. הצוות אינו נכלל בספירת 40 המפליגים,
          כך שכל 40 המקומות הם שלכם!
        </p>

        <h3>💰 מחירון ספינת קינג:</h3>
        <ul class="sp-list">
          <li><strong>שעה 1:</strong> 1,990 ₪</li>
          <li><strong>שעתיים:</strong> 3,290 ₪</li>
          <li><strong>3 שעות:</strong> 4,400 ₪</li>
          <li><strong>כל שעה נוספת:</strong> 990 ₪</li>
        </ul>

        <p class="sp-closing">
          חוגגים אירוע? ספינת קינג מחכה לכם!<br />
          התקשרו להזמין עכשיו: 053-3403449 (דניאל)
        </p>
      </div>

      <div class="services-grid">
        <a
          href="/yacht-king-40"
          class="service-card"
          style="--c:#0ea5e9; --i:0"
        >
          <div class="sc-img-wrap">
            <Image
              src={heroImage}
              width={600}
              height={400}
              format="webp"
              alt="ספינת קינג בחיפה"
              class="sc-img"
              loading="lazy"
              style="object-position: right;"
            />
            <div class="sc-tag" style="background:#0ea5e9; color:#fff">
              חיפה
            </div>
          </div>
          <div class="sc-body">
            <div class="sc-icon">🚢</div>
            <h3>ספינת קינג</h3>
            <p><strong>מחירון השכרת קינג:</strong></p>
            <ul class="pricing-list no-bullets">
              <li><strong>שעה הפלגה:</strong> 1,990 ₪</li>
              <li><strong>שעתיים הפלגה:</strong> 3,290 ₪</li>
              <li><strong>3 שעות הפלגה:</strong> 4,400 ₪</li>
              <li>כל שעה נוספת: 990 ₪</li>
              <li>👑 מתאים לעד 40 מפליגים</li>
            </ul>

            <h4 class="pricing-title">המחיר כולל:</h4>
            <ul class="pricing-list">
              <li>צוות מקצועי ומסור (מלחים וסקיפר)</li>
              <li>רחבת ריקודים ומערכת שמע</li>
              <li>אפשרות להביא אוכל, בשרים ושתייה ולצלות על המנגל</li>
            </ul>

            <h4 class="pricing-title">בהזמנה של 3 שעות:</h4>
            <ul class="pricing-list">
              <li>שירות גרילמן (על האש) ללא תוספת תשלום! 🍖</li>
            </ul>

            <p class="pricing-note">
              * כל המחירים הם לספינה במלואה<br />
              * המחיר לא כולל בקבוק שמפניה<br />
              * מחיר כולל מע"מ, תקף לסוף שבוע
            </p>
            <div class="sc-arrow" style="color:#25D366">
              להזמנה בוואטסאפ
              <svg
                aria-hidden="true"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                width="15"
                height="15"><polyline points="15 18 9 12 15 6"></polyline></svg
              >
            </div>
          </div>
        </a>
      </div>

      <PremiumSwitch
        href="/haifa"
        title="רוצים להזמין את ספינת הקינג?"
        subtitle="לחצו לעמוד צפה בצי היאכטות בחיפה"
      />
    </section>
  </div>
  <FleetSelectionCta
    ctaInstruction="נא להיכנס לעמוד יאכטות ולתאם את ההפלגה שלכם:"
  />

  <!-- Schema.org Data API -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      name: "ספינת קינג הפלגה בחיפה",
      description:
        "השכרת ספינת קינג במפרץ חיפה למסיבות ואירועים עד 40 מפליגים, כולל רחבת ריקודים ומנגל פחמים.",
      image: "https://aflagot-haifa.com/seo/seo-Leader-cruise.jpg",
      brand: { "@type": "Brand", name: "Leader שייט & הפלגות" },
      seller: {
        "@type": "TravelAgency",
        "@id": "https://aflagot-haifa.com/",
        name: "Leader שייט & הפלגות",
        legalName: "לידר",
        alternateName: [
          "Leader Haflagot",
          "לידר הפלגות שייט",
          "Leader Yachting",
        ],
        telephone: "+972533403449",
        url: "https://aflagot-haifa.com/",
        sameAs: [
          "https://www.facebook.com/leadership.haifa",
          "https://www.instagram.com/leader.aflagot?igsh=YnAzcThrbDExd2o5",
          "https://www.youtube.com/channel/UCzEOzFcGu8zSeFtFrif4cYw",
        ],
      },
      offers: {
        "@type": "AggregateOffer",
        priceCurrency: "ILS",
        lowPrice: "1990",
        highPrice: "4400",
        offerCount: "3",
        offers: [
          {
            "@type": "Offer",
            name: "הפלגה לשעה אחת",
            price: "1990",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/yacht-king-40",
          },
          {
            "@type": "Offer",
            name: "הפלגה לשעתיים",
            price: "3290",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/yacht-king-40",
          },
          {
            "@type": "Offer",
            name: "הפלגה ל-3 שעות",
            price: "4400",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/yacht-king-40",
          },
        ],
      },
    })}
  />
</Layout>
