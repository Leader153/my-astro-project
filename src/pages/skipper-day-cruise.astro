---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import desktopHero from "../assets/skipper-for-a-day-learning-to-steer-yacht.jpeg";
import mobileHero from "../assets/skipper-for-a-day-learning-to-steer-yacht.jpeg";
import img1 from "../assets/skipper-for-day.jpg";
import img2 from "../assets/skipper-for-a-day.jpg";
import FleetSelectionCta from "../components/FleetSelectionCta.astro";
---

<Layout
  title="סקיפר ליום אחד בהרצליה | Leader הפלגות"
  description="חוויה קבוצתית מרתקת עם סקיפר מקצועי על יאכטה פרטית. הדרכה, הגאי, על האש ופינוקי VIP — מחיפה ועד הרצליה."
>
  <div class="service-page" dir="rtl">
    <section class="sp-hero">
      <Image
        src={desktopHero}
        alt="סקיפר ליום אחד לומד להשיט יאכטה בנמל חיפה"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg desktop-hero"
      />
      <Image
        src={mobileHero}
        alt="סקיפר ליום אחד לומד להשיט יאכטה בנמל חיפה"
        widths={[400, 768]}
        sizes="100vw"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg mobile-hero"
      />
    </section>

    <section class="sp-content">
      <!-- Начинается контейнер, ограничивающий ширину контента и картинок (sp-inner) -->
      <div class="sp-inner">
        <h1>השכרת יאכטה לסקיפר ליום אחד – לקחת את ההגה לידיים בקבוצה</h1>
        <p>
          מכירים מישהו או מישהי שפשוט חיים ונושמים את הים? מחפשים את ההפתעה הכי
          מקורית שיש ליום הולדת או אירוע מיוחד? ב<span class="brand-leader"
            >לידר השכרת יאכטות</span
          >, אנחנו מזמינים אתכם להעניק מתנה שאי אפשר לשכוח: חוויה קבוצתית מרתקת
          שבה חתן או כלת השמחה יקבלו את הפיקוד ויהפכו לסקיפרים ליום אחד!
        </p>

        <h2>🧭 החוויה: מה זה אומר להיות סקיפר?</h2>
        <p>
          ההפלגה שלנו מלווה בסקיפר מקצועי ומנוסה מהצוות של <span
            class="brand-leader">"לידר"</span
          >. מעבר להפלגה עצמה, הסקיפר שלנו יעביר לכם הדרכה מקיפה ומעשירה, ישתף
          אתכם בסודות הים, וייתן לכם להתנסות בזמן אמת בתפעול המפרשים, ניווט
          היאכטה וכמובן – עמידה מאחורי ההגה. בואו להרגיש את העוצמה של הים דרך
          הידיים שלכם!
        </p>

        <Image
          src={img1}
          alt="סקיפר ליום אחד"
          format="webp"
          width={600}
          height={600}
          loading="lazy"
          class="sp-gallery-img"
          style="aspect-ratio: 1/1; object-fit: cover;"
        />

        <h2>📍 מחיפה ועד הרצליה – חגיגה בכל גודל</h2>
        <ul class="sp-list">
          <li>
            כדי שכל החבר'ה יוכלו להצטרף להפלגה ולעודד את ה"קפטן" החדש, צי
            היאכטות המפואר של <span class="brand-leader">לידר</span> ממתין לכם בשני
            הלוקיישנים המובילים בישראל: <strong>מרינה חיפה</strong> ו<strong
              >מרינה הרצליה</strong
            >.
          </li>
          <li>
            לא משנה כמה חברים אתם רוצים להביא לחגיגה – יש לנו את היאכטה המושלמת
            עבורכם! הצי שלנו ערוך לאירוח של קבוצות בכל גודל, עם ספינות ויאכטות
            המותאמות ל-21, 30, 40 ואפילו 55 משתתפים.
          </li>
        </ul>

        <Image
          src={img2}
          alt="סקיפר ליום אחד לומדים להיות סקיפר"
          format="webp"
          width={600}
          height={600}
          loading="lazy"
          class="sp-gallery-img"
          style="aspect-ratio: 1/1; object-fit: cover;"
        />

        <h2>🥂 אנחנו נדאג להכל – הנוחות שלכם היא המשימה שלנו</h2>
        <p>
          אתם רק צריכים להגיע עם בגד ים ומצב רוח טוב – אנחנו כבר נדאג לכל היתר.
          ב<span class="brand-leader">"לידר"</span>, אנחנו מאמינים שהנוחות שלכם
          היא המשימה שלנו (Your comfort Our mission).
        </p>

        <h2>🎉 מה מחכה לכם ולחברים על הסיפון?</h2>
        <ul class="sp-list">
          <li>
            <strong>פינוקי VIP:</strong> בקבוק שמפניה לפתיחת החגיגות, יין משובח, לבבות
            שוקולד, מים מינרליים ושתייה חמה חופשית. (למי שחוגג אירוע רומנטי בתוך הקבוצה
            – נדאג גם לקישוט של לב מעלי כותרת על המיטה!).
          </li>
          <li>
            <strong>אקשן ומוזיקה:</strong> היאכטה תקושט בבלונים חגיגיים, ובסלון תמצאו
            מערכת סאונד מתקדמת (רק תביאו את הפלייליסט שלכם). כשנעצור בלב ים תוכלו
            ליהנות ממזרן שיזוף בחרטום וקפיצה למים עם אבוב טבילה חווייתי.
          </li>
          <li>
            <strong>נוחות של מלון בוטיק:</strong> היאכטות שלנו ממוזגות לחלוטין וכוללות
            סלון מרווח, שני חדרי שינה, מטבח מאובזר, מקלחת ושירותים נקיים.
          </li>
          <li>
            <strong>תיעוד החוויה:</strong> רוצים תמונות למזכרת עם כובע הקפטן מאחורי
            ההגה? יש אפשרות לצילום על ידי הסקיפר שלנו (אנא ציינו זאת מראש בעת ההזמנה).
          </li>
        </ul>

        <h2>💰 מחירון סקיפר ליום אחד:</h2>
        <ul class="sp-pricing">
          <li>צרו איתנו קשר לקבלת הצעת מחיר מותאמת אישית למספר המשתתפים.</li>
        </ul>

        <p class="sp-closing">
          חוויה קבוצתית בלתי נשכחת מחכה לכם עם <span class="brand-leader"
            >לידר השכרת יאכטות</span
          >. הזמינו עכשיו ותנו לחבר או לחברה שלכם להפוך לקפטן ליום אחד!
        </p>
      </div>
      <!-- Закрываем sp-inner (ИМЕННО ЗДЕСЬ) -->

      <div class="services-grid">
        <a
          href="https://wa.me/972533403449"
          class="service-card"
          style="--c:#0ea5e9; --i:0"
          target="_blank"
          rel="noopener"
        >
          <div class="sc-img-wrap">
            <Image
              src={desktopHero}
              width={600}
              height={400}
              format="webp"
              alt="הפלגת סקיפר ליום אחד"
              class="sc-img"
              loading="lazy"
            />
            <div class="sc-tag" style="background:#0ea5e9; color:#fff">
              WhatsApp
            </div>
          </div>
          <div class="sc-body">
            <div class="sc-icon">⛵</div>
            <h3>סקיפר ליום אחד</h3>
            <p>
              <strong>קבוצות:</strong> עד 55 משתתפים<br />
              <strong>כולל:</strong> סקיפר מקצועי, הדרכה, שמפניה ואבזור VIP.<br
              />
              <span style="font-size: 0.85em; color: #000000;"
                >אידאלי לימי הולדת, גיבוש וחגיגות</span
              >
            </p>
            <div class="sc-arrow" style="color:#0ea5e9">
              להזמנה בוואטסאפ
              <svg
                aria-hidden="true"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                width="15"
                height="15"><polyline points="15 18 9 12 15 6"></polyline></svg
              >
            </div>
          </div>
        </a>
      </div>

      <FleetSelectionCta />

      <!-- ═══ FAQ SECTION ═══ -->
      <div class="faq-wrapper">
        <h2 class="faq-title">
          ❓ שאלות ותשובות נפוצות – סקיפר ליום אחד עם <span class="brand-leader"
            >"לידר"</span
          >
        </h2>

        <div class="accordion">
          <div class="accordion-item">
            <button
              class="accordion-trigger"
              aria-expanded="false"
              aria-controls="faq-a0"
            >
              <span class="q-num">1</span>
              <span class="q-text"
                >האם היאכטה מתנדנדת בלילה? יש סיכוי למחלת ים?</span
              >
              <span class="q-chevron" aria-hidden="true">
                <svg
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  width="18"
                  height="18"><polyline points="6 9 12 15 18 9"></polyline></svg
                >
              </span>
            </button>
            <div class="accordion-body" id="faq-a0" hidden>
              <div class="accordion-answer">
                <div class="answer-bar"></div>
                <p>
                  ממש לא! במהלך הלילה היאכטה עוגנת בבטחה בתוך המרינה (בחיפה או
                  בהרצליה), במקום שקט, יציב ומוגן מגלים. החוויה שקטה לחלוטין
                  ומרגישה ממש כמו חדר מלון צף. ההפלגה עצמה, שבה נרגיש את תנועת
                  הגלים, מתקיימת רק בבוקר לאחר שמתעוררים.
                </p>
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <button
              class="accordion-trigger"
              aria-expanded="false"
              aria-controls="faq-a1"
            >
              <span class="q-num">2</span>
              <span class="q-text">מה חשוב להביא איתנו ללילה ביאכטה?</span>
              <span class="q-chevron" aria-hidden="true">
                <svg
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  width="18"
                  height="18"><polyline points="6 9 12 15 18 9"></polyline></svg
                >
              </span>
            </button>
            <div class="accordion-body" id="faq-a1" hidden>
              <div class="accordion-answer">
                <div class="answer-bar"></div>
                <p>
                  בדיוק מה שהייתם מביאים לצימר רגיל או לבית מלון: בגדים נוחים
                  לערב, כלי רחצה אישיים (מברשת שיניים וכו'), בגדי ים להפלגת
                  הבוקר, ואם מתחשק לכם – אוכל ונשנושים שאתם אוהבים. אנחנו ב<span
                    class="brand-leader">לידר</span
                  >
                  כבר נדאג לכל השאר: מגבות נקיות, מצעים מלטפים, מוצרי טיפוח במקלחת,
                  שמפניה וקפה.
                </p>
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <button
              class="accordion-trigger"
              aria-expanded="false"
              aria-controls="faq-a2"
            >
              <span class="q-num">3</span>
              <span class="q-text"
                >רגע, הבנו שאפשר לעשות "על האש" על היאכטה. זה נכון?</span
              >
              <span class="q-chevron" aria-hidden="true">
                <svg
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  width="18"
                  height="18"><polyline points="6 9 12 15 18 9"></polyline></svg
                >
              </span>
            </button>
            <div class="accordion-body" id="faq-a2" hidden>
              <div class="accordion-answer">
                <div class="answer-bar"></div>
                <p>
                  בהחלט! זה אחד השדרוגים הכי שווים אצלנו. תוכלו להביא איתכם
                  בשרים, דגים או ירקות, ולצלות אותם על הגריל שלנו באוויר הפתוח
                  מול נוף המרינה המהפנט. המטבח של היאכטה מאובזר ועומד לרשותכם
                  במלואו להכנת ארוחת הערב המושלמת שלכם.
                </p>
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <button
              class="accordion-trigger"
              aria-expanded="false"
              aria-controls="faq-a3"
            >
              <span class="q-num">4</span>
              <span class="q-text">האם יש מקלחת ושירותים נוחים ביאכטה?</span>
              <span class="q-chevron" aria-hidden="true">
                <svg
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  width="18"
                  height="18"><polyline points="6 9 12 15 18 9"></polyline></svg
                >
              </span>
            </button>
            <div class="accordion-body" id="faq-a3" hidden>
              <div class="accordion-answer">
                <div class="answer-bar"></div>
                <p>
                  ברור! היאכטות של <span class="brand-leader">לידר</span> מאובזרות
                  ברמת VIP מתוך מחשבה על הנוחות המקסימלית שלכם. תמצאו בהן שירותים
                  חשמליים נקיים ומקלחת נוחה עם מים חמים, בדיוק כמו בבית.
                </p>
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <button
              class="accordion-trigger"
              aria-expanded="false"
              aria-controls="faq-a4"
            >
              <span class="q-num">5</span>
              <span class="q-text">איך מעבירים את הערב ביאכטה?</span>
              <span class="q-chevron" aria-hidden="true">
                <svg
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  width="18"
                  height="18"><polyline points="6 9 12 15 18 9"></polyline></svg
                >
              </span>
            </button>
            <div class="accordion-body" id="faq-a4" hidden>
              <div class="accordion-answer">
                <div class="answer-bar"></div>
                <p>
                  מעבר לרומנטיקה, לארוחה הטובה ולכוס השמפניה על הסיפון תחת כיפת
                  השמיים – הדאגנו לכם גם לבידור בפנים! הסלון וחדר השינה ממוזגים,
                  ותמצאו בהם טלוויזיה חכמה עם נטפליקס ומערכת סאונד מעולה
                  (בלוטות'). תוכלו להעביר את הערב בבינג' מפנק מתחת לפוך או פשוט
                  לשמוע את המוזיקה שאתם הכי אוהבים.
                </p>
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <button
              class="accordion-trigger"
              aria-expanded="false"
              aria-controls="faq-a5"
            >
              <span class="q-num">6</span>
              <span class="q-text">מאיפה יוצאים ואיפה מחנים את הרכב?</span>
              <span class="q-chevron" aria-hidden="true">
                <svg
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  width="18"
                  height="18"><polyline points="6 9 12 15 18 9"></polyline></svg
                >
              </span>
            </button>
            <div class="accordion-body" id="faq-a5" hidden>
              <div class="accordion-answer">
                <div class="answer-bar"></div>
                <p>
                  אנו מציעים את חווית "הצימר על המים" בשני הלוקיישנים המרכזיים
                  שלנו: מרינה הרצליה התוססת ומרינה חיפה הפסטורלית. בשתי המרינות
                  ישנם חניונים מסודרים, בטוחים ונוחים במרחק הליכה קצר מאוד
                  מהרציף הפרטי שלנו.
                </p>
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <button
              class="accordion-trigger"
              aria-expanded="false"
              aria-controls="faq-a6"
            >
              <span class="q-num">7</span>
              <span class="q-text"
                >האם הצימר מתאים גם למשפחות או רק לזוגות?</span
              >
              <span class="q-chevron" aria-hidden="true">
                <svg
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  width="18"
                  height="18"><polyline points="6 9 12 15 18 9"></polyline></svg
                >
              </span>
            </button>
            <div class="accordion-body" id="faq-a6" hidden>
              <div class="accordion-answer">
                <div class="answer-bar"></div>
                <p>
                  החוויה הקלאסית והמבוקשת ביותר היא חופשה זוגית רומנטית. עם זאת,
                  היאכטות שלנו מרווחות מספיק כדי לארח בנוחות גם זוג + עד 2
                  ילדים, כך שזו יכולה להיות חוויית גיבוש משפחתית בלתי נשכחת
                  ללילה אחד מיוחד!
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<script>
  document
    .querySelectorAll<HTMLButtonElement>(".accordion-trigger")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        const bodyId = btn.getAttribute("aria-controls")!;
        const body = document.getElementById(bodyId)!;
        const item = btn.closest(".accordion-item")!;

        // close siblings
        btn
          .closest(".accordion")!
          .querySelectorAll<HTMLButtonElement>(".accordion-trigger")
          .forEach((b) => {
            if (b !== btn) {
              b.setAttribute("aria-expanded", "false");
              b.closest(".accordion-item")!.classList.remove("open");
              const sid = b.getAttribute("aria-controls")!;
              const sb = document.getElementById(sid)!;
              sb.hidden = true;
              sb.style.maxHeight = "0";
            }
          });

        if (expanded) {
          btn.setAttribute("aria-expanded", "false");
          item.classList.remove("open");
          body.hidden = true;
          body.style.maxHeight = "0";
        } else {
          btn.setAttribute("aria-expanded", "true");
          item.classList.add("open");
          body.hidden = false;
          body.style.maxHeight = body.scrollHeight + "px";
        }
      });
    });
</script>

<!-- Schema.org Data API -->
<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TouristTrip",
    name: "סקיפר ליום אחד – לימוד השטת יאכטה",
    description:
      "חוויה קבוצתית מרתקת: לקחת את ההגה לידיים עם סקיפר מקצועי. הדרכה, אקשן ופינוקי VIP — מחיפה ועד הרצליה.",
