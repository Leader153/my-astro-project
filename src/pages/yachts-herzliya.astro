---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import louseImg from "../assets/Louse.jpeg";
import JoiBeImg from "../assets/Joy-Be-Yacht.jpeg";
import redbotimg from "../assets/redbot.png";
import LeaImg from "../assets/LeaCatamaran.png";
import catamaranimg from "../assets/Dolfin.jpeg";
import Bagiraimg from "../assets/Bagira-Yacht.jpeg";
import LiYamImg from "../assets/Lee-Yam-Yacht.png";
import PremiumSwitch from "../components/PremiumSwitch.astro";

// Array of 8 yachts
const yachts = [
  {
    name: "יאכטה ג'וי בי (עד 13 מפליגים)",
    capacity: "עד 13 מפליגים",
    desc: "",
    descLines: [
      "יאכטה מרווחת ומפנקת לחגיגות ומשפחות",
      "שעה: 910 ₪",
      "שעה וחצי: 1,090 ₪",
      "שעתיים: 1,350 ₪",
      "3 שעות: 1,860 ₪",
    ],
    img: JoiBeImg,
    tag: "מפנקת",
    href: "/yacht-joy-b",
  },
  {
    name: "יאכטה לי ים (עד 13 מפליגים)",
    capacity: "עד 13 מפליגים",
    desc: "",
    descLines: [
      "עיצוב קלאסי לשייט קסום ופרטי",
      "שעה: 860 ₪",
      "שעה וחצי: 1,030 ₪",
      "שעתיים: 1,290 ₪",
    ],
    img: LiYamImg,
    tag: "קלאסית",
    href: "/yacht-li-yam",
  },
  {
    name: "יאכטה בגירה (עד 12 מפליגים)",
    capacity: "עד 12 מפליגים",
    desc: "",
    descLines: [
      "יאכטה נהדרת לאירועי יוקרה מצומצמים",
      "שעה: 760 ₪",
      "שעה וחצי: 930 ₪",
      "שעתיים: 1,190 ₪",
      "3 שעות: 1,580 ₪",
    ],
    img: Bagiraimg,
    tag: "פופולרית",
    href: "/yacht-bagira",
  },
  {
    name: "יאכטה לואיז (עד 6 מפליגים)",
    capacity: "עד 6 מפליגים",
    desc: "",
    descLines: [
      "יאכטת בוטיק קטנה וחמימה לרומנטיקה",
      "שעה: 670 ₪",
      "שעה וחצי: 840 ₪",
      "שעתיים: 1,100 ₪",
      "3 שעות: 1,450 ₪",
    ],
    img: louseImg,
    tag: "רומנטי",
    href: "/yacht-louise",
  },
  {
    name: "לאה - יאכטה קטמרן מפרשית",
    desc: "",
    descLines: [
      "יאכטה קטמרן מפרשית מפוארת במיוחד",
      "שעה: 2,490 ₪",
      "שעתיים: 3,100 ₪",
      "3 שעות: 4,090 ₪",
    ],
    capacity: "עד 14 מפליגים",
    img: LeaImg,
    tag: "למשפחות",
    href: "/catamaran-Lea",
  },
  {
    name: "דולפין - יאכטה קטמרן",
    capacity: "עד 21 מפליגים",
    desc: "",
    descLines: [
      "ספינת קטמרן ענקית וסופר יציבה למסיבות",
      "שעה: 1,990 ₪",
      "שעתיים: 2,550 ₪",
      "3 שעות: 3,590 ₪",
    ],
    img: catamaranimg,
    tag: "לקבוצות גדולות",
    href: "/catamaran-21",
  },
  {
    name: "סירת מנוע אחמית",
    capacity: "עד 9 מפליגים",
    desc: "סירת מנוע מהירה לאדרנלין ואקסטרים על הגלים! שייט ספורטיבי.",
    img: redbotimg,
    tag: "אקסטרים",
    href: "/yachts-herzliya",
  },
];
---

<Layout
  title="יאכטות בהרצליה | צי היאכטות של Leader הפלגות"
  description="הכירו את צי היאכטות המפואר שלנו במרינה הרצליה. מגוון יאכטות להפלגות זוגיות, קבוצות עד 21 איש, אירועים ומסיבות."
>
  <div class="yachts-page" dir="rtl">
    <section class="yp-hero">
      <div class="yp-inner text-center">
        <div class="yp-eyebrow">מרינה הרצליה</div>
        <h1>היאכטות שלנו בהרצליה</h1>
        <p>
          צי יאכטות מגוון ומפואר — מקטמרן ענקית ל-21 איש ועד יאכטות אינטימיות
          לזוגות. בחרו את היאכטה המושלמת עבורכם.
        </p>
        <div class="yp-btns">
          <a href="/contact" class="yp-btn primary">לייעוץ ובחירת יאכטה</a>
          <a href="https://wa.me/972533403449" class="yp-btn wa">WhatsApp</a>
        </div>
      </div>
    </section>

    <section class="yp-grid-section">
      <div class="yp-container">
        <div class="hz-grid">
          {
            yachts.map((yacht, i) => (
              <a
                href={yacht.href}
                class="hz-card"
                style={`--c:#0f7ab0; --i:${i}`}
              >
                <div class="hz-card-img">
                  <Image
                    src={yacht.img}
                    width={600}
                    height={400}
                    format="webp"
                    alt={yacht.name}
                    class="hz-img"
                    loading={i < 4 ? "eager" : "lazy"}
                  />
                  <div class="hz-badge" style={`background:#0f7ab0`}>
                    {yacht.tag}
                  </div>
                </div>
                <div class="hz-card-body">
                  <div
                    class="hz-card-icon"
                    style="font-size: 1rem; color: #0f7ab0; font-weight: bold; display: flex; align-items: center; gap: 0.5rem; margin-top: 0;"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      width="18"
                      height="18"
                    >
                      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                      <circle cx="9" cy="7" r="4" />
                      <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                      <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                    {yacht.capacity}
                  </div>
                  <h3>{yacht.name}</h3>
                  {yacht.descLines ? (
                    <p>
                      {yacht.descLines.map((line) => (
                        <span style="display:block; margin-bottom: 0.2rem;">
                          {line}
                        </span>
                      ))}
                    </p>
                  ) : (
                    <p>{yacht.desc}</p>
                  )}
                  <span class="hz-card-cta" style={`color:#0f7ab0`}>
                    לפרטים
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      width="14"
                      height="14"
                    >
                      <polyline points="15 18 9 12 15 6" />
                    </svg>
                  </span>
                </div>
                <div class="hz-glow" style={`background:#0f7ab0`} />
              </a>
            ))
          }
        </div>
        <div class="text-center" style="margin-top: 4rem;">
          <PremiumSwitch
            href="/herzliya"
            title="ההפלגות שלנו בהרצליה"
            subtitle="לצפייה בכל אפשרויות השייט המפנקות שיש לנו להציע"
          />
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .yachts-page {
    background: #f2f5fb;
    min-height: 100vh;
    font-family: "Rubik", sans-serif;
  }

  /* Hero */
  .yp-hero {
    padding: 8rem 2rem 5rem;
    background: linear-gradient(135deg, #08047e 0%, #0a5a8f 100%);
    color: white;
    text-align: center;
  }
  .yp-eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    color: #f0c040;
    letter-spacing: 1px;
    margin-bottom: 1rem;
  }
  .yp-hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .yp-hero p {
    font-size: 1.1rem;
    opacity: 0.9;
    max-width: 650px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .yp-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .yp-btn {
    padding: 0.85rem 2rem;
    border-radius: 12px;
    font-weight: 700;
    font-size: 1.05rem;
    text-decoration: none;
    transition: 0.2s;
  }
  .yp-btn.primary {
    background: #d4a017;
    color: #08047e;
    box-shadow: 0 6px 20px rgba(212, 160, 23, 0.3);
  }
  .yp-btn.primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(212, 160, 23, 0.5);
  }
  .yp-btn.wa {
    background: #25d366;
    color: white;
  }
  .yp-btn.wa:hover {
    background: #128c7e;
    transform: translateY(-3px);
  }

  /* Grid Section */
  .yp-grid-section {
    padding: 5rem 2rem;
  }
  .yp-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    color: #0f7ab0;
    font-weight: 600;
    text-decoration: none;
    padding: 0.5rem 1rem;
    border: 1px solid #0f7ab0;
    border-radius: 8px;
    transition: 0.2s;
  }
  .back-link:hover {
    background: #0f7ab0;
    color: white;
  }
</style>
