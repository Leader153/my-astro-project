---
import Layout from "../layouts/Layout.astro";
import PremiumSwitch from "../components/PremiumSwitch.astro";
import FleetSelectionCta from "../components/FleetSelectionCta.astro";
import { Image } from "astro:assets";
import bannerImg from "../assets/wedding-couple-sailing-yacht-sunset-herzliya.webp";
import romantic2Img from "../assets/wedding-couple-sailing-yacht-sunset-haifa.webp";
import coupleImg from "../assets/couple-holding-hands-yacht-bow-haifa.webp";
import brideImg from "../assets/romantic-couple-sunset-yacht-trip-herzliya.webp";

import "../styles/pricing-card.css";
import JoiBeImg from "../assets/Joy-Be-Yacht.jpeg";
import LiYamImg from "../assets/Lee-Yam-Yacht.png";
import Bagiraimg from "../assets/Bagira-Yacht.jpeg";
import louseImg from "../assets/Louse.jpeg";
import YamiImg from "../assets/Yami.png";

const coupleYachts = [
  {
    name: "ג'וי בי (Joy B)",
    price1: "680",
    price15: "860",
    price2: "1050",
    extraHour: "510",
    img: JoiBeImg,
    href: "/yacht-joy-b",
  },
  {
    name: "לי-ים (Lee Yam)",
    price1: "620",
    price15: "800",
    price2: "990",
    extraHour: "450",
    fishing: true,
    img: LiYamImg,
    href: "/yacht-li-yam",
  },
  {
    name: "בגירה (Bagira)",
    price1: "590",
    price15: "750",
    price2: "890",
    extraHour: "390",
    img: Bagiraimg,
    href: "/yacht-bagira",
  },
  {
    name: "לואיז (Louise)",
    price1: "550",
    price15: "700",
    price2: "850",
    extraHour: "300",
    img: louseImg,
    href: "/yacht-louise",
  },
  {
    name: "יאכטה יאמי (חיפה)",
    price1: "1090",
    price2: "1250",
    extraHour: "550",
    img: YamiImg,
    href: "/yacht-11",
  },
];
---

<Layout
  title="שייט רומנטי ביאכטה פרטית: הפלגה זוגית מול השקיעה | Leader הפלגות"
  description="מחפשים חוויה זוגית בלתי נשכחת? ⚓ שייט רומנטי ביאכטה פרטית מחכה לכם! מושלם להצעות נישואין, ימי הולדת או פינוק זוגי 🥂. התקשרו!"
>
  <div class="service-page" dir="rtl">
    <!-- ═══ HERO BANNER ═══ -->
    <div class="hero-banner">
      <Image
        src={bannerImg}
        alt="זוג בהפגנת אהבה על יאכטה בזמן שקיעה רומנטית בהרצליה"
        width={1920}
        height={700}
        class="hero-banner-image desktop-banner"
        loading="eager"
      />
      <Image
        src={romantic2Img}
        alt="זוג בהפגנת אהבה על יאכטה בזמן שקיעה רומנטית בהרצליה"
        width={1080}
        height={1080}
        class="hero-banner-image mobile-banner"
        loading="eager"
      />
    </div>

    <!-- ═══ HERO TEXT (below the photo) ═══ -->
    <div class="hero-text-block">
      <div class="hero-eyebrow">✦ חוויה זוגית ✦</div>
      <h1>השכרת יאכטה לזוג - שייט רומנטי מול השקיעה</h1>
      <p class="hero-subtitle">רק השניים, הים, והשקיעה</p>
      <a
        href="https://wa.me/972533403449"
        target="_blank"
        rel="noopener"
        class="hero-cta">💬 ליצירת קשר ב-WhatsApp</a
      >
    </div>

    <!-- ═══ SECTION 1: Intro ═══ -->
    <div class="container container-top-offset">
      <div class="intro-block">
        <p>
          בעידן שבו אנחנו כל הזמן מוקפים במסכים, רעשים ומטלות יומיומיות, קשה
          למצוא את הרגע הזה שהוא באמת <strong>"רק של שניינו"</strong>.
        </p>
        <p>שייט זוגי ביאכטה מציע בדיוק את הניתוק הזה.</p>
      </div>

      <div class="content">
        <p>
          ברגע שאתם עולים על הסיפון , המנוע מותנע והיאכטה יוצאת מהמרינה בהרצליה
          אל עבר האופק הכחול – הזמן עוצר מלכת.
        </p>
        <p>
          אין פקקים, אין טלפונים, יש רק את צליל הגלים, הרוח שמלטפת את הפנים,
          ומרחבים אינסופיים של ים ושמיים. זוהי הזדמנות פז להתנתק מהשגרה השוחקת,
          להסתכל אחד לשנייה בעיניים, לשתות כוס יין צונן מול השקיעה, ולהרגיש שוב
          את אותם פרפרים בבטן של הדייט הראשון.
        </p>
        <p>
          האווירה הייחודית של הים הפתוח מרחיבה את הלב ומאפשרת לכם לחגוג את האהבה
          שלכם בצורה הכי טהורה ורומנטית שיש.
        </p>

        <div class="image-wrapper" style="margin: 3rem auto; max-width: 450px;">
          <Image
            src={coupleImg}
            alt="זוג מחזיק ידיים על חרטום היאכטה מול שקיעה בחיפה"
            width={900}
            height={1200}
            class="vertical-img"
          />
        </div>

        <!-- Occasions box -->
        <div class="highlight-box">
          <h2>🥂 לאילו אירועים מתאים שייט רומנטי?</h2>
          <p class="highlight-lead">
            הפלגה ביאכטה מתאימה לכל אירוע שבו תרצו להפתיע, לרגש ולצאת מהקופסה:
          </p>
          <div class="occasions-grid">
            <div class="occasion-card">
              <div class="occasion-icon">💍</div>
              <h3>הצעות נישואין בלתי נשכחות</h3>
              <p>
                שעת שקיעה, מוזיקה רומנטית ברקע, כוסות שמפניה משיקות זו לזו –
                ואתם כורעים ברך על סיפון עץ יוקרתי בלב הים. אנחנו נדאג לתפאורה
                המושלמת, לכם נשאר רק להביא את הטבעת.
              </p>
            </div>
            <div class="occasion-card">
              <div class="occasion-icon">💒</div>
              <h3>יום נישואין</h3>
              <p>
                במקום עוד מסעדה שגרתית, בואו לחגוג את הזוגיות שלכם בארוחה
                רומנטית ופרטית המוגשת לכם על סיפון היאכטה, באווירה של מסעדת
                מישלן על המים.
              </p>
            </div>
            <div class="occasion-card">
              <div class="occasion-icon">🎂</div>
              <h3>ימי הולדת והפתעות לבן/בת הזוג</h3>
              <p>
                שייט שקיעה מפנק, בשילוב עיסוי מקצועי וארוחת שף – זוהי מתנת יום
                ההולדת האולטימטיבית שתיחרט בזיכרון לנצח.
              </p>
            </div>
            <div class="occasion-card">
              <div class="occasion-icon">❤️</div>
              <h3>פסק זמן זוגי – סתם כי אוהבים</h3>
              <p>
                מי אמר שצריך תאריך מיוחד? לפעמים המתנה הכי טובה היא פשוט לפנות
                זמן אחד לשנייה, לברוח מהכל למספר שעות של שקט, אינטימיות ופינוק.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══ MIDDLE SECTION IMAGE ═══ -->
    <div style="margin: 4rem auto; max-width: 600px; padding: 0 20px;">
      <Image
        src={brideImg}
        alt="זוג רומנטי ברגע אינטימי על יאכטה בזמן שקיעה בהרצליה"
        width={900}
        height={900}
        class="square-img"
      />
    </div>
    <div class="strip-quote-block">
      <p class="strip-quote">"הרגע המושלם לא מגיע – אתם יוצרים אותו"</p>
    </div>

    <!-- ═══ SECTION 2: What to Expect ═══ -->
    <div class="container container-bottom">
      <h2 class="section-title">⚓ מה מחכה לכם על הסיפון?</h2>
      <p class="section-subtitle">
        כשאתם בוחרים בנו, אתם בוחרים בסטנדרט האירוח הגבוה ביותר.
      </p>

      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🛋️</div>
          <h3>אבזור מלא ונוחות מקסימלית</h3>
          <p>
            כל יאכטה מצוידת בסלון מרווח, חדרי שינה מפנקים, מטבח מאובזר, שירותים
            ומקלחת.
          </p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🌹</div>
          <h3>הפרטים הקטנים שעושים את ההבדל</h3>
          <p>
            מצעים לבנים ורכים, מגבות נקיות, ורדים פזורים על המיטה, בלונים
            חגיגיים ופרחים – הכל מוכן לפני הגעתכם.
          </p>
        </div>
        <a href="/yacht-dining-herzliya" class="feature-card feature-card-link">
          <div class="feature-icon">🍽️</div>
          <h3>קולינריה בלב ים</h3>
          <p>
            ארוחות בוקר עשירות, ארוחות צהריים/ערב עם דג או בשר, מוגשות עם מפות
            נקיות וכלים יוקרתיים.
          </p>
        </a>
        <div class="feature-card">
          <div class="feature-icon">🍫</div>
          <h3>פינוקים מתוקים</h3>
          <p>
            כל אירוח זוגי כולל כסטנדרט בקבוק יין איכותי ושוקולדים טעימים שימתיקו
            לכם את ההפלגה.
          </p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">💆</div>
          <h3>ספא על המים</h3>
          <p>
            הוסיפו לחבילה שלכם עיסוי מקצועי ומרגיע שיינתן לכם באוויר הפתוח או
            בתוך היאכטה הממוזגת, לקול פכפוך הגלים.
          </p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🎵</div>
          <h3>מוזיקה שלכם</h3>
          <p>
            מערכת סאונד מתקדמת עם חיבור בלוטות'. הביאו את הפלייליסט האהוב עליכם,
            או תנו לנו לבחור מוזיקת רקע רומנטית ונעימה.
          </p>
        </div>
      </div>

      <!-- ═══ FAQ ═══ -->
      <div class="faq-section">
        <h2 class="section-title">❓ שאלות ותשובות נפוצות</h2>

        <div class="faq-item">
          <div class="faq-q">האם צריך לדעת להשיט יאכטה?</div>
          <div class="faq-a">
            ממש לא! לכל הפלגה מצטרף סקיפר מקצועי ומנוסה מטעמנו. הסקיפר ידאג
            לבטיחות שלכם ולניהול ההפלגה, ומיומן בלהעניק לכם שירות אדיב ודיסקרטי
            – כך שתרגישו בפרטיות מוחלטת לאורך כל השייט.
          </div>
        </div>

        <div class="faq-item">
          <div class="faq-q">מהיכן יוצאת ההפלגה ואיפה חונים?</div>
          <div class="faq-a">
            היאכטות שלנו עוגנות במרינה המפוארת של הרצליה. ממוקמים מול טיילת
            המסעדות התוססת, עם גישה לרציף פרטי לבעלי אישור בלבד – שקט ופרטיות
            מרגע ההגעה. ישנו חניון מוסדר וצמוד לנוחותכם.
          </div>
        </div>

        <div class="faq-item">
          <div class="faq-q">מה קורה אם סובלים ממחלת ים?</div>
          <div class="faq-a">
            ההפלגות הזוגיות שלנו נעשות לרוב בקרבת החוף ובתנאי ים נוחים. אם אתם
            רגישים, אנו ממליצים לקחת כדור נגד מחלת ים כחצי שעה לפני ההפלגה,
            ולהסתכל תמיד אל עבר האופק במהלך השייט.
          </div>
        </div>

        <div class="faq-item">
          <div class="faq-q">האם ניתן להשמיע מוזיקה משלנו?</div>
          <div class="faq-a">
            בהחלט! יש לנו מערכת סאונד מתקדמת ביאכטה. אתם מוזמנים להתחבר בבלוטות'
            ולהשמיע את הפלייליסט האהוב עליכם, או לתת לנו לבחור עבורכם מוזיקת רקע
            רומנטית ונעימה.
          </div>
        </div>
      </div>

      <!-- ═══ CTA ═══ -->
      <div class="cta-block">
        <h2>מוכנים לחוות את הרגע הכי רומנטי בחיים?</h2>
        <p>צרו קשר עוד היום ונבנה יחד את ההפלגה המושלמת עבורכם</p>
        <a
          href="https://wa.me/972533403449"
          target="_blank"
          rel="noopener"
          class="cta-btn">💬 הזמינו עכשיו ב-WhatsApp</a
        >
      </div>
<div style="margin: 3rem auto; max-width: 450px; border-radius: 15px; overflow: hidden; position: relative;">
        <video 
          id="romantic-yacht-video"
          width="450"
          height="600"
          autoplay 
          loop 
          muted 
          playsinline 
          class="vertical-img"
          style="width: 100%; height: auto; aspect-ratio: 3/4; object-fit: cover; display: block;"
        >
          <source src="https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/ViD-20260314-WA0001_ei9m4d.mp4" type="video/mp4" />
        </video>
        <button id="mute-toggle-btn" class="mute-btn" aria-label="Включить звук">
          🔇
        </button>
      </div>
      <div style="margin-top: 3rem;">
        <PremiumSwitch
          href="/herzliya"
          title="לכל סוגי ההפלגות בהרצליה"
          subtitle="בואו לבחור לכם יאכטה 🚤"
        />
      </div>
    </div>

    <!-- ═══ SECTION: COUPLES YACHT PRICING ═══ -->
    <section class="container" style="margin-top: 5rem; text-align: right;">
      <h2
        class="packages-title"
        style="color: #3c0a28; text-align: center; margin-bottom: 2rem;"
      >
        מחירון מיוחד לזוגות לפי יאכטה
      </h2>
      <p
        style="text-align: center; margin-bottom: 3rem; font-size: 1.1rem; color: #555;"
      >
        המחירים המוצגים כאן תקפים אך ורק להפלגות זוגיות (2 משתתפים בלבד).
      </p>

      <div
        style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;"
      >
        {
          coupleYachts.map((yacht) => (
            <a
              href={yacht.href}
              style="text-decoration: none; color: inherit; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.08); transition: transform 0.2s; display: flex; flex-direction: column;"
              class="couple-card"
            >
              <Image
                src={yacht.img}
                width={600}
                height={400}
                format="webp"
                alt={yacht.name}
                style="width: 100%; height: 200px; object-fit: cover; display: block;"
              />
              <div style="padding: 1.5rem;">
                <h3 style="color: #3c0a28; font-size: 1.3rem; margin-top: 0; margin-bottom: 1rem; font-weight: 800;">
                  {yacht.name}
                </h3>

                <ul
                  class="pricing-list no-bullets"
                  style="margin-bottom: 1.5rem;"
                >
                  <li>
                    <strong>שעה הפלגה:</strong> {yacht.price1} ₪
                  </li>
                  <li>
                    <strong>שעה וחצי הפלגה:</strong> {yacht.price15} ₪
                  </li>
                  <li>
                    <strong>שעתיים הפלגה:</strong> {yacht.price2} ₪
                  </li>
                  <li>כל שעה נוספת: {yacht.extraHour} ₪</li>
                </ul>

                <h4 class="pricing-title">המחיר כולל:</h4>
                <ul class="pricing-list" style="font-size: 0.9rem;">
                  <li>שלט מזל טוב, בלונים</li>
                  <li>מוזיקה (בלוטוס), שתייה מים</li>
                  <li>בקבוק שמפניה 🥂</li>
                  <li>ביטוח לכל משתתף</li>
                  <li>סקיפר מקצועי לאורך כל הדרך</li>
                </ul>

                <h4 class="pricing-title">בהזמנה של שעתיים:</h4>
                <ul class="pricing-list" style="font-size: 0.9rem;">
                  <li>ירידה לים עם אבוב 🌊</li>
                </ul>

                {yacht.fishing && (
                  <p style="margin-top: 0.5rem; font-size: 0.9rem; font-weight: 600; color: #d4a017;">
                    תוספת ציוד דייג: 100 ₪
                  </p>
                )}

                <div style="background: rgba(192, 84, 122, 0.05); padding: 1rem; border-radius: 8px; margin-top: 1.5rem;">
                  <p style="margin: 0 0 0.5rem 0; font-size: 0.85rem; font-weight: 600; color: #c0547a;">
                    תוספות מיוחדות:
                  </p>
                  <ul
                    class="pricing-list"
                    style="font-size: 0.85rem; margin-bottom: 0;"
                  >
                    <li>לאחר 20:00 - תוספת 100 ₪</li>
                  </ul>
                </div>

                <div style="margin-top: auto; padding-top: 1.5rem; text-align: left; font-weight: 800; color: #0ea5e9; display: flex; align-items: center; justify-content: flex-end; gap: 0.5rem; font-size: 1.05rem;">
                  לעמוד היאכטה
                  <svg
                    aria-hidden="true"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    width="16"
                    height="16"
                  >
                    <polyline points="15 18 9 12 15 6" />
                  </svg>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <!-- ═══ PACKAGES SECTION (MOVED DOWN) ═══ -->
    <div class="packages-section">
      <div class="packages-inner">
        <p class="packages-lead">אשמח להציע לכם רעיונות לפעילות נוספת</p>
        <h2 class="packages-title">💎 החבילות שלנו בהרצליה</h2>

        <div class="packages-table">
          <div class="pkg-row pkg-header">
            <div class="pkg-cell">סוג החבילה</div>
            <div class="pkg-cell">מה היא כוללת</div>
            <div class="pkg-cell pkg-price-col">מחיר החל מ-</div>
          </div>
          <a
            href="/spa"
            class="pkg-row"
            style="text-decoration: none; color: inherit;"
          >
            <div class="pkg-cell pkg-name">
              <span class="pkg-badge platinum">פלטיניום</span> חבילת ספא פלטיניום
            </div>
            <div class="pkg-cell pkg-desc">
              חוויית פינוק מקסימלית ומרגיעה לאורך 4 שעות.
            </div>
            <div class="pkg-cell pkg-price">2,200 ₪</div>
          </a>
          <a
            href="/spa"
            class="pkg-row"
            style="text-decoration: none; color: inherit;"
          >
