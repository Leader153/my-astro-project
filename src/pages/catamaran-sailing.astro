---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import Heroimg from "../assets/LeaCatamaran.png";
import img1 from "../assets/LeaCatamaran.png";
import midImg from "../assets/lea-back.png";
import botImg from "../assets/Lea-up.jpg";
import FleetSelectionCta from "../components/FleetSelectionCta.astro";
import PremiumSwitch from "../components/PremiumSwitch.astro";
import YachtVideoCard from "../components/YachtVideoCard.astro";
const isoUploadDate = new Date("2026-03-12").toISOString();
import "../styles/pricing-card.css";
---

<Layout
  title="יאכטה קטמרן מפרשית (עד 14 איש): חוויית שייט בחיפה | Leader הפלגות"
  description="השכרת יאכטת קטמרן מפרשית במפרץ חיפה ל-14 מפליגים. החל מ-2,390 ₪ לשעה. מושלם לחגיגות. כולל סקיפר, בלונים ואבוב. מקסימום רווח ויוקרה בים."
>
  <div class="service-page" dir="rtl">
    <section class="sp-hero">
      <Image
        src={Heroimg}
        alt="יאכטה קטמרן מפוארת"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg desktop-hero"
      />
      <Image
        src={Heroimg}
        alt="יאכטה קטמרן מפוארת"
        widths={[400, 768]}
        sizes="100vw"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg mobile-hero"
        style="object-position: 50% 50%;"
      />
    </section>

    <section class="sp-content">
      <div class="sp-inner">
        <h1>השכרת יאכטה קטמרן מפרשית בחיפה – מדגם Lagoon 40</h1>
        <p>
          חוויית הפלגה שקטה וחלקה על קטמרן מפרשית יציבה המציעה מקסימום רווח
          ויוקרה אמיתית בים.
        </p>

        <h2>✨ שקט של מפרש ויוקרה של קטמרן</h2>
        <p>
          ליאכטות קטמרן מסוג מפרשית יש קסם מיוחד - הן מרחפות על המים ביציבות
          חסרת פשרות בשל שני הבידונים הענקיים שלהן. כשהמפרש עולה והמנועים
          דוממים, זוהי חוויית השקט והבריזה הטהורה של הים. הקטמרן שלנו מאובזרת
          בכל מה שצריך להפלגת שיא עם החברים או המשפחה, ואזורי שיזוף קדמיים
          מרגשים שישאירו טעם של עוד.
        </p>
        <p>
          יאכטה קטמרן מפרשית בעלת שני בידונים של חברת Lagoon הצרפתית<br />
          <strong>שנת יצור:</strong> 2020<br />
          <strong>אורך קטמרן:</strong> 12 מטר<br />
          הדגם כולל 4 קבינות שינה ו- 4 שירותים ומקלחות.
        </p>

        <Image
          src={img1}
          alt="יאכטה קטמרן מבחוץ"
          class="sp-gallery-img"
          style="aspect-ratio: 3/2; object-fit: cover;"
          format="webp"
        />

        <h2>💎 אידיאלית למשפחות וחגיגות</h2>
        <p>
          ספינה נוחה ומפנקת ומותאמת במיוחד להפלגות משפחתיות והפלגות חברים.
          מושלמת לאירועים וחגיגות.
        </p>
        <p>
          הרשת הקדמית והסיפון האחורי מרווחים ונוחים ומעניקים מרחב אידיאלי
          להתרווחות תחת קרני השמש, ואידיאלית לקבוצות של עד 14 מפליגים.
        </p>

        <Image
          src={midImg}
          alt="סיפון אלגנטי ויציב"
          class="sp-gallery-img"
          style="aspect-ratio: 3/2; object-fit: cover;"
          format="webp"
        />

        <h2>⭐ חוויה של פעם בחיים</h2>
        <p>
          השילוב של סיפון ענק, יציבות מקסימלית ותנאי מלון אמיתיים על הים, הופכים
          כל הפלגה על הקטמרן שלנו לחוויה עוצרת נשימה.
        </p>

        <Image
          src={botImg}
          alt="מבט נוסף על הקוקפיט"
          class="sp-gallery-img"
          style="aspect-ratio: 3/2; object-fit: cover;"
          format="webp"
        />

        <p class="sp-closing">
          רוצים להפליג? הקטמרן המפוארת מחכה לכם!<br />
          התקשרו להזמין עכשיו: 053-3403449
        </p>
      </div>

      <YachtVideoCard
        id="catamaran-sailing-haifa"
        videoUrl="https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20250512-WA0021_r5asfo.mp4"
        posterUrl="https://res.cloudinary.com/dmbdadurw/video/upload/so_1,f_auto,q_auto/VID-20250512-WA0021_r5asfo.jpg"
        videoName="Catamaran Sailing Lagoon 40 Haifa"
        videoDescription="יאכטה קטמרן מפרשית עד 14 משתתפים מחיפה"
        uploadDate={isoUploadDate}
        tagText="חיפה"
        tagColor="#d4a017"
        icon="⛵"
        title="מחירון יאכטה קטמרן מפרשית"
        note='* מחיר כולל מע"מ, תקף לסוף שבוע'
        whatsappNumber="972533403449"
        width="450"
        height="800"
        muted="true"
        ragHint="[מידע לבוט על קטמרן מפרשית חיפה] שם: קטמרן מפרשית (Lagoon 40). מיקום: חיפה. סוג: קטמרן מפרשית. קיבולת: עד 14 מפליגים. מחירון מקוצר: שעה 2,390₪, שעתיים 2,700₪, 3 שעות 3,690₪, שעה נוספת 990₪. המחיר כולל: סקיפר, שתייה מים, בלונים, שלט מזל טוב, מוזיקה (בלוטוס), ביטוח. בהפלגה של 3 שעות: ירידה לים עם אבוב. כאשר לקוח שואל על יאכטה זו, שלח לו את הקישור הישיר לדף: /catamaran-sailing. ציין שיש שם וידאו, תמונות ומחירון מלא."
      >
        <p><strong>מחירון השכרת קטמרן מפרשית:</strong></p>
        <ul class="pricing-list no-bullets">
          <li><strong>שעה הפלגה:</strong> 2,390 ₪</li>
          <li><strong>שעתיים הפלגה:</strong> 2,700 ₪</li>
          <li><strong>3 שעות הפלגה:</strong> 3,690 ₪</li>
          <li>כל שעה נוספת: 990 ₪</li>
          <li>👑 עד 14 מפליגים מאושרים</li>
        </ul>

        <h4 class="pricing-title">המחיר כולל:</h4>
        <ul class="pricing-list">
          <li>שלט מזל טוב</li>
          <li>בלונים בתוך היאכטה</li>
          <li>מוזיקה (רמקול בלוטוס)</li>
          <li>שתייה מים</li>
          <li>ביטוח לכל משתתף</li>
          <li>שירות של סקיפר מקצועי לאורך כל הדרך</li>
        </ul>

        <h4 class="pricing-title">בהזמנה של 3 שעות:</h4>
        <ul class="pricing-list">
          <li>ירידה לים עם אבוב 🌊</li>
        </ul>
      </YachtVideoCard>
      <PremiumSwitch
        href="/haifa"
        title="בחזרה ליאכטות חיפה"
        subtitle="לצפייה בצי שלנו ולבחירת היאכטה המושלמת"
      />
    </section>
  </div>
  <FleetSelectionCta
    ctaInstruction="נא להמשיך להזמנה או לצפות בעוד יאכטות בחיפה:"
  />

  <!-- Schema.org Data API -->
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      name: "יאכטה קטמרן מפרשית חיפה",
      description:
        "השכרת יאכטת קטמרן מפרשית במפרץ חיפה עד 14 מפליגים, כולל סקיפר, ירידה לים עם אבוב, בלונים ומוזיקה.",
      image: "https://aflagot-haifa.com/seo/seo-Leader-cruise.jpg",
      brand: { "@type": "Brand", name: "Leader שייט & הפלגות" },
      seller: {
        "@type": "TravelAgency",
        "@id": "https://aflagot-haifa.com/",
        name: "Leader שייט & הפלגות",
        legalName: "לידר",
        alternateName: [
          "Leader Haflagot",
          "לידר הפלגות שייט",
          "Leader Yachting",
        ],
        telephone: "+972533403449",
        url: "https://aflagot-haifa.com/",
        location: [
          {
            "@type": "Place",
            address: {
              "@type": "PostalAddress",
              streetAddress: "מרינה הרצליה",
              addressLocality: "הרצליה",
              addressCountry: "IL",
            },
            geo: {
              "@type": "GeoCoordinates",
              latitude: 32.162443,
              longitude: 34.796172,
            },
          },
          {
            "@type": "Place",
