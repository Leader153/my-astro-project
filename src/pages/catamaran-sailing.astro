        offerCount: "3",
        offers: [
          {
            "@type": "Offer",
            name: "הפלגה לשעה אחת",
            price: "2390",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/catamaran-sailing",
          },
          {
            "@type": "Offer",
            name: "הפלגה לשעתיים",
            price: "2700",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/catamaran-sailing",
          },
          {
            "@type": "Offer",
            name: "הפלגה ל-3 שעות",
            price: "3690",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/catamaran-sailing",
          },
        ],
      },
      subjectOf: {
        "@type": "VideoObject",
        name: "יאכטה קטמרן מפרשית חיפה",
        description: "יאכטה קטמרן מפרשית עד 14 משתתפים מחיפה",
        thumbnailUrl:
          "https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20250512-WA0021_r5asfo.jpg",
        contentUrl:
          "https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20250512-WA0021_r5asfo.mp4",
        uploadDate: isoUploadDate,
        embedUrl: "https://aflagot-haifa.com/catamaran-sailing",
      },
    })}
  />
</Layout>
