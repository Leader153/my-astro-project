---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import cardImg from "../assets/Birthday-party.png";
import mobileImg from "../assets/Birthday-party.png";
import img1 from "../assets/group-friends-toasting-drinks-yacht-haifa.webp";
import midImg from "../assets/birthday-celebration-yacht-cake-herzliya.webp";
import botImg from "../assets/friends-celebrating-yacht-party-haifa.webp";
import FleetSelectionCta from "../components/FleetSelectionCta.astro";
---

<Layout
  title="יום הולדת על יאכטה"
  description="תחגגו יום הולדת שלא תשכחו לעולם — ביאכטה פרטית עם כל החבריי"
>
  <div class="service-page" dir="rtl">
    <section class="sp-hero">
      <Image
        src={cardImg}
        widths={[768, 1280, 1920]}
        sizes="100vw"
        format="webp"
        alt="חגיגות יום הולדת על יאכטה בחיפה, קבוצת בנים בנות מרימים לי חיים"
        class="sp-hero-bg desktop-hero"
        loading="eager"
        fetchpriority="high"
      />
      <Image
        src={mobileImg}
        widths={[400, 768]}
        sizes="100vw"
        format="webp"
        alt="קבוצת חברים חוגגת ומרימה כוסית על סיפון יאכטה בחיפה"
        class="sp-hero-bg mobile-hero"
        loading="eager"
        fetchpriority="high"
      />
    </section>

    <section class="sp-content">
      <div class="sp-inner">
        <h1>השכרת יאכטה ליום הולדת - החגיגה המושלמת בים</h1>

        <p>
          בכל שנה מגיע התאריך הזה, ואיתו אותה השאלה ששוברת לנו את הראש: "איך
          נחגוג את יום ההולדת השנה?". אנחנו תמיד מחפשים משהו מיוחד, שונה, כזה
          שהחברים לא ישכחו. אנחנו רוצים להיות מוקפים באנשים שהכי קרובים אלינו,
          אבל בדרך כלל, הפקת אירוע כזה מסתכמת בהמון תכנונים, ארגונים, ולא מעט
          כאב ראש.
        </p>
        <p>
          כאן אנחנו נכנסים לתמונה! מסיבת יום הולדת על יאכטה היא הפתרון
          האולטימטיבי. אצלנו ב<span class="brand-leader"
            >לידר הפלגות &amp; שייט</span
          > השכרת יאכטות לא תצטרכו לשבור את הראש יותר. הדבר היחיד שאתם צריכים לעשות
          הוא להגיע אלינו ארוזים עם בגדי ים, חברים אהובים, וים של מצב רוח.
        </p>

        <Image
          src={img1}
          alt="קבוצת חברים צוחקים ומרימים כוסית על סיפון יאכטה בחיפה"
          class="sp-gallery-img"
        />

        <h2>
          למה לחגוג יום הולדת דווקא על היאכטות של <span class="brand-leader"
            >לידר הפלגות &amp; שייט</span
          >?
        </h2>
        <ul class="sp-list">
          <li>
            <strong>כי אנחנו דואגים להכל (ואתם באים ליהנות!):</strong> שכחו מלסחוב
            ציוד או לתכנן כל פרט. בכל הפלגה על אחת היאכטות שלנו נדאג שתהיה לכם חוויה
            בלתי נשכחת. נקשט עבורכם את היאכטה בבלונים חגיגיים, נדאג למערכת סאונד פצצה
            עם מוזיקה טובה, ונפנק אתכם בשתייה קלה וחמה חופשית. מחפשים קצת אקשן? על
            כל יאכטה ממתין לכם מזרון שיזוף בחרטום ואבוב לגרירה במי הים המרעננים!
          </li>
          <li>
            <strong>לוקיישנים מנצחים בהרצליה ובחיפה:</strong> היאכטות של <span
              class="brand-leader">לידר הפלגות &amp; שייט</span
            > עוגנות בשתי המרינות הבולטות בישראל – מרינה הרצליה ומרינה חיפה. הרציפים
            שלנו ממוקמים במיקומים מרכזיים עם גישה מהירה לטיילת ולמסעדות. בשתי המרינות
            יש גישה נוחה וקרובה מאוד מחניון רחב ידיים, כך שלא תצטרכו להיסחב לחינם
            עם אוכל ושתייה בחום הישראלי (פשוט חונים ועולים אל הסיפון!).
          </li>
          <li>
            <strong>יאכטות ברמה של חמישה כוכבים:</strong> היאכטות שלנו מטופחות, נקיות
            ומאובזרות במיוחד לצרכים שלכם. בכל יאכטה תמצאו מזגן מקפיא, שירותים חשמליים,
            מקלחת עם מים חמים, ומטבח מאובזר הכולל מקרר גדול.
          </li>
          <li>
            <strong>החברה המובילה לאירוח ימי:</strong> אנחנו ב<span
              class="brand-leader">לידר הפלגות &amp; שייט</span
            > חברה המתמחה באירוח קבוצות על יאכטות, והשמחה שלכם היא המקצוע שלנו. צורת
            החשיבה שלנו שמה אתכם במרכז – אנחנו כאן כדי להקשיב ולהגשים בדיוק את מה
            שאתם רוצים ביום ההולדת שלכם.
          </li>
          <li>
            <strong>צוות עם נשמה ושירות דיגיטלי חכם:</strong> אנו מעסיקים סקיפרים
            מנוסים שאוהבים את הים ואוהבים אנשים. האירוח זורם להם בעורקים, עם המון
            סבלנות ואהבה. בנוסף, חוויית השירות שלנו נוחה ודיגיטלית – את אישורי ההזמנה,
            הנחיות ההגעה, ותזכורות עם שם הסקיפר תקבלו אוטומטית לנייד טרם הפעילות,
            כך שהכל יהיה ברור, שקוף ופשוט.
          </li>
        </ul>

        <Image
          src={midImg}
          alt="חגיגת יום הולדת עם עוגה ושמפניה על יאכטה בהרצליה"
          class="sp-gallery-img"
        />

        <h2>מסיבת טבע בלב ים – בלי החול ובלי השכנים!</h2>
        <p>
          חושבים שיום הולדת על יאכטה זה עסק יקר? תתפלאו, אבל זו חוויה יוקרתית
          במחיר משתלם ונגיש להפליא!
        </p>
        <p>
          בכל מסיבת יום הולדת רגילה תמיד צצה בעיית הרעש – "לא להפריע לשכנים",
          "תחלישו את המוזיקה". אצלנו ב<span class="brand-leader"
            >לידר הפלגות &amp; שייט</span
          > הבעיה הזו פשוט לא קיימת! בלב ים אתם נמצאים לבד, ויכולים לשים את המוזיקה
          שלכם בפול ווליום. פשוט מתחברים למערכת שלנו (עם כבל AUX או בלוטות'), שמים
          פלייליסט מספוטיפיי או יוטיוב, ועפים על החיים יחד עם החברים.
        </p>
        <p>
          השילוב המושלם: מצד אחד אתם בים, נהנים מהבריזה ומהאוויר הפתוח, ומצד שני
          – אתם לא סובלים מהצפיפות של החוף. אין צורך להיסחב עם צידניות (יש
          מקרר!), לא צריך לחפש שירותים ציבוריים (יש שירותים צמודים ונקיים!),
          ואפילו לא צריך לקשט – כי אנחנו עשינו את זה בשבילכם. בסוף השכשוך בים
          תוכלו לשטוף את המלח במקלחת חמה ונעימה (עם מגבות נקיות בהזמנה מראש),
          ולחזור הביתה רעננים, נקיים ובלי גרגר אחד של חול.
        </p>

        <Image
          src={botImg}
          alt="קבוצת חברים מאושרים חוגגים יום הולדת ונהנים מבריזה על יאכטה בחיפה"
          class="sp-gallery-img"
        />

        <h2>חוויה שמתאימה לכל גיל</h2>
        <p>
          אצלנו ב<span class="brand-leader">לידר הפלגות &amp; שייט</span> מתאימים
          את סגנון יום ההולדת בדיוק לגיל שלכם:
        </p>
        <ul class="sp-list">
          <li>
            <strong>לילדים ולקטנים:</strong> נפיק חוויית פיראטים מלהיבה, בה ילד או
            ילדת יום ההולדת יהפכו לקפטן צעיר (והאמיצים אפילו יקבלו תעודת פיראט רשמית!).
          </li>
          <li>
            <strong>לגדולים ולמבוגרים:</strong> נרים מסיבה עם אווירה משוחררת, אלכוהול
            משובח (שאתם מביאים), ובריזה מחוזקת מהים שתרענן לכם את הנשמה.
          </li>
        </ul>
      </div>
    </section>

    <!-- ══ NEW GLOBAL CTA SECTION (GOLDEN FENCE) ══ -->
    <FleetSelectionCta
      ctaInstruction="נא להיכנס לעמוד יאכטות ולבחור את המתנה שלכם ליום ההולדת:"
    />
  </div>
</Layout>

