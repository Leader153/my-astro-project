---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import cardImg from "../assets/MeryMe.png";
import mobileImg from "../assets/MeryMe.png";
import img1 from "../assets/MeryMe.png";
import midImg from "../assets/marriage-proposal-couple-romantic-yacht-haifa.webp";
import botImg from "../assets/wedding-couple-sailing-yacht-sunset-haifa.webp";
import FleetSelectionCta from "../components/FleetSelectionCta.astro";
---

<Layout
  title="הצעת נישואין על יאכטה "
  description='ה" – הרגע שבו היא תגיד "כן!" הפתעה מושלמת, תפאורה רומנטית וכל הפינוקים כלול'
>
  <div class="service-page" dir="rtl">
    <!-- ══ HERO ══ -->
    <section class="sp-hero">
      <Image
        src={cardImg}
        widths={[768, 1280, 1920]}
        sizes="100vw"
        format="webp"
        alt="הצעת נישואים על יאכטה יוקרתית בהרצליה"
        class="sp-hero-bg desktop-hero"
        loading="eager"
        fetchpriority="high"
      />
      <!-- MOBILE HERO IMAGE -->
      <Image
        src={mobileImg}
        widths={[400, 768]}
        sizes="100vw"
        format="webp"
        alt="הצעת נישואים על יאכטה יוקרתית בהרצליה"
        class="sp-hero-bg mobile-hero"
        loading="eager"
        fetchpriority="high"
      />
    </section>

    <!-- CONTENT -->
    <section class="sp-content">
      <div class="sp-inner">
        <h1>💍 הצעת נישואין על יאכטה – הרגע שבו היא תגיד "כן!"</h1>

        <p>
          <strong
            >"אם הייתי יכול להיות בשני מקומות בפעם אחת, הייתי איתך ברגע אחד
            פעמיים..."</strong
          >
        </p>
        <p>
          דמיין את המבט המופתע והמתרגש בעיניה: אתם מוקפים בשקט של לב הים, רחש
          הגלים משתלב עם שיר רומנטי שאתם אוהבים, והבריזה מלטפת. פתאום, מול קו
          הרקיע העוצר נשימה והשקיעה הצבועה בכתום, נפתח שלט ענק עם המילים שמשנות
          את החיים: "התינשאי לי?". אתה כורע ברך, מביט עמוק בעיניה, ושניכם יודעים
          – זו האישה של חייך, וזה הרגע שבו אתם קושרים את גורלכם יחד.
        </p>

        <Image
          src={img1}
          alt="הצעת נישואים על יאכטה בחיפה"
          class="sp-gallery-img is-square is-wide"
        />

        <h3>ההפתעה המושלמת – בלי לחץ, אנחנו דואגים להכל!</h3>
        <p>
          אחרי כל החוויות שעברתם יחד, בטוב וברע, הגיע הרגע הגדול. אנחנו ב<strong
            >לידר הפלגות &amp; שייט</strong
          >, השכרת יאכטות, יודעים שהצעת נישואין היא אירוע של פעם בחיים, והאמת?
          זה יכול קצת להלחיץ.
        </p>
        <p>
          כאן אנחנו נכנסים לתמונה! הצוות המנוסה שלנו יעזור לך לבנות "סיפור
          כיסוי" מושלם ואמין שלא יעורר שום חשד. הסקיפר שלנו ישחק את המשחק למופת
          עד השנייה האחרונה, כדי להוריד ממך את כל הלחץ ולאפשר לך פשוט להתרגש יחד
          איתה.
        </p>

        <Image
          src={midImg}
          alt="הצעת נישואים רומנטית של זוג על יאכטה בחיפה"
          class="sp-gallery-img is-square is-wide"
        />

        <h3>📍 לבחירתכם: קסם על המים בחיפה או בהרצליה</h3>
        <p>
          כדי להתאים את החוויה בדיוק אליכם, הצי המפואר של לידר מחכה לכם בשני
          לוקיישנים מנצחים:
        </p>
        <ul class="sp-list">
          <li>
            <strong>מרינה הרצליה:</strong> קרוב למרכז, תוסס ומול חופי השרון המרהיבים.
          </li>
          <li>
            <strong>מרינה חיפה:</strong> רומנטיקה צפונית מהפנטת למרגלות הרי הכרמל.
          </li>
        </ul>

        <Image
          src={botImg}
          alt="זוג בהפגנת אהבה על יאכטה בזמן שקיעה רומנטית בהרצליה"
          class="sp-gallery-img is-wide"
        />

        <h3>🥂 יאכטה של חמישה כוכבים – כל הפינוקים כלולים</h3>
        <p>
          אנחנו נכין את היאכטה מראש ונדאג לתפאורה רומנטית עוצרת נשימה. מה מחכה
          לכם על הסיפון?
        </p>
        <ul class="sp-list">
          <li>
            <strong>אווירה ורומנטיקה:</strong> בקבוק יין איכותי, סוכריות ושוקולדים,
            ועיצוב רומנטי הכולל לב מעלי כותרת אדומים על המיטה בחדר השינה.
          </li>
          <li>
            <strong>נוחות מקסימלית:</strong> היאכטות שלנו ממוזגות ומאובזרות ברמת VIP.
            תמצאו בהן סלון מרווח, שני חדרי שינה, מטבח מלא, מקלחת ושירותים.
          </li>
          <li>
            <strong>אקשן ומוזיקה:</strong> מזרן שיזוף מפנק בחרטום היאכטה, אבוב לטבילה
            מרעננת בים (אם תרצו לקפוץ למים אחרי ההצעה!), ומערכת סאונד מתקדמת – פשוט
            חברו את הטלפון ושימו את הפלייליסט שלכם. שתייה חמה וקלה תוגש באופן חופשי.
          </li>
          <li>
            <strong>עיצוב חגיגי:</strong> בלונים, שלטי "מזל טוב" וקישוטים שיהפכו את
            היאכטה לחגיגה של אהבה.
          </li>
          <li>
            <strong>שדרוגים טעימים (בתוספת תשלום):</strong> רוצים להמשיך לחגוג? ניתן
            להזמין מראש ארוחת בוקר, צהריים או ערב מפנקת שתוגש לכם ישירות לסיפון.
          </li>
        </ul>

        <h3>📸 מזכרת לכל החיים</h3>
        <p>
          הצעת נישואין כזו חייבת להיות מתועדת! מעבר לחוויה הייחודית, אנחנו נדאג
          (בתיאום מראש בעת ההזמנה) שכל האירוע יצולם. נפיק עבורכם סרטון ערוך
          ומרגש ותמונות מדהימות, שיישארו כמתנה נפלאה ומזכרת מושלמת שתוכלו להראות
          בעתיד גם לילדים.
        </p>
      </div>
    </section>

    <!-- ══ NEW GLOBAL CTA SECTION (GOLDEN FENCE) ══ -->
    <FleetSelectionCta />
  </div>
</Layout>
