---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import cardImg from "../assets/large-family-celebration-yacht.webp";
import mobileImg from "../assets/large-family-celebration-yacht-herzelia.webp";
import img1 from "../assets/group-sitting-yacht-deck-haifa.png";
import midImg from "../assets/large-group-waving-on-yacht-deck-haifa.webp";
import botImg from "../assets/group-wearing-white-sitting-yacht-herzliya.webp";
import FleetSelectionCta from "../components/FleetSelectionCta.astro";
---

<Layout
  title="שייט קבוצתי על יאכטה"
  description="הפלגות לקבוצות – חוויית אירוח בסטנדרט בלתי מתפשר בלב ים."
>
  <div class="service-page" dir="rtl">
    <section class="sp-hero">
      <Image
        src={cardImg}
        alt="משפחה גדולה חוגגת עם עוגה ושמפניה על יאכטה בחיפה"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg desktop-hero"
      />
      <Image
        src={mobileImg}
        alt="משפחה גדולה חוגגת עם עוגה ושמפניה על יאכטה בחיפה"
        widths={[400, 768]}
        sizes="100vw"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg mobile-hero"
        style="object-position: 50% 50%;"
      />
    </section>

    <section class="sp-content">
      <div class="sp-inner">
        <h1>השכרת יאכטה לקבוצות - שייט והפלגות אירוח בלב ים</h1>

        <p>
          חברת <span class="brand-leader">לידר הפלגות &amp; שייט</span> השכרת יאכטות
          היא הכתובת שלכם לאירועים ואירוח קבוצות על גבי יאכטות יוקרתיות במרינה הרצליה
          ובמרינה חיפה. כל יאכטה בצי שלנו מאובזרת במלואה וכוללת סלון מרווח, חדרי שינה,
          מטבח, מקלחת ושירותים, לצד אבוב וציוד ספורט ימי שישדרגו לכם את החוויה במים.
        </p>
        <p>
          הלוקיישן שלנו פשוט מנצח: היאכטות שלנו עוגנות ממש מול טיילת המסעדות
          התוססת, אך ממוקמות ברציף סגור המיועד למורשים בלבד. השילוב הזה מעניק
          לכם את הטוב משני העולמות – מצד אחד אתם קרובים למרכז העניינים ולחנייה,
          ומצד שני אתם נהנים מאקסקלוסיביות ופרטיות מוחלטת לאורך כל השהות שלכם.
          כדי להתחיל את המסיבה ברגל ימין, כל אירוח אצלנו כולל בקבוק שמפניה גדול,
          פלייליסט מקפיץ, ואווירה שפשוט אין לה תחליף.
        </p>

        <Image
          src={img1}
          alt="קבוצת חברים יושבת על סיפון יאכטה בנמל חיפה"
          class="sp-gallery-img is-square"
          format="webp"
        />

        <h2>הפלגה קבוצתית – חגיגה מושלמת לכל גיל ולכל מטרה</h2>
        <p>
          אצלנו ב<span class="brand-leader">לידר הפלגות &amp; שייט</span> תוכלו להזמין
          יאכטה המותאמת לקבוצות של עד 40 חוגגים. אנחנו נדאג לכל המסביב כדי שאתם תבואו
          רק ליהנות – נקשט את הסיפון בבלונים ססגוניים ונציב שלטי "מזל טוב" או ברכות
          המותאמות בדיוק לסוג האירוע שלכם.
        </p>

        <Image
          src={midImg}
          alt="קבוצה גדולה של אנשים וילדים מנופפים לשלום על סיפון יאכטה בחיפה"
          class="sp-gallery-img is-square"
          format="webp"
        />

        <h2>לאילו אירועים זה מתאים?</h2>
        <p>השכרת יאכטה לקבוצה היא הפתרון האידיאלי למגוון רחב של אירועים:</p>
        <ul class="sp-list">
          <li>
            <strong>מסיבות יום הולדת:</strong> חגיגות בלתי נשכחות ומפנקות מול נוף
            הים.
          </li>
          <li>
            <strong>מסיבות רווקים ורווקות:</strong> לחגוג בלב ים, הרחק מההמולה.
          </li>
          <li>
            <strong>מסיבות גיוס ושחרור:</strong> רגעים של שמחה טהורה יחד עם כל החברים.
          </li>
          <li>
            <strong>מפגש חברים שובר שגרה:</strong> מול נוף הים הפתוח, בלי לחכות לסיבה
            מיוחדת.
          </li>
        </ul>

        <Image
          src={botImg}
          alt="קבוצת אנשים לבושים בלבן יושבים על דופן של יאכטה בהרצליה"
          class="sp-gallery-img is-square"
          format="webp"
        />

        <h2>שייט משפחתי – זמן איכות מגבש שכולם יאהבו</h2>
        <p>
          בעידן שבו כולם מחוברים למסכים והשגרה היומיומית לוחצת, מתי בפעם האחרונה
          יצא לכם לבלות זמן איכות משפחתי אמיתי, נטו אחד עם השני? אצלנו ב<span
            class="brand-leader">לידר הפלגות &amp; שייט</span
          > השכרת יאכטות, מצאנו את הנוסחה המושלמת לפעילות שגם הילדים הקטנים, גם המתבגרים
          ואפילו סבא וסבתא יעופו עליה!
        </p>
        <p>
          שייט משפחתי על יאכטה הוא הרבה יותר מסתם אטרקציה – זו חוויה מגבשת
          שמוציאה את כולם מהשגרה ומכניסה המון שמחה ואנרגיות טובות. במקום ללכת
          לים, לחפש חניה, לסחוב צידניות ולהצטופף בחום עם עוד אלפי אנשים, אתם
          מקבלים "אי פרטי" משלכם בלב הים, עם כל הנוחות האפשרית.
        </p>

        <h2>
          למה משפחות בוחרות להפליג איתנו ב"<span class="brand-leader"
            >לידר הפלגות &amp; שייט</span
          >"?
        </h2>
        <ul class="sp-list">
          <li>
            <strong>בטיחות לפני הכל:</strong> הסקיפרים המקצועיים שלנו מיומנים באירוח
            משפחות וילדים. היאכטות בטוחות, מאובזרות בכל ציוד הבטיחות הנדרש (כולל חגורות
            הצלה לכל גיל), והסקיפר ידאג לכל פרט כדי שאתם, ההורים, תוכלו סוף סוף להישען
            לאחור ולהירגע.
          </li>
          <li>
            <strong>אטרקציות שיעייפו את הילדים (בקטע טוב!):</strong> בזמן שאתם משתזפים
            על הסיפון עם כוס שתייה קרה, הילדים יוכלו ליהנות מקפיצות למים, שכשוך מרענן,
            וגרירה על אבוב חווייתי (בהתאם לתנאי הים). הקטנטנים יוכלו אפילו "לעזור"
            לסקיפר להחזיק את ההגה ולהרגיש כמו קפטנים אמיתיים!
          </li>
          <li>
            <strong>נוחות של בית מלון:</strong> לא צריך לוותר על הנוחות. ביאכטות של
            <span class="brand-leader">לידר הפלגות &amp; שייט</span> תמצאו אזור מוצל
            לארוחה משפחתית, מקרר גדול לאחסון החטיפים והאוכל שהבאתם, סלון ממוזג למקרה
            שרוצים קצת הפסקה מהשמש, ומקלחת ושירותים נקיים כדי שתחזרו הביתה רעננים
            וללא טיפת חול.
          </li>
          <li>
            <strong>מתאים לכל אירוע משפחתי:</strong> בין אם אתם חוגגים יום הולדת לסבא,
            בר/בת מצווה באווירה אינטימית, או פשוט רוצים לפנק את המשפחה בשבת בבוקר
            או בשעות השקיעה המרהיבות – אנחנו נתאים את ההפלגה בדיוק לאופי של המשפחה
            שלכם.
          </li>
        </ul>

        <br />
        <h2>כל יום הוא הזדמנות לשבור שגרה</h2>
        <p>
          אנחנו מאמינים שלא חייבים לחכות לתאריך מיוחד – כל יום הוא הזדמנות
          מצוינת לצאת לים, להתנתק מהשגרה, ולייצר חוויות חדשות עם האנשים שאתם הכי
          אוהבים.
        </p>
      </div>
    </section>
  </div>
  <FleetSelectionCta
    ctaInstruction="צפו בצי היאכטות שלנו ותבחרו את היאכטה לקבוצה שלכם:"
  />
</Layout>

