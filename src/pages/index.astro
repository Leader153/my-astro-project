---
import '../styles/index-page.css';
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import FleetSelectionCta from '../components/FleetSelectionCta.astro';
import cardImg from '../assets/romantic-cruise-2.webp';
import bacheloretteImg from '../assets/large-group-bachelorette-party-yacht-haifa.webp';
import birthdayImg from '../assets/Birthday-party-on-the-yach.webp';
import familyImg from '../assets/large-family-celebration-yacht.webp';
import corporateImg from '../assets/employees-teambuilding-group-on-boat-herzliya.webp';
import cyprusImg from '../assets/sail-with-me.webp';
import proposalImg from '../assets/romantic-marriage-proposal-yacht-sunset.webp';
import fishingImg from '../assets/original-high-res.png';
import skiperImg from '../assets/skipper-for-a-day-learning-to-steer-yacht.jpeg';

const services = [
  {
    icon: '💑',
    title: 'שייט, ארוחה רומנטית לזוג',
    desc: 'רגעים קסומים לשניים. שקיעה, כוכבים ורוח ים — החל מ-600 ₪',
    tag: 'לזוגות',
    color: '#e91e8c',
    href: '/romantic-sailing',
    alt: 'זוג מאושר על יאכטה בשקיעה רומנטית בים התיכון',
  },
  {
    icon: '🎉',
    title: 'מסיבת רווקות',
    desc: 'מסיבה בלתי נשכחת על הסיפון עם חברים. אלכוהול, מוסיקה והרבה כיף',
    tag: 'פופולרי',
    color: '#7c3aed',
    href: '/bachelor-party',
    alt: 'קבוצת חברים חוגגת מסיבת רווקות על יאכטה פרטית',
    img: bacheloretteImg,
  },
  {
    icon: '🎂',
    title: 'יום הולדת על יאכטה',
    desc: 'תחגגו יום הולדת שלא תשכחו לעולם — ביאכטה פרטית עם כל החברים',
    tag: 'מומלץ',
    color: '#d4a017',
    href: '/birthday',
    alt: 'חגיגות יום הולדת על יאכטה בחיפה, קבוצת בנים בנות מרימים לי חיים',
    img: birthdayImg,
  },
  {
    icon: '👔',
    title: 'גיבוש ואירועי חברה',
    desc: 'ימי גיבוש לעובדים ואירוח עסקי ביאכטה — חוויה שתחזק את הצוות',
    tag: 'עסקי',
    color: '#0f7ab0',
    href: '/team-building',
    alt: 'צוות עובדים ביום גיבוש על יאכטה עם נוף ים',
    img: corporateImg,
  },
  {
    icon: '👨‍👩‍👧‍👦',
    title: 'הפלגה משפחתית',
    desc: 'יום בים עם כל המשפחה — בטוח, מהנה ובלתי נשכח לכל הגילאים',
    tag: 'משפחות',
    color: '#059669',
    href: '/group-sailing',
    alt: 'משפחה שמחה עם ילדים נהנים מהפלגה ביאכטה בים',
    img: familyImg,
  },
  {
    icon: '💍',
    title: 'הצעת נישואין',
    desc: 'הפתיעו את האהוב/ה שלכם ביאכטה — רגע שתזכרו לכל החיים',
    tag: 'מיוחד',
    color: '#e91e8c',
    href: '/marriage-proposal',
    alt: 'גבר כורע ברך ומציע נישואים על סיפון יאכטה בשקיעה בחיפה',
    img: proposalImg,
  },
  {
    icon: '🎣',
    title: 'הפלגת דייג ללא צורך ברישיון',
    desc: 'חוויית דייג מהנה בלב ים, ציוד מקצועי עלינו — פשוט לבוא וליהנות',
    tag: 'אטרקציה',
    color: '#0ea5e9',
    href: '/fishing',
    alt: 'קבוצה בהפלגת דייג על יאכטה במרינה',
    img: fishingImg,
    imgStyle: 'object-position: right;',
  },
  {
    icon: '⛵',
    title: 'הפלגת סקיפר ליום אחד',
    desc: 'יום שלם בים עם סקיפר מקצועי — שיזוף, נוף, מוזיקה ויין. חוויה מהסרטים',
    tag: 'פופולרי',
    color: '#7c3aed',
    href: '/skipper-day-cruise',
    alt: 'הפלגה ביאכטה עם סקיפר מקצועי ליום אחד',
    img: skiperImg,
  },
  {
    icon: '🌍',
    title: 'שייט לקפריסין',
    desc: 'הפלגה ממושכת לאי השכן — חופשה חלומית, בטוחה ובלתי נשכחת מחוץ לגבולות',
    tag: 'חו״ל',
    color: '#8b5cf6',
    href: '/cyprus-cruise',
    alt: 'יאכטה בלב ים בדרכה לקפריסין עם נוף פנורמי',
    img: cyprusImg,
  },
];

const features = [
  { icon: '⭐', title: '10+ שנות ניסיון', desc: 'מאז 2011, מאות הפלגות מאושרות' },
  { icon: '⛵', title: 'צי של 18 יאכטות', desc: 'יאכטות ברמת פאר גבוהה לכל תקציב' },
  { icon: '👨‍✈️', title: 'סקיפרים מוסמכים', desc: 'מקצועיים, אוהבי ים ושירותיים' },
  { icon: '🛡️', title: 'בטיחות מקסימלית', desc: 'מבוטחים, מאובזרים וזמינים 24/7' },
  { icon: '📍', title: 'חיפה + הרצליה', desc: 'שתי מרינות —  במיקום נוח ונגיש אליכם' },
  { icon: '💰', title: 'מחיר הוגן', desc: 'איכות יוקרה במחיר שמתאים לכולם' },
];

const testimonials = [
  {
    name: 'שירה כ.',
    event: 'מסיבת רווקות',
    stars: 5,
    text: 'חוויה מטורפת! הסקיפר היה מדהים, היאכטה יפהפייה והארגון ברמה אחרת. כל החברות עוד מדברות על זה!',
    avatar: 'ש',
  },
  {
    name: 'דניאל מ.',
    event: 'יום הולדת',
    stars: 5,
    text: 'הזמנו ליום הולדת ה-40 שלי — פשוט wow. שירות אישי, תשומת לב לפרטים, ורגעים שלא אשכח.',
    avatar: 'ד',
  },
  {
    name: 'איתי ו.',
    event: 'גיבוש חברה',
    stars: 5,
    text: 'גיבוש חברה מושלם! הצוות היה מקצועי ואירח אותנו ברמה גבוהה מאוד. ממליץ בחום לכל חברה.',
    avatar: 'א',
  },
];
---

<Layout 
  title="השכרת יאכטות בהרצליה וחיפה - הפלגות יוקרה | Leader הפלגות"
  description="מחפשים יאכטה להשכרה?🐬 Leader הפלגות מציעה שייט ביאכטה פרטית בחיפה ובהרצליה לאירועים, מסיבות, ימי הולדת והפלגות רומנטיות🥂. שירות יוקרתי ומחירים הוגנים. היכנסו עכשיו!">
<div class="home-page" dir="rtl">

  <!-- ══════════════════════════════════════
       HERO — Full Screen
  ══════════════════════════════════════ -->
  <section class="hero" aria-label="כותרת ראשית">
    <!-- Video/gradient bg -->
    <div class="hero-bg">
      <div class="hero-gradient"></div>
      <div class="hero-waves-anim" aria-hidden="true">
        <div class="wave-anim w1"></div>
        <div class="wave-anim w2"></div>
        <div class="wave-anim w3"></div>
      </div>
    </div>

    <div class="hero-inner">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        חיפה · הרצליה · 24/7
      </div>

      <div class="new-hero-title">
        <span class="nh-sub" style="font-size: clamp(1.4rem, 4vw, 2rem); margin-bottom: 5px;">הדרך אל האושר</span>
        <span class="nh-main" dir="ltr">LEADER</span>
        <span class="nh-sub" style="font-size: clamp(1.4rem, 4vw, 2rem); margin-top: 5px; margin-bottom: 20px;">הפלגות & שייט</span>
        <span class="nh-sub" style="color: #a8d5ff; font-weight: 500;">בקו האופק אתה תראה רק מה שבא לך לראות</span>
      </div>

      <h1 class="hero-desc new-hero-desc">
        <span class="nh-big">השכרת יאכטות בהרצליה וחיפה</span>
        <span class="nh-location">הפלגות יוקרה ושייט ביאכטה פרטית</span>
      </h1>

      <div class="hero-actions">
        <a href="/contact" class="hero-btn primary">
          קבלו הצעת מחיר
          <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="18" height="18"><polyline points="15 18 9 12 15 6"/></svg>
        </a>
        <a href="https://wa.me/972533403449" class="hero-btn wa-solid" target="_blank" rel="noopener">
          <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>

    </div>


  </section>

  <!-- ══════════════════════════════════════
       SERVICES — Card Grid
  ══════════════════════════════════════ -->
  <section class="services-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="eyebrow">בחרו את ההפלגה שלכם</div>
        <h2>השכרת יאכטה לכל אירוע — הפלגה מושלמת</h2>
        <div class="intro-highlight">
          <p class="ih-main">
            מגוון חבילות לכל מטרה — מזוגות שמחפשים רומנטיקה ועד קבוצות גדולות לאירוע בלתי נשכח
          </p>
          <div class="ih-divider"></div>
          <p class="ih-sub">
            <strong>מזמינים אתכם לאווירה כיפית</strong><br/>
            מוזיקה, ים . הנאה מובטחת<br/>
            צבירת חוויה בלתי נשכחת<br/>
            וכמובן מלא מצב רוח טוב
          </p>
        </div>
      </div>

      <div class="services-grid">
        {services.slice(0, 3).map((s, i) => (
          <a href={s.href} class="service-card" style={`--c:${s.color}; --i:${i}`}>
            <!-- Card image -->
            <div class="sc-img-wrap">
              <Image
                src={s.img || cardImg}
                width={600}
                height={400}
                format="webp"
                alt={s.alt}
                class="sc-img"
                loading={i < 3 ? 'eager' : 'lazy'}
              />
              <div class="sc-tag" style={`background:${s.color}; color:#fff`}>{s.tag}</div>
            </div>
            <!-- Card body -->
            <div class="sc-body">
              <div class="sc-icon">{s.icon}</div>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
              <div class="sc-arrow" style={`color:${s.color}`}>
                קבלו פרטים
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="15" height="15"><polyline points="15 18 9 12 15 6"/></svg>
              </div>
            </div>
            <div class="sc-glow" style={`background:${s.color}`}></div>
          </a>
        ))}
      </div>

      <div class="mid-text-blocks">
        <div class="mt-block">
          <div>
            <span style="display:block; font-size: 1.1rem; color: var(--sea); margin: 0 0 0.5rem; font-weight: 900;">הכול מתחיל בבחירה מסוימת</span>
            <p>האירוע ביאכטה שתשנה את הרגע ותהפוך את הרגעים המרגשים ביותר בחייכם למשהו מיוחד !</p>
          </div>
        </div>
        <div class="mt-block">
          <div>
            <span style="display:block; font-size: 1.1rem; color: var(--sea); margin: 0 0 0.5rem; font-weight: 900;">אצלנו תוכלו למצוא</span>
            <p>
              השכרת יאכטה — מגוון של יאכטות<br/>
              וספינות לאירועים שלכם<br/>
              בין הפלגה רומנטית לזוג או שייט עם משפחה<br/>
              ביאכטה מפרשית קטנה לזוג מפליגים<br/>
              עד יאכטה מפוארת מדהימה עד 40 מפליגים
            </p>
          </div>
        </div>
        <div class="mt-block">
          <div>
            <span style="display:block; font-size: 1.1rem; color: var(--sea); margin: 0 0 0.5rem; font-weight: 900;">ניתן להזמין מבחר מנות</span>
            <p>
              מהתפריט שלנו<br/>
              או להביא איתכם בחיפה או בהרצליה
            </p>
          </div>
        </div>
      </div>

      <div class="services-grid">
        {services.slice(3, 6).map((s, i) => (
          <a href={s.href} class="service-card" style={`--c:${s.color}; --i:${i + 3}`}>
            <!-- Card image -->
            <div class="sc-img-wrap">
              <Image
                src={s.img || cardImg}
                width={600}
                height={400}
                format="webp"
                alt={s.alt}
                class="sc-img"
                loading="lazy"
              />
              <div class="sc-tag" style={`background:${s.color}; color:#fff`}>{s.tag}</div>
            </div>
            <!-- Card body -->
            <div class="sc-body">
              <div class="sc-icon">{s.icon}</div>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
              <div class="sc-arrow" style={`color:${s.color}`}>
                קבלו פרטים
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="15" height="15"><polyline points="15 18 9 12 15 6"/></svg>
              </div>
            </div>
            <div class="sc-glow" style={`background:${s.color}`}></div>
          </a>
        ))}
      </div>

      <div class="mt-block" style="margin-top: 3rem; max-width: 800px; margin-left: auto; margin-right: auto;">
        <p>
          <strong>מבחינתנו השירות מתחיל בעודכם קוראים שורות אלו,</strong><br/>
          ממשיך בשיחת הטלפון שבה נשמע אתכם, נכיר אתכם, מה אתם חולמים וכיצד ניתן<br/>
          להגשים את רצונכם ולהתאים לכם חווית שייט חלומית ואישית בדיוק עבורכם.<br/>
          שייט ביאכטה פרטית עם הפלגות לזוגות, משפחות וקבוצות —<br/>
          נוף ים קסום ופינוק מושלם שלא תשכחו לעולם
        </p>
      </div>

      <div class="services-grid" style="margin-top: 3rem;">
        {services.slice(6, 9).map((s, i) => (
          <a href={s.href} class="service-card" style={`--c:${s.color}; --i:${i + 6}`}>
            <!-- Card image -->
            <div class="sc-img-wrap">
              <Image
                src={s.img || cardImg}
                width={600}
                height={400}
                format="webp"
                alt={s.alt}
                class="sc-img"
                loading="lazy"
                style={s.imgStyle}
              />
              <div class="sc-tag" style={`background:${s.color}; color:#fff`}>{s.tag}</div>
            </div>
            <!-- Card body -->
            <div class="sc-body">
              <div class="sc-icon">{s.icon}</div>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
              <div class="sc-arrow" style={`color:${s.color}`}>
                קבלו פרטים
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="15" height="15"><polyline points="15 18 9 12 15 6"/></svg>
              </div>
            </div>
            <div class="sc-glow" style={`background:${s.color}`}></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       WHY US — Feature Strip
  ══════════════════════════════════════ -->
  <section class="why-section">
    <div class="why-bg" aria-hidden="true"></div>
    <div class="section-inner">
      <div class="section-header light">
        <div class="eyebrow light">למה לבחור בנו</div>
        <h2>Leader הפלגות — שייט והפלגות יוקרה בחיפה והרצליה</h2>
      </div>
      <div class="features-grid">
        {features.map((f, i) => (
          <div class="feature-card" style={`--i:${i}`}>
            <div class="fc-icon">{f.icon}</div>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FleetSelectionCta />

  <!-- ══════════════════════════════════════
       LOCATIONS — 2-col split
  ══════════════════════════════════════ -->
  <section class="locations-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="eyebrow">אנחנו נמצאים ב</div>
        <h2>הפלגות בשתי מרינות — הרצליה וחיפה</h2>
      </div>
      <div class="locations-split">
        <div class="loc-card herzliya">
          <div class="loc-emoji">🌊</div>
          <h3>הרצליה</h3>
          <p>מרינה הרצליה<br/>רציף E מול שער A — קניון ארנה</p>
          <a href="https://maps.google.com/?q=32.162443,34.796172" target="_blank" rel="noopener" class="loc-map-btn">פתח במפה ↗</a>
        </div>
        <div class="loc-divider" aria-hidden="true">
          <span>+</span>
        </div>
        <div class="loc-card haifa">
          <div class="loc-emoji">⚓</div>
          <h3>חיפה</h3>
          <p>פארק קישון – מעגנת שביט<br/>רחוב הדייגים 3</p>
          <a href="https://maps.google.com/?q=32.8069075,35.0322383" target="_blank" rel="noopener" class="loc-map-btn">פתח במפה ↗</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       TESTIMONIALS
  ══════════════════════════════════════ -->
  <section class="testimonials-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="eyebrow">מה אומרים עלינו</div>
        <h2>המלצות על שייט ביאכטה של Leader הפלגות</h2>
      </div>
      <div class="testimonials-grid">
        {testimonials.map((t, i) => (
          <div class="testimonial-card" style={`--i:${i}`}>
