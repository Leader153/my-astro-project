---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import mobileImg from "../assets/dolfin-catamara-herzelia.jpg";
import img1 from "../assets/Dolfin-peple.jpeg";
import midImg from "../assets/catamaran21.jpg";
import heroImage from "../assets/Dolfin.jpeg";
import FleetSelectionCta from "../components/FleetSelectionCta.astro";
import PremiumSwitch from "../components/PremiumSwitch.astro";
---

<Layout
  title="יאכטה קטמרן דולפין | עד 21 מפליגים"
  description="יאכטה קטמרן דולפין עד 21 מפליגים. מתאימה לשייט משפחות, חברים, מסיבות. יאכטה מרווחת עם ספסלים מרופדים."
>
  <div class="service-page" dir="rtl">
    <section class="sp-hero">
      <Image
        src={heroImage}
        alt="יאכטה קטמרן דולפין"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg desktop-hero"
      />
      <Image
        src={mobileImg}
        alt="יאכטה קטמרן דולפין"
        widths={[400, 768]}
        sizes="100vw"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg mobile-hero"
        style="object-position: center top;"
      />
    </section>

    <section class="sp-content">
      <div class="sp-inner">
        <h1>⚓ יאכטה קטמרן- דולפין - dolphin</h1>
        <p>
          יאכטה קטמרן עד 21 מפליגים (לא כולל צוות)<br />
          מתאימה לשייט משפחות, חברים, מסיבות ...
        </p>

        <h3>✨ יאכטה מרווחת ונוחה לאירוע שלכם</h3>
        <p>
          היאכטה היא קטמרן מרווחת באורך 12 מטר, יציבה ונוחה עם ספסלי ישיבה
          מרופדים ויפים, ושולחן ענק מגודר מסביב.
        </p>
        <p>
          על הסיפון תמצאו אווירה מקושטת וחגיגית הכוללת <strong
            >שלט מזל טוב גדול, לוכדי חלומות לבנים, וכריות נוחות</strong
          > המבטיחים פינוק מושלם לאורך כל ההפלגה.
        </p>

        <Image
          src={img1}
          alt="מסיבה על הקטמרן"
          class="sp-gallery-img"
          style="aspect-ratio: 3/2; object-fit: cover;"
          format="webp"
        />

        <h3>🎉 אבזור, מערכות ואטרקציות במים</h3>
        <ul class="sp-list">
          <li>
            <strong>מוזיקה ואווירה:</strong> מערכת הגברה איכותית עם חיבור בלוטוס,
            ומיקרופונים שתוכלו לשיר ולחגוג.
          </li>
          <li>
            <strong>קפיצה למים:</strong> מזרן ים גדול, סאפ, חגורות ציפה וגלגלי הצלה
            עומדים לרשותכם.
          </li>
          <li>
            <strong>נוחות וציוד:</strong> היאכטה כוללת שירותים לנוחות המפליגים וביאכטה
            יש צידניות לשמירת השתייה והאוכל שלכם.
          </li>
        </ul>

        <Image
          src={midImg}
          alt="צוות הקטמרן דולפין"
          class="sp-gallery-img"
          style="aspect-ratio: 3/2; object-fit: cover;"
          format="webp"
        />

        <h3>👨‍✈️ צוות מקצועי לשירותכם</h3>
        <p>
          שלושה אנשי צוות מסורים המלווים אתכם ונותנים שירות אישי במהלך השייט.
          אנו נדאג שתרגישו הכי בנוח שאפשר.
        </p>

        <p class="sp-closing">
          חוגגים אירוע? התקשרו להזמין עכשיו: 053-3403449 (דניאל)
        </p>
      </div>

      <div class="services-grid">
        <a
          href="https://wa.me/972533403449"
          class="service-card"
          style="--c:#0ea5e9; --i:0"
          target="_blank"
        >
          <div class="sc-img-wrap">
            <Image
              src={heroImage}
              width={600}
              height={400}
              format="webp"
              alt="יאכטה קטמרן דולפין"
              class="sc-img"
              loading="lazy"
              style="object-position: right;"
            />
            <div class="sc-tag" style="background:#0ea5e9; color:#fff">
              הפלגת קטמרן
            </div>
          </div>
          <div class="sc-body">
            <div class="sc-icon">⛵</div>
            <h3>יאכטה קטמרן דולפין</h3>
            <p>
              <strong>מחירון שייט עם סקיפר:</strong><br />
              1 שעה הפלגה: 1850 ₪<br />
              שעתיים הפלגה: 2650 ₪<br />
              3 שעות הפלגה: 3300 ₪<br />
              👑 עד 21 מפליגים מאושרים<br />
              <span style="font-size: 0.85em; opacity: 0.9;"
                >* המחיר תקף לסוף שבוע</span
              >
            </p>
            <div class="sc-arrow" style="color:#0ea5e9">
              להזמנה בוואטסאפ
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                width="15"
                height="15"><polyline points="15 18 9 12 15 6"></polyline></svg
              >
            </div>
          </div>
        </a>
      </div>

      <PremiumSwitch
        href="/yachts-herzliya"
        title="חזרה לעמוד יאכטות הרצליה "
        subtitle="לחצו לעמוד היאכטות ותאמו הפלגה"
      />
    </section>
  </div>
  <FleetSelectionCta
    ctaInstruction="נא להיכנס לעמוד יאכטות ולתאם את ההפלגה שלכם:"
  />
</Layout>
