---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import mobileImg from "../assets/dolfin-catamara-herzelia.jpg";
import img1 from "../assets/Dolfin-peple.jpeg";
import midImg from "../assets/catamaran21.jpg";
import heroImage from "../assets/Dolfin.jpeg";
import FleetSelectionCta from "../components/FleetSelectionCta.astro";
import PremiumSwitch from "../components/PremiumSwitch.astro";
import YachtVideoCard from "../components/YachtVideoCard.astro";
const isoUploadDate = new Date("2026-03-14").toISOString();
import "../styles/pricing-card.css";
---

<Layout
  title="יאכטה קטמרן דולפין (עד 21 איש) הרצליה | Leader הפלגות"
  description="השכרת יאכטה קטמרן דולפין במרינה הרצליה לעד 21 מפליגים. החל מ-1,990 ₪ לשעה. יאכטה מרווחת וסופר-יציבה למסיבות ומשפחות. כולל סקיפר מקצועי ומוזיקה."
>
  <div class="service-page" dir="rtl">
    <section class="sp-hero">
      <Image
        src={heroImage}
        alt="יאכטה קטמרן דולפין"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg desktop-hero"
      />
      <Image
        src={mobileImg}
        alt="יאכטה קטמרן דולפין"
        widths={[400, 768]}
        sizes="100vw"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg mobile-hero"
        style="object-position: center top;"
      />
    </section>

    <section class="sp-content">
      <div class="sp-inner">
        <h1>השכרת יאכטה קטמרן דולפין בהרצליה – עד 21 איש</h1>
        <p>
          יאכטה קטמרן עד 21 מפליגים (לא כולל צוות)<br />
          מתאימה לשייט משפחות, חברים, מסיבות ...
        </p>

        <h2>✨ יאכטה מרווחת ונוחה לאירוע שלכם</h2>
        <p>
          היאכטה היא קטמרן מרווחת באורך 12 מטר, יציבה ונוחה עם ספסלי ישיבה
          מרופדים ויפים, ושולחן ענק מגודר מסביב.
        </p>
        <p>
          על הסיפון תמצאו אווירה מקושטת וחגיגית הכוללת <strong
            >שלט מזל טוב גדול, לוכדי חלומות לבנים, וכריות נוחות</strong
          > המבטיחים פינוק מושלם לאורך כל ההפלגה.
        </p>

        <Image
          src={img1}
          alt="מסיבה על הקטמרן"
          class="sp-gallery-img"
          style="aspect-ratio: 3/2; object-fit: cover;"
          format="webp"
        />

        <h2>🎉 אבזור, מערכות ואטרקציות במים</h2>
        <ul class="sp-list">
          <li>
            <strong>מוזיקה ואווירה:</strong> מערכת הגברה איכותית עם חיבור בלוטוס,
            ומיקרופונים שתוכלו לשיר ולחגוג.
          </li>
          <li>
            <strong>קפיצה למים:</strong> מזרן ים גדול, סאפ, חגורות ציפה וגלגלי הצלה
            עומדים לרשותכם.
          </li>
          <li>
            <strong>נוחות וציוד:</strong> היאכטה כוללת שירותים לנוחות המפליגים וביאכטה
            יש צידניות לשמירת השתייה והאוכל שלכם.
          </li>
        </ul>

        <Image
          src={midImg}
          alt="צוות הקטמרן דולפין"
          class="sp-gallery-img"
          style="aspect-ratio: 3/2; object-fit: cover;"
          format="webp"
        />

        <h2>👨‍✈️ צוות מקצועי לשירותכם</h2>
        <p>
          שלושה אנשי צוות מסורים המלווים אתכם ונותנים שירות אישי במהלך השייט.
          אנו נדאג שתרגישו הכי בנוח שאפשר.
        </p>

        <p class="sp-closing">
          חוגגים אירוע? התקשרו להזמין עכשיו: 053-3403449 (דניאל)
        </p>
      </div>

      <YachtVideoCard
        id="catamaran-dolfin-herzliya"
        videoUrl="https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20250608-WA0048_aku3qj.mp4"
        posterUrl="https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20250608-WA0048_aku3qj.jpg"
        videoName="Catamaran Dolfin Herzliya"
        videoDescription="יאכטה קטמרן עד 21 משתתפים מהרצליה"
        uploadDate={isoUploadDate}
        tagText="הפלגת קטמרן"
        tagColor="#0ea5e9"
        icon="⛵"
        title="מחירון יאכטה קטמרן דולפין"
        note='* מחיר כולל מע"מ, תקף לסוף שבוע'
        whatsappNumber="972533403449"
        ragHint="[מידע לבוט על קטמרן דולפין] שם: קטמרן דולפין. מיקום: הרצליה. סוג: קטמרן. קיבולת: עד 21 מפליגים (לא כולל צוות). מחירון מקוצר: שעה 1,990₪, שעתיים 2,550₪, 3 שעות 3,590₪, שעה נוספת 990₪. המחיר כולל: צוות מקצועי וסקיפר, שלט מזל טוב, מוזיקה (בלוטוס), ביטוח. בהפלגה של שעתיים ומעלה: ירידה לים עם אבוב. כאשר לקוח שואל על יאכטה זו, שלח לו את הקישור הישיר לדף: /catamaran-21. ציין שיש שם וידאו, תמונות ומחירון מלא."
      >
        <p><strong>מחירון השכרת קטמרן דולפין:</strong></p>
        <ul class="pricing-list no-bullets">
          <li><strong>שעה הפלגה:</strong> 1,990 ₪</li>
          <li><strong>שעתיים הפלגה:</strong> 2,550 ₪</li>
          <li><strong>3 שעות הפלגה:</strong> 3,590 ₪</li>
          <li>כל שעה נוספת: 990 ₪</li>
          <li>👑 מתאים לעד 21 מפליגים (לא כולל צוות)</li>
        </ul>

        <h4 class="pricing-title">המחיר כולל:</h4>
        <ul class="pricing-list">
          <li>שלט מזל טוב</li>
          <li>מוזיקה (רמקול בלוטוס)</li>
          <li>ביטוח לכל משתתף</li>
          <li>שירות של סקיפר וצוות מקצועי לאורך כל הדרך</li>
        </ul>

        <h4 class="pricing-title">בהזמנה של שעתיים:</h4>
        <ul class="pricing-list">
          <li>ירידה לים עם אבוב 🌊</li>
        </ul>
      </YachtVideoCard>
  <style is:global>
  /* Теперь ID точно совпадает с тем, что в YachtVideoCard */
  #catamaran-dolfin-herzliya .yvc-img-wrap {
    aspect-ratio: 3 / 2 !important; 
    height: auto !important;
  }

  /* Чтобы видео красиво заполняло новую горизонтальную область и не сплющивалось */
  #catamaran-dolfin-herzliya .cloudinary-video-facade,
  #catamaran-dolfin-herzliya .cloudinary-video-facade video {
    object-fit: cover !important; 
  }
</style>
      <PremiumSwitch
        href="/yachts-herzliya"
        title="חזרה לעמוד יאכטות הרצליה "
        subtitle="לחצו לעמוד היאכטות ותאמו הפלגה"
      />
    </section>
  </div>
  <FleetSelectionCta
    ctaInstruction="נא להיכנס לעמוד יאכטות ולתאם את ההפלגה שלכם:"
  />

  <!-- Schema.org Data API -->
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      name: "יאכטה קטמרן דולפין הרצליה",
      description:
        "השכרת יאכטת קטמרן דולפין במרינה הרצליה לענק ולמסיבות עד 21 מפליגים. כוללת צוות מקצועי וירידה לים עם אבוב.",
      image: "https://aflagot-haifa.com/seo/seo-Leader-cruise.jpg",
      brand: { "@type": "Brand", name: "Leader שייט & הפלגות" },
      seller: {
        "@type": "TravelAgency",
        "@id": "https://aflagot-haifa.com/",
        name: "Leader שייט & הפלגות",
        legalName: "לידר",
        alternateName: [
          "Leader Haflagot",
          "לידר הפלגות שייט",
          "Leader Yachting",
        ],
        telephone: "+972533403449",
        url: "https://aflagot-haifa.com/",
        location: [
          {
            "@type": "Place",
            address: {
              "@type": "PostalAddress",
              streetAddress: "מרינה הרצליה",
              addressLocality: "הרצליה",
              addressCountry: "IL",
            },
            geo: {
              "@type": "GeoCoordinates",
              latitude: 32.162443,
              longitude: 34.796172,
            },
          },
          {
            "@type": "Place",
            address: {
              "@type": "PostalAddress",
              streetAddress: "מעגן שביט, פארק קישון",
              addressLocality: "חיפה",
              addressCountry: "IL",
            },
            geo: {
              "@type": "GeoCoordinates",
              latitude: 32.8069075,
              longitude: 35.0322383,
            },
          },
        ],
        sameAs: [
          "https://www.facebook.com/leadership.haifa",
          "https://www.instagram.com/leader.aflagot?igsh=YnAzcThrbDExd2o5",
          "https://www.youtube.com/channel/UCzEOzFcGu8zSeFtFrif4cYw",
        ],
      },
      offers: {
        "@type": "AggregateOffer",
        priceCurrency: "ILS",
        lowPrice: "1990",
        highPrice: "3590",
        offerCount: "3",
        offers: [
          {
            "@type": "Offer",
            name: "הפלגה לשעה אחת",
            price: "1990",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/catamaran-21",
          },
          {
            "@type": "Offer",
            name: "הפלגה לשעתיים",
            price: "2550",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/catamaran-21",
          },
          {
            "@type": "Offer",
            name: "הפלגה ל-3 שעות",
            price: "3590",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/catamaran-21",
          },
        ],
      },
      subjectOf: {
        "@type": "VideoObject",
        name: "יאכטה קטמרן דולפין הרצליה",
        description: "יאכטה קטמרן עד 21 משתתפים מהרצליה",
        thumbnailUrl:
          "https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20250608-WA0048_aku3qj.jpg",
        contentUrl:
          "https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20250608-WA0048_aku3qj.mp4",
        uploadDate: isoUploadDate,
        embedUrl: "https://aflagot-haifa.com/catamaran-21",
      },
    })}
  />
</Layout>
