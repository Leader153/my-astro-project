---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import typhoonImg from "../assets/typhoon-ship.jpg";
import marinaImg from "../assets/mifratz-Haifa.png";
import KingImg from "../assets/king.png";
import MargaImg from "../assets/Marga-bot.png";
import YamiImg from "../assets/Yami.png";
import SeuImg from "../assets/Seu.png";
import LeaImg from "../assets/LeaCatamaran.png";
import OchenImg from "../assets/Ochen.png";
import margafishImg from "../assets/margafish.png";
import "../styles/catalog-page.css";

const yachts = [
  {
    title: "יאכטה יאמי (עד 11 מפליגים)",
    desc: "",
    descLines: [
      "יאכטה קלאסית ואינטימית במפרץ חיפה",
      "שעה: 1,100 ₪",
      "שעתיים: 1,350 ₪",
      "3 שעות: 1,850 ₪",
    ],
    tag: "עד 11 מפליגים",
    color: "#0f7ab0",
    alt: "יאכטה עד 11 מפליגים",
    img: YamiImg,
    href: "/yacht-11",
  },
  {
    title: "יאכטה סי יו (עד 14 מפליגים)",
    desc: "",
    descLines: [
      "יאכטה נוחה ומרווחת לחגיגות ואירועים",
      "שעה: 1,300 ₪",
      "שעתיים: 1,790 ₪",
      "3 שעות: 2,550 ₪",
    ],
    tag: "עד 14 מפליגים",
    color: "#e91e8c",
    alt: "יאכטה עד 14 מפליגים",
    img: SeuImg,
    href: "/yacht-14",
  },
  {
    title: "ספינת טייפון (עד 30 מפליגים)",
    desc: "",
    descLines: [
      "מסיבות, ימי הולדת ואירועים על המים",
      "שעה: 1,200 ₪",
      "שעתיים: 2,200 ₪",
      "3 שעות: 2,650 ₪",
    ],
    imgPosition: "right",
    tag: "עד 30 מפליגים",
    color: "#d4a017",
    alt: "ספינת טייפון בחיפה",
    img: typhoonImg,
    href: "/typhoon-ship",
  },
  {
    title: "יאכטה קטמרן מפרשית (עד 14 מפליגים)",
    desc: "",
    descLines: [
      "חוויית שייט שקטה וחלקה על קטמרן יוקרתית",
      "שעה: 2,390 ₪",
      "שעתיים: 2,700 ₪",
      "3 שעות: 3,690 ₪",
    ],
    tag: "עד 14 מפליגים",
    color: "#7c3aed",
    alt: "יאכטה קטמרן מפרשית מפוארת",
    img: LeaImg,
    href: "/catamaran-sailing",
  },
  {
    title: "יאכטה קטמרן מנועית (עד 13 מפליגים)",
    desc: "",
    descLines: [
      "קטמרן גדולה המשלבת יציבות ועוצמה למסיבות",
      "שעה: 2,100 ₪",
      "שעתיים: 2,200 ₪",
      "3 שעות: 2,650 ₪",
    ],
    tag: "עד 13 מפליגים",
    color: "#08047e",
    alt: "יאכטה קטמרן מנועית",
    img: OchenImg,
    href: "/catamaran-motor",
  },
  {
    title: "סירת מרגע (עד 6 מפליגים)",
    desc: "",
    descLines: [
      "סירת מנוע מהירה לחובבי אקסטרים",
      "שעה: 1,290 ₪",
      "שעתיים: 1,390 ₪",
      "3 שעות: 1,890 ₪",
    ],
    tag: "עד 6 מפליגים",
    color: "#1da8e8",
    alt: "סירת מנוע",
    img: margafishImg,
    href: "/motorboat-6",
  },
  {
    title: "ספינת טייפון (עד 30 מפליגים)",
    desc: "",
    descLines: [
      "מסיבות, ימי הולדת ואירועים על המים",
      "שעה: 1,200 ₪",
      "שעתיים: 2,200 ₪",
      "3 שעות: 2,650 ₪",
    ],
    tag: "עד 30 מפליגים",
    color: "#d4a017",
    alt: "יאכטה טייפון",
    img: typhoonImg,
    href: "/typhoon-ship",
  },
  {
    title: "ספינת קינג (עד 40 מפליגים)",
    desc: "",
    descLines: [
      "מסיבות, ימי הולדת ואירועים על המים",
      "שעה: 1,990 ₪",
      "שעתיים: 3,290 ₪",
      "3 שעות: 4,400 ₪",
    ],
    tag: "עד 40 מפליגים",
    color: "#08047e",
    alt: "ספינת קינג",
    img: KingImg,
    href: "/yacht-king-40",
  },
  {
    title: "סירת מרגע (עד 6 מפליגים)",
    desc: "",
    descLines: [
      "סירת מנוע מהירה לחובבי אקסטרים",
      "שעה: 1,290 ₪",
      "שעתיים: 1,390 ₪",
      "3 שעות: 1,890 ₪",
    ],
    tag: "עד 6 מפליגים",
    color: "#ff5722",
    alt: "סירת מנוע מרגע",
    img: MargaImg,
    href: "/motorboat-6",
  },
];

const textSections = [
  {
    icon: "⚓",
    title: "צי היאכטות המגוון שלנו בחיפה",
    text: "אנו מציעים מגוון רחב של כלי שייט בחיפה — צי היאכטות המפוארות שלנו כולל יאכטות מאובזרות בשיא הפינוק. מיאכטות אינטימיות ורומנטיות, דרך יאכטות קטמרן ליציבות מירבית, ועד לספינת הקייפון הגדולה. כאן תמצאו את היאכטה שתמיד חלמתם עליה.",
  },
  {
    icon: "🌊",
    title: "שייט מול הרי הכרמל",
    text: "הפלגה בחיפה מעניקה חוויה ייחודית בין נופי רכס הכרמל החופש הנושק לים, אל מול נמל חיפה הציורי. אוויר ים צלול וגלים שמלווים אתכם אל עבר האופק בחוויה של פעם בחיים.",
  },
  {
    icon: "👨‍✈️",
    title: "שירות אישי ומקצועי",
    text: "צוות הסקיפרים המנוסים שלנו יעניק לכם שירות בסטנדרט הגבוה ביותר — אדיב, מקצועי ובחיוך גדול. יאכטות מפוארות להשכרה בחיפה שמחכות לכם לחוויה בלתי נשכחת. אנו נדאג לכל פרט קטן כך שתוכלו להתרווח ולצרוב בזיכרון חוויה קסומה. מחכים לכם!",
  },
];
---

<Layout
  title="הפלגה בחיפה - השכרת יאכטות וספינות בנמל חיפה ⚓ | Leader הפלגות"
  description="מחפשים יאכטה בחיפה? ⚓ הכירו את צי היאכטות המפוארות שלנו! הפלגות למשפחות, מסיבות רווקות ואירועים רומנטיים בים התיכון מול הרי הכרמל. התקשרו להזמנת שייט מושלם!"
>
  <div class="hz-page" dir="rtl">
    <!-- ══ HERO ══ -->
    <section class="hz-hero">
      <div class="hz-hero-bg"></div>
      <div class="hz-hero-inner">
        <div class="hz-eyebrow">
          <span class="dot"></span>
          משטים בחיפה
        </div>
        <h1>שייט יאכטות בחיפה</h1>
        <p>
          צי היאכטות והספינות שלנו מחכה לכם לחוויה בלתי נשכחת מול חופי חיפה.
          מגוון רחב של אפשרויות לזוגות, משפחות וקבוצות.
        </p>
        <div class="hz-hero-btns">
          <a href="#fleet" class="hz-btn primary">לצפייה בצי שלנו</a>
          <a
            href="https://wa.me/972533403449"
            target="_blank"
            rel="noopener"
            class="hz-btn wa"
          >
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              width="18"
              height="18"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path></svg
            >
            WhatsApp
          </a>
        </div>
      </div>
    </section>

    <!-- ══ FLEET CARDS ══ -->
    <section id="fleet" class="hz-services">
      <div class="hz-inner">
        <div class="hz-section-header">
          <div class="hz-eyebrow-sm">צי היאכטות</div>
          <h2>בחרו את היאכטה שלכם</h2>
          <p>יאכטות לחופשות, מסיבות ורגעים רומנטיים — איזה סגנון מתאים לכם?</p>
        </div>

        <div class="hz-grid">
          {
            yachts.slice(0, 3).map((y, i) => (
              <a
                href={y.href}
                class="hz-card"
                style={`--c:${y.color}; --i:${i}`}
              >
                <div class="hz-card-img">
                  <Image
                    src={y.img}
                    width={600}
                    height={400}
                    format="webp"
                    alt={y.alt}
                    class="hz-img"
                    loading={i < 2 ? "eager" : "lazy"}
                    style={
                      y.imgPosition ? `object-position: ${y.imgPosition};` : ""
                    }
                  />
                  <div class="hz-badge" style={`background:${y.color}`}>
                    {y.tag}
                  </div>
                </div>
                <div class="hz-card-body">
                  <h3>{y.title}</h3>
                  {y.descLines ? (
                    <p>
                      {y.descLines.map((line) => (
                        <span style="display:block; margin-bottom: 0.2rem;">
                          {line}
                        </span>
                      ))}
                    </p>
                  ) : (
                    <p>{y.desc}</p>
                  )}
                  <span class="hz-card-cta" style={`color:${y.color}`}>
                    הזמן עכשיו
                    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      width="14"
                      height="14"
                    >
                      <polyline points="15 18 9 12 15 6" />
                    </svg>
                  </span>
                </div>
                <div class="hz-glow" style={`background:${y.color}`} />
              </a>
            ))
          }
        </div>

        <div class="hz-mid-text">
          <p class="hmt-main">
            <strong>נפגש במעגנת יאכטות</strong><br />
            ונעלה על יאכטת ההחלמות . נפליג על פני הספינות הענק שעוגנות בנמל<br
            />
            מרימים מפרשים ומפליגים על עבר הים הפתוח<br />
            על הרפתקאות הנפלאות
          </p>
        </div>

        <div class="hz-grid">
          {
            yachts.slice(3, 6).map((y, i) => (
              <a
                href={y.href}
                class="hz-card"
                style={`--c:${y.color}; --i:${i + 3}`}
              >
                <div class="hz-card-img">
                  <Image
                    src={y.img}
                    width={600}
                    height={400}
                    format="webp"
                    alt={y.alt}
                    class="hz-img"
                    loading="lazy"
                  />
                  <div class="hz-badge" style={`background:${y.color}`}>
                    {y.tag}
                  </div>
                </div>
                <div class="hz-card-body">
                  <h3>{y.title}</h3>
                  {y.descLines ? (
                    <p>
                      {y.descLines.map((line) => (
                        <span style="display:block; margin-bottom: 0.2rem;">
                          {line}
                        </span>
                      ))}
                    </p>
                  ) : (
                    <p>{y.desc}</p>
                  )}
                  <span class="hz-card-cta" style={`color:${y.color}`}>
                    הזמן עכשיו
                    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      width="14"
                      height="14"
                    >
                      <polyline points="15 18 9 12 15 6" />
                    </svg>
                  </span>
                </div>
                <div class="hz-glow" style={`background:${y.color}`} />
              </a>
            ))
          }
        </div>

        <div class="hz-mid-text">
          <p class="hmt-main">
            <strong>תבחרו לכם יאכטה שהכי מתאימה</strong><br />
            לסוג האירוע , כמות מפליגים , ועדיפות אישית כמובן !<br />
            יאכטות עוגנות במקום קסום<br /><br />
            מרינה חיפה - מעגן שביט<br />
            בעמוד זה תוכלו למצוא לכם יאכטה<br />
            לכל מטרה.
          </p>
        </div>

        <div class="hz-grid">
          {
            yachts.slice(6).map((y, i) => (
              <a
                href={y.href}
                class="hz-card"
                style={`--c:${y.color}; --i:${i + 6}`}
              >
                <div class="hz-card-img">
                  <Image
                    src={y.img}
                    width={600}
                    height={400}
                    format="webp"
                    alt={y.alt}
                    class="hz-img"
                    loading="lazy"
                  />
                  <div class="hz-badge" style={`background:${y.color}`}>
                    {y.tag}
                  </div>
                </div>
                <div class="hz-card-body">
                  <h3>{y.title}</h3>
                  {y.descLines ? (
                    <p>
                      {y.descLines.map((line) => (
                        <span style="display:block; margin-bottom: 0.2rem;">
                          {line}
                        </span>
                      ))}
                    </p>
                  ) : (
                    <p>{y.desc}</p>
                  )}
                  <span class="hz-card-cta" style={`color:${y.color}`}>
                    הזמן עכשיו
                    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      width="14"
                      height="14"
                    >
                      <polyline points="15 18 9 12 15 6" />
                    </svg>
                  </span>
                </div>
                <div class="hz-glow" style={`background:${y.color}`} />
              </a>
            ))
          }
        </div>

        <div class="hz-mid-text">
          <p class="hmt-main">
            <strong>תמצאו לכם בדיוק את אותה היאכטה שתמיד חלמתם...</strong><br />
            מחכים לכם !<br />
            תתקשרו עכשיו ותקבעו יום ההפלגה<br />
            ---<br />
            לשירותכם דניאל - <span class="brand-leader"
              >לידר הפלגות &amp; שייט</span
            >
          </p>
        </div>
      </div>
    </section>

    <!-- ══ TEXT SECTIONS ══ -->
    <section class="hz-about">
      <div class="hz-inner">
        <div class="hz-section-header">
          <div class="hz-eyebrow-sm">למה להפליג איתנו?</div>
          <h2>שייט בחיפה מול הנוף הקסום של הכרמל וגלי הים</h2>
        </div>

        <div class="hz-about-grid">
          {
            textSections.map((sec, i) => (
              <div class="hz-about-card" style={`--i:${i}`}>
                <div class="hz-about-icon">{sec.icon}</div>
                <div>
                  <h3>{sec.title}</h3>
                  <p>{sec.text}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ══ SCENIC PHOTO ══ -->
    <section class="hz-marina-container">
      <div class="hz-marina-wrap">
        <Image
          src={marinaImg}
          widths={[768, 1280, 1920]}
          sizes="100vw"
          format="webp"
          alt="שייט בחיפה, אווירה קסומה"
          class="hz-marina-img"
          loading="lazy"
        />
      </div>
      <div class="hz-marina-info">
        <div class="hz-marina-eyebrow-dark">📍 אזור ההפלגות</div>
        <h2>אגן מפרץ חיפה</h2>
        <p>
          הפלגות חווייתיות אל מול הרי הכרמל, הרחק מההמולה. אוויר הים, הרוח
          במפרשים ומנוחה אמיתית.
        </p>
        <a
          href="https://maps.google.com/?q=חיפה"
          target="_blank"
          rel="noopener noreferrer"
          class="hz-btn primary">פתח במפה ↗</a
        >
      </div>
    </section>

    <!-- ══ CTA ══ -->
    <section class="hz-cta">
      <div class="hz-cta-bg"></div>
      <div class="hz-cta-inner">
        <h2>מחכים לכם! תקבעו יום להפלגה עוד היום</h2>
        <p>
          לשירותכם דניאל - <span class="brand-leader"
            >לידר הפלגות &amp; שייט</span
          >. התקשרו עכשיו והבטיחו לעצמכם מקום.
        </p>
        <div class="hz-cta-btns">
          <a href="/contact" class="hz-btn primary large">לפרטים והזמנה</a>
          <a href="tel:0533403449" class="hz-btn outline-light large"
            >053-340-3449</a
          >
        </div>
      </div>
    </section>
  </div>
</Layout>

<!-- Schema.org Data API -->
<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TouristAttraction",
    name: "לידר",
    description:
      "השכרת יאכטות, הפלגות בחיפה, מסיבות בים ואירועי בוטיק מול נופי הר כרמל.",
    url: "https://aflagot-haifa.com/haifa",
    image: "https://aflagot-haifa.com/images/default-social.jpg",
    address: {
      "@type": "PostalAddress",
      streetAddress: "מעגן שביט, פארק קישון",
      addressLocality: "חיפה",
      addressRegion: "מחוז חיפה",
      addressCountry: "IL",
    },
    telephone: "+972533403449",
    provider: {
      "@type": "TravelAgency",
      name: "Leader הפלגות",
      url: "https://aflagot-haifa.com/",
    },
  })}
/>
