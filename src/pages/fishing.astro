---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import cardImg from "../assets/group-men-sitting-on-yacht-deck-herzliya.webp";
import mobileImg from "../assets/group-men-sitting-on-yacht-deck-herzliya.webp";
import img1 from "../assets/group-of-fishermen-marina-herzelia.jpg";
import midImg from "../assets/man-holding-large-fish-yacht-haifa.jpeg";
import botImg from "../assets/family-fishing-trip-sailing-yacht-haifa.jpeg";
import FleetSelectionCta from "../components/FleetSelectionCta.astro";
import heroImage from "../assets/original-high-res.png";
---

<Layout
  title="הפלגת דייג על יאכטה פרטית: אקשן ויוקרה בלב ים"
  description='הפלגת דייג קבוצתית עם "לידר" – אקשן, חברים והשלל שלכם בלב ים! חוויית דייג מקצועית עם מומחים ⚓ מחיפה והרצליה.'
>
  <div class="service-page" dir="rtl">
    <!-- ══ HERO ══ -->
    <section class="sp-hero">
      <Image
        src={heroImage}
        alt="קבוצת אנשים דגים ביחד על סיפון יאכטה"
        width={1920}
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg desktop-hero"
      />
      <!-- MOBILE HERO IMAGE -->
      <Image
        src={heroImage}
        widths={[400, 768]}
        sizes="100vw"
        format="webp"
        alt="הפלגת דייג קבוצתית"
        class="sp-hero-bg mobile-hero"
        loading="eager"
        fetchpriority="high"
      />
    </section>

    <!-- CONTENT -->
    <section class="sp-content">
      <div class="sp-inner">
        <h1>השכרת יאכטה להפלגת דייג קבוצתית – אקשן וחברים בלב ים</h1>

        <p>
          מחפשים חוויה שמשלבת אדרנלין, טבע, וזמן איכות עם החבר'ה? ב<span
            class="brand-leader">לידר השכרת יאכטות</span
          > אנחנו לוקחים את אהבת הים שלכם לשלב הבא! הפלגות הדייג שלנו מציעות שילוב
          מנצח של ספורט ימי מקצועי יחד עם פינוק של יאכטת יוקרה.
        </p>

        <Image
          src={img1}
          alt="קבוצת דייגים עם חכות עומדים על המזח במרינה בהרצליה"
          class="sp-gallery-img"
          format="webp"
        />

        <h2>חוויית דייג מקצועית עם מומחים</h2>
        <p>
          אצלנו לא סתם זורקים חכה לים. להפלגה יתלווה סקיפר מקצועי ומנוסה, שידריך
          אתכם ויעשיר אתכם בטכניקות דייג מגוונות בהתאם לעונה ולתנאי הים: בולוס,
          פתיונות, ג'יג לייט/כבד, וטרולינג (ג'ירג'ור).
        </p>
        <ul class="sp-list">
          <li>
            <strong>דגי המטרה שלנו:</strong> לוקוס (לבן/אדום/סלעים), אינטיאס, פלמידות,
            פארידות. בעונה הנכונה נצא גם בעקבות אלבקור וטונות כחולות!
          </li>
          <li>
            <strong>ציוד:</strong> היאכטות שלנו מצוידות בטכנולוגיה מתקדמת לאיתור דגים
            (פישפיינדר) ומתקני חכות. תוכלו לשכור מאיתנו ציוד דייג מקצועי ומלא, או
            להביא את הציוד האישי האהוב עליכם.
          </li>
        </ul>

        <h2>📍 צי היאכטות שלנו: מחיפה ועד הרצליה</h2>
        <p>
          הפלגות הדייג שלנו יוצאות לנוחיותכם משתי המרינות המובילות בארץ: מרינה
          חיפה ומרינה הרצליה. (מומלץ לצאת בשעות הבוקר המוקדמות כדי לתפוס את הים
          בשיאו!).
        </p>
        <p>
          ההפלגה הסטנדרטית מתבצעת על יאכטה מפוארת ומהירה באורך 38 פיט (כ-12
          מטרים). יוצאים בקבוצה גדולה במיוחד? צי הספינות של <span
            class="brand-leader">"לידר"</span
          > ערוך לכל תרחיש! יש לנו יאכטות המתאימות לקבוצות של עד 10 משתתפים לאירועי
          דייג וגיבוש ענקיים.
        </p>

        <Image
          src={midImg}
          alt="גבר מחזיק דג גדול שנתפס במהלך שייט דייג בחיפה"
          class="sp-gallery-img is-square"
          format="webp"
        />

        <h2>🥩 תפסנו דג? יאללה, על האש!</h2>
        <p>
          אחד היתרונות הגדולים של הפלגה עם <span class="brand-leader">לידר</span
          > הוא החוויה הקולינרית. אצלנו יש אפשרות לעשות בשרים (או דגים!) על הגריל
          ממש על סיפון היאכטה! תוכלו להביא איתכם בשרים ואוכל מהבית, או להזמין דרכנו
          מראש ארוחות בוקר, צהריים או ערב (בתוספת תשלום) שיחכו לכם מוכנות.
        </p>

        <Image
          src={botImg}
          alt="משפחה נהנית מדיג משותף על סיפון יאכטה בחיפה"
          class="sp-gallery-img"
          format="webp"
        />

        <h2>🥂 פינוקים, מוזיקה וצ'יל אחרי הדייג</h2>
        <p>
          הפלגת דייג עם <span class="brand-leader">"לידר"</span> היא הרבה מעבר לספורט.
          אחרי שהתעייפנו מהאקשן, הגיע הזמן לנוח:
        </p>
        <ul class="sp-list">
          <li>
            <strong>אבזור VIP:</strong> בכל יאכטה תמצאו סלון ממוזג, שני חדרי שינה,
            מטבח מאובזר, מקלחת ושירותים נקיים.
          </li>
          <li>
            <strong>אווירה ומסיבה:</strong> מערכות סאונד מתקדמות עם חיבור בלוטות'
            למוזיקה שלכם, בקבוק שמפניה קפוא להרמת כוסית על השלל, ומים קרים ושתייה
            חמה חופשית.
          </li>
          <li>
            <strong>קופצים למים:</strong> נעצור לטבילה מרעננת בלב ים עם אבוב חווייתי,
            או סתם נתפוס צבע על מזרני השיזוף בחרטום.
          </li>
          <li>
            <strong>תיעוד החוויה:</strong> רוצים תמונות של הדג הענק שתפסתם? יש אפשרות
            לצילום מקצועי על ידי הסקיפר שלנו (יש לציין בעת ההזמנה).
          </li>
        </ul>

        <h2>💰 מחירון הפלגת דייג בהרצליה (מומלץ למינימום 3 שעות):</h2>
        <p>
          החל מ- <strong>1,890 ש"ח</strong> להפלגה של 3 שעות (המחיר כולל את השכרת
          ציוד הדייג).
        </p>

        <div class="services-grid">
          <a
            href="/yacht-li-yam"
            class="service-card"
            style="--c:#0ea5e9; --i:0"
          >
            <div class="sc-img-wrap">
              <Image
                src={heroImage}
                width={600}
                height={400}
                format="webp"
                alt="הפלגת דייג בהרצליה"
                class="sc-img"
                loading="lazy"
                style="object-position: left;"
              />
              <div class="sc-tag" style="background:#0ea5e9; color:#fff">
                הרצליה
              </div>
            </div>
            <div class="sc-body">
              <div class="sc-icon">🎣</div>
              <h3>הפלגת דייג בהרצליה</h3>
              <p>
                <strong>מחירון דייג:</strong><br />
                שעתיים 1150 ₪<br />
                3 שעות 1890 ₪<br />
                עד 8 דייגים<br />
                <span style="font-size: 0.85em; opacity: 0.9;"
                  >מחיר כולל חכות, פתיונות, רישיון דייג ליום אחד</span
                >
              </p>
              <div class="sc-arrow" style="color:#0ea5e9">
                קבלו פרטים
                <svg
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  width="15"
                  height="15"
                  ><polyline points="15 18 9 12 15 6"></polyline></svg
                >
              </div>
            </div>
          </a>

          <a
            href="/yacht-li-yam"
            class="service-card"
            style="--c:#0f7ab0; --i:1"
          >
            <div class="sc-img-wrap">
              <Image
                src={img1}
                width={600}
                height={400}
                format="webp"
                alt="הפלגת דייג בחיפה"
                class="sc-img"
                loading="lazy"
              />
              <div class="sc-tag" style="background:#0f7ab0; color:#fff">
                חיפה
              </div>
            </div>
            <div class="sc-body">
              <div class="sc-icon">⚓</div>
              <h3>הפלגת דייג בחיפה</h3>
              <p>
                <strong>מחירון דייג:</strong><br />
                שעתיים 1150 ₪<br />
                3 שעות 1890 ₪<br />
                עד 8 דייגים<br />
                <span style="font-size: 0.85em; opacity: 0.9;"
                  >מחיר כולל חכות, פתיונות, רישיון דייג ליום אחד</span
                >
              </p>
              <div class="sc-arrow" style="color:#0f7ab0">
                קבלו פרטים
                <svg
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  width="15"
                  height="15"
                  ><polyline points="15 18 9 12 15 6"></polyline></svg
                >
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- ══ NEW GLOBAL CTA SECTION (GOLDEN FENCE) ══ -->
    <FleetSelectionCta
      ctaInstruction="נא להיכנס לעמוד יאכטות ולתאם את הפלגת הדייג שלכם:"
    />
  </div>
</Layout>

<!-- Schema.org Data API -->
<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TouristTrip",
    name: "הפלגת דייג על יאכטה פרטית",
    description:
      "הפלגת דייג קבוצתית מחיפה והרצליה עם ציוד מקצועי, סקיפר מנוסה ואפשרות BBQ על הסיפון. ללא צורך ברישיון.",
    url: "https://aflagot-haifa.com/fishing",
    image: "https://aflagot-haifa.com/seo/seo-Leader-cruise.jpg",
    touristType: { "@type": "Audience", audienceType: "חובבי דייג וקבוצות" },
    offers: {
      "@type": "AggregateOffer",
      priceCurrency: "ILS",
      lowPrice: "1150",
      highPrice: "1890",
      availability: "https://schema.org/InStock",
    },
    provider: {
      "@type": "TravelAgency",
      "@id": "https://aflagot-haifa.com/",
      name: "Leader שייט & הפלגות",
      legalName: "לידר",
      alternateName: ["Leader Haflagot", "לידר הפלגות שייט", "Leader Yachting"],
      telephone: "+972533403449",
      location: [
        {
          "@type": "Place",
          address: {
            "@type": "PostalAddress",
            streetAddress: "מרינה הרצליה",
            addressLocality: "הרצליה",
            addressCountry: "IL",
          },
          geo: {
            "@type": "GeoCoordinates",
            latitude: 32.162443,
            longitude: 34.796172,
          },
        },
        {
          "@type": "Place",
          address: {
            "@type": "PostalAddress",
            streetAddress: "מעגן שביט, פארק קישון",
            addressLocality: "חיפה",
            addressCountry: "IL",
          },
          geo: {
            "@type": "GeoCoordinates",
            latitude: 32.8069075,
            longitude: 35.0322383,
          },
        },
      ],
      sameAs: [
        "https://www.facebook.com/leadership.haifa",
        "https://www.instagram.com/leader.aflagot?igsh=YnAzcThrbDExd2o5",
        "https://www.youtube.com/channel/UCzEOzFcGu8zSeFtFrif4cYw",
      ],
    },
  })}
/>
