---
import "../styles/faq-page.css";

import Layout from "../layouts/Layout.astro";

const categories = [
  {
    id: "booking",
    icon: "🗓️",
    label: "הזמנה ותיאום",
    color: "#08047e",
    faqs: [
      {
        q: "איך מתבצע תהליך ההזמנה ואופן סגירת העסקה?",
        a: "בשביל לשריין מקום יש למסור לנו: תאריך, שעות הפלגה רצויות, ושם מלא. לאחר מכן נשלח לכם 'אישור הזמנה' מסודר בו יהיה כתוב: מתמצת פרטיכם, תאריך ושעות, סכום ההזמנה המלא, סכום המקדמה (50% מערך ההזמנה), יתרה לתשלום, ותנאי הביטול.",
      },
      {
        q: "כיצד משלמים את המקדמה לקביעת ההזמנה?",
        a: "יש לקרוא ולאשר את פרטי ההזמנה ששלחנו (באמצעות המשפט 'אני מאשר/ת'). את המקדמה ניתן להעביר ב-PayBox, בהעברה בנקאית (נשלח פרטי חשבון), או באשראי (עסקה טלפונית). לאחר התשלום יש לשלוח צילום מסך עם מספר אסמכתא ששילמתם, ומייד תקבלו קבלה דיגיטלית בוואטסאפ. זהו אופן סגירת העסקה!",
      },
      {
        q: "מתי עלינו להגיע להפלגה?",
        a: "יש להגיע למרינה כ-10 דקות לפני המועד שנקבע לתדריך בטיחות. סקיפר יקבל את פניכם ויוביל אתכם ליאכטה. מספר הטלפון של הסקיפר וקישור לווייז יישלחו אליכם יום לפני ההפלגה.",
      },
      {
        q: "מה קורה אם אנחנו מאחרים?",
        a: "כל איחור של הלקוח ייגרע מזמן השייט הכולל שנקבע מראש. אין פיצוי או זמן נוסף, ואין החזר כספי בגין איחור שלכם, לכן חשוב מאוד להגיע בזמן!",
      },
      {
        q: "האם מקבלים בדיוק את הזמן שהוזמן נטו?",
        a: "הזמן נספר אך ורק מהשעה הרשומה בחוזה ועד לשעה הרשומה (למשל מ-10:00 עד 12:00). שימו לב: היאכטה תשוב לרציף כ-15 דקות לפני תום הזמן הנקוב לשם קשירה בטוחה וירידה מההפלגה. לא יינתן זמן חורג מעבר לכך.",
      },
    ],
  },
  {
    id: "payment",
    icon: "💳",
    label: "תשלום ומחירים",
    color: "#059669",
    faqs: [
      {
        q: "איך משלמים את המקדמה ויתרת התשלום?",
        a: "את המקדמה (בהנחה שנדרשת) ניתן להעביר ב-PayBox, העברה בנקאית או כרטיס אשראי (עסקה טלפונית / קישור מאובטח). את יתרת התשלום יש לשלם במועד ההפלגה עצמה במזומן מול הסקיפר או באשראי טלפוני/דיגיטלי.",
      },
      {
        q: "מה המחיר כולל (בהפלגות זוגיות / סטנדרט)?",
        a: "מחיר ההזמנה הרגיל כולל את השייט עצמו, בקבוק שמפניה המפנק, בלונים בתוך היאכטה, שלט 'מזל טוב' ומים לשתייה (ללא תוספות מיוחדות מעבר לזה). המחיר אינו כולל שירות או טיפ אישי לסקיפר.",
      },
    ],
  },
  {
    id: "sailing",
    icon: "⛵",
    label: "ההפלגה עצמה",
    color: "#0f7ab0",
    faqs: [
      {
        q: "האם מותר להכניס אוכל, אלכוהול או ציוד אישי?",
        a: "ניתן להביא אוכל ושתייה, אך באחריותכם לפנות את האשפה ולהשאיר יאכטה נקייה. במידה והיאכטה תישאר מלוכלכת (או שפינויה יתארך), תחויבו בקנס בגובה עלות שעת הפלגה אחת. בנוסף, חשוב לדעת: שתיית אלכוהול מתחת לגיל 18 אסורה בהחלט.",
      },
      {
        q: "האם רואים דולפינים במהלך ההפלגה?",
        a: "כן, אנחנו רואים דולפינים באופן קבוע! הדולפינים מגיעים אלינו לרוב בלהקות של שניים או שלושה, קופצים לצידי היאכטה ומשמחים אותנו. חוויה מדהימה ובלתי נשכחת לכל המשפחה.",
      },
      {
        q: "האם ניתן לרדת למים ולשחות?",
        a: "הרחצה בים חופשית אך היא באחריות המתרחץ בלבד! הירידה למים תתאפשר אך ורק על פי החלטתו הבלעדית של הסקיפר, במידה ותנאי הים מצד החברה מאפשרים. לא תתאפשר רחצה בשעות החשיכה, ומטעמי בטיחות אסורה גרירת אבוב.",
      },
      {
        q: "האם מומלץ לקחת כדורים נגד בחילה?",
        a: "בהחלט! מומלץ מאוד ליטול כדורים נגד בחילה (כאלה שללא מרשם) כשעה לפני תחילת השייט, כדי להבטיח הנאה מירבית.",
      },
      {
        q: "מה בקשר לחפצים אישיים שנופלים למים?",
        a: "אחריות במקרה של אובדן או נזק לטלפון סלולרי, משקפיים, או כל פריט אחר שנופל למים או ניזוק, חלה על המפליג באופן בלעדי. צוות היאכטה אינו אחראי לכך.",
      },
      {
        q: "מה אסור בשום אופן לעשות ביאכטה?",
        a: "חל איסור מוחלט על עלייה ליאכטה עם נרגילה (או עישונה שם), חל איסור על פיזור קונפטי מכל סוג, ואין להגיע או להדליק מנגל וברביקיו בשום מצב.",
      },
    ],
  },
  {
    id: "cancellation",
    icon: "�",
    label: "ביטולים ושינויים",
    color: "#dc2626",
    faqs: [
      {
        q: "מהי מדיניות דחייה עקב מזג אוויר וים סוער?",
        a: "לידר הפלגות אינה אחראית למצב הים או מזג אוויר תנודתי. במידה ומזג האוויר אינו מאפשר הפלגה בצורה בטוחה, האירוע יידחה אל מועד חלופי קרוב ומתואם. לא יינתן החזר כספי או פיצוי בגין שינוי מועד עקב מזג אוויר, אלא רק שריון תאריך חדש.",
      },
      {
        q: "מהם דמי הביטול מיוזמת הלקוח (ללא מזג אוויר)?",
        a: "ביטול הזמנה מול החזר כספי אפשרי רק עד 14 ימים טרם ההפלגה — במקרה זה ינוכו קבוע 400 ₪ דמי טיפול. ביטול בין 14 ימים ל-48 שעות מראש יגרור חיוב של 50% מעלות ההזמנה. במקרה של ביטול בתוך פחות מ-48 שעות: חיוב מלא (100%) של ההזמנה.",
      },
      {
        q: "מה קורה במקרה של כוח עליון (מלחמה או מבצע צבאי)?",
        a: "במקרה של נסיבות חריגות ובלתי צפויות שאינן בשליטתנו 'כוח עליון' (מלחמה, מבצע צבאי חריג או אסון טבע), לא מבוצע החזר כספי — אך לפנים משורת הדין, תינתן למזמין אפשרות לדחות את מועד האירוע למועד חלופי עתידי ללא מגבלה.",
      },
    ],
  },
  {
    id: "safety",
    icon: "🛡️",
    label: "בטיחות וביטוח",
    color: "#7c3aed",
    faqs: [
      {
        q: "האם יש ביטוח לאורחים ביאכטה?",
        a: "כן, מובן שכן. כל היאכטות בצי שלנו מבוטחות בביטוח צד ג', כמקובל להשכרת יאכטות בישראל.",
      },
      {
        q: "האם נדרש מלווה מבוגר להפלגה לצעירים?",
        a: "כן, קיימת חובת נוכחות מלאה של מלווה מעל גיל 16 לפחות (מטעם הלקוח) בכל הפלגה.",
      },
      {
        q: "מי אחראי על יידוע המשפחה / האורחים בכללים?",
        a: "הלקוח/ה המזמין והחותם על טופס ההזמנה. עליו חלה באופן בלעדי האחריות להבהיר לאורחים המגיעים מטעמו את תנאי ההסכם, איסורי הבטיחות, שעת ההגעה והנהלים בשייט.",
      },
    ],
  },
];
---

<Layout
  title="שאלות ותשובות: כל מה שצריך לדעת לפני הפלגה יוקרתית"
  description="יש לכם שאלות? ⚓ ריכזנו את כל המידע על השכרת יאכטה והפלגות בוטיק 🐬. הכל מוכן לחוויה מושלמת וראש שקט 🥂. התקשרו והזמינו עכשיו!"
>
  <div class="faq-page" dir="rtl">
    <!-- ══════════════ HERO ══════════════ -->
    <div class="page-hero">
      <div class="hero-bubbles" aria-hidden="true">
        <span class="bubble b1">?</span>
        <span class="bubble b2">?</span>
        <span class="bubble b3">?</span>
      </div>
      <div class="hero-content">
        <div class="hero-icon-wrap">
          <svg
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            width="36"
            height="36"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
            <line
              x1="12"
              y1="17"
              x2="12.01"
              y2="17"
              stroke-width="2.5"
              stroke-linecap="round"></line>
          </svg>
        </div>
        <h1>שאלות ותשובות - כל מה שצריך לדעת על השכרת יאכטה</h1>
        <p class="hero-sub">
          כל מה שצריך לדעת לפני הפלגה יוקרתית — השכרת יאכטה, הפלגות בוטיק וחוויה
          מושלמת בראש שקט — במקום אחד
        </p>

        <!-- Search bar -->
        <div class="search-wrap">
          <svg
            aria-hidden="true"
            class="search-icon"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            width="18"
            height="18"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="8"></circle><line
              x1="21"
              y1="21"
              x2="16.65"
              y2="16.65"></line>
          </svg>
          <input
            type="search"
            id="faq-search"
            class="search-input"
            placeholder="חפשו שאלה..."
            autocomplete="off"
            aria-label="חיפוש שאלות"
          />
          <div class="search-clear" id="search-clear" aria-hidden="true">✕</div>
        </div>
      </div>
    </div>

    <div class="content-wrapper">
      <!-- Category tabs -->
      <div
        class="cat-tabs"
        id="cat-tabs"
        role="tablist"
        aria-label="קטגוריות שאלות"
      >
        <button
          class="cat-tab active"
          data-cat="all"
          role="tab"
          aria-selected="true"
        >
          🌊 הכל
        </button>
        {
          categories.map((c) => (
            <button
              class="cat-tab"
              data-cat={c.id}
              role="tab"
              aria-selected="false"
              style={`--cat-color:${c.color}`}
            >
              {c.icon} {c.label}
            </button>
          ))
        }
      </div>

      <!-- No results msg -->
      <div class="no-results" id="no-results" hidden>
        <div class="no-results-icon">🔍</div>
        <p>לא נמצאו תוצאות לחיפוש זה.</p>
        <button class="no-results-reset" id="no-results-reset">נקה חיפוש</button
        >
      </div>

      <!-- FAQ sections -->
      <div class="faq-sections" id="faq-sections">
        {
          categories.map((cat) => (
            <section class="faq-section" data-cat={cat.id}>
              <div class="section-heading">
                <div
                  class="section-icon"
                  style={`background:${cat.color}18; color:${cat.color}`}
                >
                  {cat.icon}
                </div>
                <h2 style={`color:${cat.color}`}>{cat.label}</h2>
              </div>

              <div class="accordion">
                {cat.faqs.map((item, i) => (
                  <div class="accordion-item" data-q={item.q.toLowerCase()}>
                    <button
                      class="accordion-trigger"
                      aria-expanded="false"
                      id={`q-${cat.id}-${i}`}
                      aria-controls={`a-${cat.id}-${i}`}
                    >
                      <span
                        class="q-num"
                        style={`background:${cat.color}18; color:${cat.color}`}
                      >
                        {i + 1}
                      </span>
                      <span class="q-text">{item.q}</span>
                      <span class="q-chevron" aria-hidden="true">
                        <svg
                          aria-hidden="true"
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2.5"
                          width="18"
                          height="18"
                        >
                          <polyline points="6 9 12 15 18 9" />
                        </svg>
                      </span>
                    </button>
                    <div
                      class="accordion-body"
                      id={`a-${cat.id}-${i}`}
                      role="region"
                      aria-labelledby={`q-${cat.id}-${i}`}
                      hidden
                    >
                      <div class="accordion-answer">
                        <div
                          class="answer-bar"
                          style={`background:${cat.color}`}
                        />
                        <p>{item.a}</p>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </section>
          ))
        }
      </div>

      <!-- Still have questions CTA -->
      <div class="still-questions">
        <div class="still-icon">💬</div>
        <div class="still-text">
          <h3>לא מצאתם את התשובה?</h3>
          <p>התקשרו והזמינו עכשיו — אנחנו כאן 24/7 ונענה בהקדם</p>
        </div>
        <div class="still-actions">
          <a href="tel:0533403449" class="still-btn phone">
            <svg
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              width="17"
              height="17"
              ><path
                d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"
              ></path></svg
            >
            053-340-3449
          </a>
          <a
            href="https://wa.me/972533403449"
            target="_blank"
            rel="noopener"
            class="still-btn wa"
          >
            <svg
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              width="17"
              height="17"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path></svg
            >
            WhatsApp
          </a>
        </div>
      </div>
    </div><!-- /content-wrapper -->
  </div>
</Layout>

<!-- Schema.org Data API -->
<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    url: "https://aflagot-haifa.com/faq",
    image: "https://aflagot-haifa.com/seo/seo-Leader-cruise.jpg",
    mainEntity: [
      {
        "@type": "Question",
        name: "איך מבצעים הזמנה?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "מתקשרים או שולחים הודעה בווטסאפ למספר 053-340-3449. נתאם יחד את כל הפרטים ותקבלו אישור הזמנה מפורט.",
        },
      },
      {
        "@type": "Question",
        name: "כמה עולה הפלגה?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "המחיר תלוי בסוג היאכטה, מספר המשתתפים ומשך ההפלגה. יש לנו יאכטות לכל תקציב. צרו קשר לקבלת הצעת מחיר.",
        },
      },
      {
        "@type": "Question",
        name: "האם ההפלגות בטוחות?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "בהחלט! היאכטות שלנו עוברות בדיקות תקופתיות. כל הפלגה מלווה בסקיפר מוסמך ומנוסה עם ציוד הצלה מלא.",
        },
      },
      {
        "@type": "Question",
        name: "מה מדיניות הביטול?",
