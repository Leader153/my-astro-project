<script>
  /* ════════════════════════════════════════
     ACCORDION
  ════════════════════════════════════════ */
  document
    .querySelectorAll<HTMLButtonElement>(".accordion-trigger")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        const expanded = btn.getAttribute("aria-expanded") === "true";
        const bodyId = btn.getAttribute("aria-controls")!;
        const body = document.getElementById(bodyId)!;
        const item = btn.closest(".accordion-item")!;

        // close siblings in same accordion
        btn
          .closest(".accordion")!
          .querySelectorAll<HTMLButtonElement>(".accordion-trigger")
          .forEach((b) => {
            if (b !== btn) {
              b.setAttribute("aria-expanded", "false");
              b.closest(".accordion-item")!.classList.remove("open");
              const sid = b.getAttribute("aria-controls")!;
              const sb = document.getElementById(sid)!;
              sb.hidden = true;
              sb.style.maxHeight = "0";
            }
          });

        if (expanded) {
          btn.setAttribute("aria-expanded", "false");
          item.classList.remove("open");
          body.hidden = true;
          body.style.maxHeight = "0";
        } else {
          btn.setAttribute("aria-expanded", "true");
          item.classList.add("open");
          body.hidden = false;
          body.style.maxHeight = body.scrollHeight + "px";
        }
      });
    });

  /* ════════════════════════════════════════
     CATEGORY TABS
  ════════════════════════════════════════ */
  const tabs = document.querySelectorAll<HTMLButtonElement>(".cat-tab");
  const sections = document.querySelectorAll<HTMLElement>(".faq-section");

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      tabs.forEach((t) => {
        t.classList.remove("active");
        t.setAttribute("aria-selected", "false");
      });
      tab.classList.add("active");
      tab.setAttribute("aria-selected", "true");

      const cat = tab.dataset.cat!;
      sections.forEach((s) => {
        s.style.display = cat === "all" || s.dataset.cat === cat ? "" : "none";
      });

      // clear search when switching tabs
      (document.getElementById("faq-search") as HTMLInputElement).value = "";
      applySearch("");
    });
  });

  /* ════════════════════════════════════════
     SEARCH
  ════════════════════════════════════════ */
  const searchInput = document.getElementById("faq-search") as HTMLInputElement;
  const searchClear = document.getElementById("search-clear")!;
  const noResults = document.getElementById("no-results")!;
  const noResBtn = document.getElementById("no-results-reset")!;

  const applySearch = (query: string) => {
    const q = query.trim().toLowerCase();
    let found = 0;

    sections.forEach((sec) => {
      let secVisible = false;
      sec.querySelectorAll<HTMLElement>(".accordion-item").forEach((item) => {
        const text =
          (item.dataset.q || "") +
          " " +
          (
            item.querySelector(".accordion-answer p")?.textContent || ""
          ).toLowerCase();
        const match = !q || text.includes(q);
        item.style.display = match ? "" : "none";
        if (match) {
          secVisible = true;
          found++;
        }
      });
      sec.style.display = secVisible ? "" : "none";
    });

    noResults.hidden = found > 0;
    searchClear.style.display = q ? "flex" : "none";
  };

  searchInput.addEventListener("input", () => {
    // switch to "all" tab when searching
    tabs.forEach((t) => {
      t.classList.remove("active");
      t.setAttribute("aria-selected", "false");
    });
    tabs[0].classList.add("active");
    tabs[0].setAttribute("aria-selected", "true");
    applySearch(searchInput.value);
  });

  searchClear.addEventListener("click", () => {
    searchInput.value = "";
    applySearch("");
    searchInput.focus();
  });
  noResBtn.addEventListener("click", () => {
    searchInput.value = "";
    applySearch("");
  });
</script>
