        thumbnailUrl: "https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20240216-WA0027_1_hbujam.jpg",
        contentUrl: "https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20240216-WA0027_1_hbujam.mp4",
        uploadDate: isoUploadDate,
        embedUrl: "https://aflagot-haifa.com/yacht-li-yam",
      },
    })}
  />
</Layout>
