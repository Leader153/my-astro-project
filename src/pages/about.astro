---
import "../styles/about-page.css";

import Layout from "../layouts/Layout.astro";

const stats = [
  { num: "10+", label: "שנות ניסיון", icon: "⚓" },
  { num: "500+", label: "הפלגות שמחות", icon: "⛵" },
  { num: "4", label: "יאכטות בצי", icon: "🚢" },
  { num: "24/7", label: "זמינים עבורכם", icon: "📞" },
];

const experiences = [
  {
    icon: "🌅",
    title: "דייט רומנטי בשקיעה",
    desc: "רגעים בלתי נשכחים לשניים, עם נוף ים מרהיב.",
  },
  {
    icon: "🎉",
    title: "מסיבות ואירועים",
    desc: "ימי הולדת, מסיבות רווקות ורווקים על הסיפון.",
  },
  {
    icon: "👨‍👩‍👧‍👦",
    title: "אירועים משפחתיים",
    desc: "חוויה בטוחה ומהנה לכל הגיל ומשפחה.",
  },
  {
    icon: "🌟",
    title: "צפייה בכוכבים",
    desc: "ליקויי ירח וכוכבים מסיפון היאכטה בלילה.",
  },
  {
    icon: "🌊",
    title: "בריזת ים",
    desc: "בריחה מהשגרה העירונית לרוח ים רעננה.",
  },
  {
    icon: "🏆",
    title: "שירות ברמה הגבוהה ביותר",
    desc: "מחויבות מוחלטת לנוחות ולבטיחות שלכם.",
  },
];

const bizDetails = [
  { label: "שם העוסק", value: "לידר דניאל" },
  {
    label: "כינוי העסק",
    value: '<span class="brand-leader">לידר הפלגות &amp; שייט</span>',
  },
  { label: "מספר עוסק מורשה", value: "314589272" },
  { label: "מען העסק", value: "שד' קרן קימת 9, דירה 7, קריית מוצקין" },
];
---

<Layout
  title="אודות - Leader הפלגות בחיפה והרצליה"
  description="הכירו את Leader הפלגות! ⚓ מאז 2011 אנו מעניקים חוויות ים בלתי נשכחות 🐬. צוות מקצועי, יאכטות יוקרה ואלפי לקוחות מרוצים 🥂. דברו איתנו!"
>
  <div class="about-page" dir="rtl">
    <!-- ══════════════════ HERO ══════════════════ -->
    <div class="page-hero">
      <div class="hero-bg-circles">
        <div class="circle c1"></div>
        <div class="circle c2"></div>
        <div class="circle c3"></div>
      </div>
      <div class="hero-content">
        <div class="hero-eyebrow">
          <span class="eyebrow-dot"></span>
          Leader
          <span class="eyebrow-dot"></span>
        </div>
        <h1>לידר הפלגות: מומחים בהשכרת יאכטות וחוויות בוטיק על הים</h1>
        <p class="hero-sub">
          מתמחים בארגון הפלגות בלתי נשכחות והשכרת יאכטות בחיפה — כי כל הרגע על
          הים שווה אלף מילים
        </p>
        <div class="hero-scroll-hint" aria-hidden="true">
          <svg
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            width="22"
            height="22"><polyline points="6 9 12 15 18 9"></polyline></svg
          >
        </div>
      </div>
    </div>

    <!-- ══════════════════ STATS BAR ══════════════════ -->
    <div class="stats-bar">
      {
        stats.map((s) => (
          <div class="stat-item">
            <span class="stat-icon">{s.icon}</span>
            <span class="stat-num">{s.num}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))
      }
    </div>

    <div class="content-wrapper">
      <!-- ══════════════════ INTRO SECTION ══════════════════ -->
      <section class="intro-section">
        <div class="intro-text-col">
          <div class="section-eyebrow">מי אנחנו</div>
          <h2>הפלגות חיפה — חוויות ים שלא נשכחות</h2>
          <p>
            אנו מתמחים ! בארגון הפלגות בלתי נשכחות והשכרת יאכטות בחיפה. המטרה
            העיקרית שלנו היא להעניק לכם חוויות מרגשות וייחודיות בלב ים.
          </p>
          <p>
            אנו דואגים לכל פרט קטן מתוך מחויבות מוחלטת לנוחות ולבטיחות שלכם, כדי
            להבטיח שההפלגה שלכם תהיה ברמה הגבוהה ביותר.
          </p>
          <div class="intro-badges">
            <span class="badge">✅ מבוטח צד ג'</span>
            <span class="badge">🛡️ בטיחות מקסימלית</span>
            <span class="badge">⚓ סקיפר מוסמך</span>
          </div>
        </div>

        <div class="intro-visual-col">
          <div class="visual-card main-card">
            <div class="visual-icon big">⛵</div>
            <div class="visual-text">
              <strong>Leader הפלגות</strong>
              <span>חיפה | הרצליה</span>
            </div>
          </div>
          <div class="visual-card accent-card">
            <div class="visual-icon">🌊</div>
            <span>מים כחולים · שמיים פתוחים</span>
          </div>
          <div class="visual-card accent-card-2">
            <div class="visual-icon">⭐</div>
            <span>שירות פרמיום</span>
          </div>
          <!-- Floating dots -->
          <div class="dot-grid" aria-hidden="true">
            {Array.from({ length: 15 }).map(() => <span class="dot" />)}
          </div>
        </div>
      </section>

      <!-- ══════════════════ EXPERIENCES ══════════════════ -->
      <section class="experiences-section">
        <div class="section-header center">
          <div class="section-eyebrow">מה אנחנו מציעים</div>
          <h2>חוויות על הים לכל מטרה</h2>
          <p class="section-desc">
            בין אם מדובר בדייט רומנטי, מסיבה תוססת או בריחה מהשגרה — אנחנו כאן
            כדי להפיק לכם את האירוע המושלם.
          </p>
        </div>
        <div class="exp-grid">
          {
            experiences.map((e, i) => (
              <div class="exp-card" style={`--delay:${i * 0.07}s`}>
                <div class="exp-icon">{e.icon}</div>
                <h3>{e.title}</h3>
                <p>{e.desc}</p>
              </div>
            ))
          }
        </div>
      </section>

      <!-- ══════════════════ BUSINESS DETAILS ══════════════════ -->
      <section class="biz-section">
        <div class="biz-card">
          <div class="biz-header">
            <div class="biz-shield">
              <svg
                aria-hidden="true"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                width="32"
                height="32"
                ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                ></path></svg
              >
            </div>
            <div>
              <div class="section-eyebrow">שקיפות מלאה</div>
              <h2>פרטי העסק הרשמיים</h2>
              <p class="biz-subtext">
                למען שקיפות מלאה ובהתאם לחוק הגנת הצרכן, להלן הפרטים המשפטיים
                והרשמיים שלנו:
              </p>
            </div>
          </div>

          <div class="biz-details-grid">
            {
              bizDetails.map((d) => (
                <div class="biz-row">
                  <div class="biz-label">{d.label}</div>
                  <div class="biz-value" set:html={d.value} />
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <!-- ══════════════════ CONTACT CTA ══════════════════ -->
      <section class="cta-section">
        <div class="cta-card">
          <div class="cta-bg-wave" aria-hidden="true"></div>
          <div class="cta-content">
            <h2>מוכנים לצאת לים?</h2>
            <p>דברו איתנו ונבנה יחד את ההפלגה המושלמת עבורכם</p>
            <div class="cta-actions">
              <a href="tel:0533403449" class="cta-btn primary">
                <svg
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  width="18"
                  height="18"
                  ><path
                    d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"
                  ></path></svg
                >
                053-340-3449
              </a>
              <a
                href="https://wa.me/972533403449"
                target="_blank"
                rel="noopener"
                class="cta-btn whatsapp"
              >
                <svg
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  width="18"
                  height="18"
                  ><path
                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                  ></path></svg
                >
                WhatsApp
              </a>
              <a href="mailto:danielflider78@gmail.com" class="cta-btn email">
                <svg
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  width="18"
                  height="18"
                  ><path
                    d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                  ></path><polyline points="22,6 12,13 2,6"></polyline></svg
                >
                danielflider78@gmail.com
              </a>
            </div>
          </div>
        </div>
      </section>
    </div><!-- /content-wrapper -->
  </div>
</Layout>

<!-- Schema.org Data API -->
