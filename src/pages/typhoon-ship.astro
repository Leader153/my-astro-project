---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import heroImage from "../assets/typhoon-ship.jpg";
import img1 from "../assets/ספינת-טייפון-מושבים.png";
import midImg2 from "../assets/צוות-טייפון.webp";
import FleetSelectionCta from "../components/FleetSelectionCta.astro";
import PremiumSwitch from "../components/PremiumSwitch.astro";
import YachtVideoCard from "../components/YachtVideoCard.astro";
const isoUploadDate = new Date("2026-03-12").toISOString();
import "../styles/pricing-card.css";
---

<Layout
  title="ספינת טייפון (עד 30 איש): יאכטה לאירועים בחיפה | Leader הפלגות"
  description="השכרת ספינת טייפון במפרץ חיפה לאירועים ומסיבות עד 30 מפליגים. החל מ-1,200 ₪ לשעה. רחבת ריקודים, מנגל וצוות מקצועי. מושלם ליום הולדת וגיבוש."
>
  <div class="service-page" dir="rtl">
    <section class="sp-hero">
      <Image
        src={heroImage}
        alt="ספינת טייפון בחיפה"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg desktop-hero"
      />
      <Image
        src={heroImage}
        alt="ספינת טייפון בחיפה"
        widths={[400, 768]}
        sizes="100vw"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg mobile-hero"
        style="object-position: 80% 0%;"
      />
    </section>

    <section class="sp-content">
      <div class="sp-inner">
        <h1>השכרת יאכטה לאירועים בחיפה – ספינת טייפון עד 30 מפליגים</h1>
        <p>
          מסיבות, ימי הולדת, ימי גיבוש ואירועים פרטיים<br />
          שייט חוויתי 🐬 עם רחבת ריקודים, מנגל ופינוק מושלם 🥂
        </p>

        <h2>🎉 חוגגים אירוע? הטייפון הוא הבמה שלכם!</h2>
        <p>
          מחפשים אירוע שאף אחד לא ישכח? <strong>ספינת טייפון בחיפה</strong> היא הבחירה
          המושלמת לכל מי שרוצה לחגוג בסטייל בלב ים. יום הולדת, מסיבת רווקות, יום גיבוש
          קבוצתי או כל אירוע פרטי – אצלנו כל רגע הופך לחוויה שתישאר בזיכרון לתמיד.
        </p>
        <p>
          <strong>ספינת טייפון</strong> מכילה <strong>עד 30 מפליגים</strong> ומציעה
          שייט חוויתי לאורך מפרץ חיפה. רחבת ריקודים, מנגל פחמים, מוזיקה, ים – כל מה
          שצריך לאירוע מושלם כבר על הסיפון. פנקו את האורחים שלכם כמו שמגיע להם!
        </p>

        <Image
          src={img1}
          alt="מסיבה על ספינת טייפון בחיפה"
          class="sp-gallery-img is-square"
          format="webp"
        />

        <h2>🚢 על הסיפון – מרחב פינוק מושלם לאירוע</h2>
        <p>
          <strong>ספינת טייפון</strong> מחולקת למספר אזורים שתוכננו במיוחד כדי לשדרג
          כל אירוע: מטבחון, מקרר, כיור, שירותים, חדר עם מיטה, מנוע עוצמתי וכמובן הגה
          אמיתי של ספינה!
        </p>
        <ul class="sp-list">
          <li>
            <strong>אזור החרטום (קדימה):</strong> 6 מושבים נוחים במרחב מבודד ושקט.
            המקום המושלם לצילומים דרמטיים מול הגלים ולרגעים אינטימיים בלב ים.
          </li>
          <li>
            <strong>רחבת הריקודים ואזור הבילוי:</strong> שולחן ענק, מושבים נוחים וגג
            צל על כל האזור – עם מקרר, <strong>מנגל פחמים</strong> ורחבה ענקית לרקוד,
            לשמוח ולחגוג כמו שצריך!
          </li>
          <li>
            <strong>אזור ירכתיים וצוות:</strong> הצוות המקצועי שלנו מנהל את ההשטה
            הבטוחה כך שאתם מתפנים רק ליהנות.
          </li>
        </ul>

        <h2>אוכל ושתיה – פינוק מושלם על הסיפון!</h2>
        <p>
          <strong>מביאים אוכל ושתיה מהבית?</strong> בכיף! ללא תוספת מחיר. הביאו בשרים
          ופחמים ואנחנו נבשל לכם על המנגל – התפנו ליהנות מהשייט החוויתי בזמן שהריח
          הנהדר עולה מהאש.
        </p>
        <p>
          <strong>מעדיפים שנארגן הכל?</strong> תגידו מה אתם אוהבים ונדאג לתפריט מפנק
          בהתאם לאירוע. מנות יפות, פינוקים ומשקאות – הכל מסודר עבורכם.
        </p>

        <Image
          src={midImg2}
          alt="צוות הספינה"
          class="sp-gallery-img is-square"
          format="webp"
        />

        <h2>⚓ שייט חוויתי לאורך מפרץ חיפה</h2>
        <p>
          השייט מתבצע לאורך <strong>מפרץ חיפה</strong> הציורי – נוף עוצר נשימה לכל
          עבר, עם עגינה מרגיעה ב<strong>מפרץ פולינום</strong>, במרחק של כ-35
          דקות שייט מנקודת היציאה (פארק קישון). חוויה שאסור לפספס!
        </p>

        <h2>קפיצה לים – בונוס לאירוע!</h2>
        <p>
          רוצים לשדרג את האירוע? יש לנו סולם לירידה למים ומקפצה! בתנאי ים
          מתאימים, הקבוצה יכולה להיכנס למים ולהפוך את האירוע לחוויה מושלמת
          לחלוטין.
        </p>
        <ul class="sp-list">
          <li>הרחצה על אחריות המתרחצים בלבד.</li>
          <li>הירידה למים מותנית באישור הסקיפר.</li>
          <li>הכניסה למים רק לאנשים שיודעים לשחות.</li>
        </ul>

        <h2>👨‍✈️ הצוות המקצועי שלנו</h2>
        <p>
          2–3 אנשי צוות מנוסים – מלחים שיודעים לפנק ולתת שירות מחייך, וסקיפרים
          מורשים שמבטיחים שייט בטוח ומהנה. הצוות אינו נכלל בספירת 30 המפליגים,
          כך שכל 30 המקומות הם שלכם!
        </p>

        <p class="sp-closing">
          חוגגים אירוע? ספינת טייפון מחכה לכם!<br />
          התקשרו להזמין עכשיו: 053-3403449 (דניאל)
        </p>
      </div>

      <YachtVideoCard
        id="ship-typhoon-haifa"
        videoUrl="https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20250707-WA0013_qgcvco.mp4"
        posterUrl="https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20250707-WA0013_qgcvco.jpg"
        videoName="Typhoon Ship Haifa"
        videoDescription="ספינת טייפון לאירועים עד 30 משתתפים מחיפה"
        uploadDate={isoUploadDate}
        tagText="חיפה"
        tagColor="#0ea5e9"
        icon="🚢"
        title="מחירון ספינת טייפון"
        note='* המחיר לא כולל שמפניה | * מחיר כולל מע"מ, תקף לסוף שבוע'
        whatsappNumber="972533403449"
        width="450"
        height="800"
        muted="true"
        ragHint="[מידע לבוט על ספינת טייפון] שם: ספינת טייפון. מיקום: חיפה. סוג: ספינת אירועים. קיבולת: עד 30 מפליגים. מחירון מקוצר: שעה 1,200₪, שעתיים 2,200₪, 3 שעות 2,650₪. המחיר הוא לספינה במלואה וכולל: צוות מקצועי (סקיפר ומלחים), רחבת ריקודים, מערכת שמע, אפשרות להביא אוכל/בשרים ולצלות על מנגל פחמים שיש בספינה. בהפלגה של 3 שעות: שירות גרילמן (על האש) ללא תוספת תשלום. הערה חשובה: המחיר אינו כולל שמפניה. כאשר לקוח שואל על ספינה זו, שלח לו את הקישור הישיר לדף: /typhoon-ship. ציין שיש שם וידאו, תמונות ומחירון מלא."
      >
        <p><strong>מחירון השכרת טייפון:</strong></p>
        <ul class="pricing-list no-bullets">
          <li><strong>שעה הפלגה:</strong> 1,200 ₪</li>
          <li><strong>שעתיים הפלגה:</strong> 2,200 ₪</li>
          <li><strong>3 שעות הפלגה:</strong> 2,650 ₪</li>
          <li>👑 מתאים לעד 30 מפליגים</li>
        </ul>

        <h4 class="pricing-title">המחיר כולל:</h4>
        <ul class="pricing-list">
          <li>צוות מקצועי ומסור (מלחים וסקיפר)</li>
          <li>רחבת ריקודים ומערכת שמע</li>
          <li>אפשרות להביא אוכל, בשרים ושתייה ולצלות על המנגל</li>
        </ul>

        <h4 class="pricing-title">בהזמנה של 3 שעות:</h4>
        <ul class="pricing-list">
          <li>שירות גרילמן (על האש) ללא תוספת תשלום! 🍖</li>
        </ul>
      </YachtVideoCard>
      <style is:global>
        /* Теперь ID точно совпадает с тем, что в YachtVideoCard */
        #ship-typhoon-haifa .yvc-img-wrap {
          aspect-ratio: 3 / 2 !important;
          height: auto !important;
        }

        /* Чтобы видео красиво заполняло новую горизонтальную область и не сплющивалось */
        #ship-typhoon-haifa .cloudinary-video-facade,
        #ship-typhoon-haifa .cloudinary-video-facade video {
          object-fit: cover !important;
        }
      </style>
      <div
        style="margin: 3rem auto; max-width: 450px; border-radius: 15px; overflow: hidden;"
      >
        <video
          autoplay
          id="birthday-yacht-video"
          width="450"
          height="600"
          loop="true"
          muted
          playsinline
          class="vertical-img"
          style="width: 100%; height: auto; aspect-ratio: 3/4; object-fit: cover; display: block;"
        >
          <source
            src="https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20260314-WA0006_xtxpop.mp4"
            type="video/mp4"
          />
        </video>
      </div>
      <PremiumSwitch
        href="/haifa"
        title="צפו בצי יאכטות חיפה"
        subtitle="מעבר לעמוד פריסת ספינות ויאכטות שלנו בחיפה"
      />
    </section>
  </div>
  <FleetSelectionCta
    ctaInstruction="נא להיכנס לעמוד יאכטות ולתאם את הפלגתכם בחיפה:"
  />

  <!-- Schema.org Data API -->
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      name: "ספינת טייפון בני גלים בחיפה",
      description:
        "השכרת ספינת טייפון במפרץ חיפה למסיבות ואירועים עד 30 מפליגים, כולל רחבת ריקודים ומנגל פחמים.",
      image: "https://aflagot-haifa.com/seo/seo-Leader-cruise.jpg",
      brand: { "@type": "Brand", name: "Leader שייט & הפלגות" },
      seller: {
        "@type": "TravelAgency",
        "@id": "https://aflagot-haifa.com/",
        name: "Leader שייט & הפלגות",
        legalName: "לידר",
        alternateName: [
          "Leader Haflagot",
          "לידר הפלגות שייט",
          "Leader Yachting",
        ],
        telephone: "+972533403449",
        url: "https://aflagot-haifa.com/",
        location: [
          {
            "@type": "Place",
            address: {
              "@type": "PostalAddress",
              streetAddress: "מרינה הרצליה",
              addressLocality: "הרצליה",
              addressCountry: "IL",
            },
            geo: {
              "@type": "GeoCoordinates",
              latitude: 32.162443,
              longitude: 34.796172,
            },
          },
          {
            "@type": "Place",
            address: {
              "@type": "PostalAddress",
              streetAddress: "מעגן שביט, פארק קישון",
              addressLocality: "חיפה",
              addressCountry: "IL",
            },
            geo: {
              "@type": "GeoCoordinates",
              latitude: 32.8069075,
              longitude: 35.0322383,
            },
          },
        ],
        sameAs: [
          "https://www.facebook.com/leadership.haifa",
          "https://www.instagram.com/leader.aflagot?igsh=YnAzcThrbDExd2o5",
          "https://www.youtube.com/channel/UCzEOzFcGu8zSeFtFrif4cYw",
        ],
      },
      offers: {
        "@type": "AggregateOffer",
        priceCurrency: "ILS",
        lowPrice: "1200",
        highPrice: "2650",
        offerCount: "3",
        offers: [
          {
            "@type": "Offer",
            name: "הפלגה לשעה אחת",
            price: "1200",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/typhoon-ship",
          },
          {
            "@type": "Offer",
            name: "הפלגה לשעתיים",
            price: "2200",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/typhoon-ship",
          },
          {
            "@type": "Offer",
            name: "הפלגה ל-3 שעות",
            price: "2650",
            priceCurrency: "ILS",
            url: "https://aflagot-haifa.com/typhoon-ship",
          },
        ],
      },
      subjectOf: {
        "@type": "VideoObject",
        name: "ספינת טייפון בני גלים בחיפה",
        description: "ספינת טייפון לאירועים עד 30 משתתפים מחיפה",
        thumbnailUrl:
          "https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20250707-WA0013_qgcvco.jpg",
        contentUrl:
          "https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20250707-WA0013_qgcvco.mp4",
        uploadDate: isoUploadDate,
        embedUrl: "https://aflagot-haifa.com/typhoon-ship",
      },
    })}
  />
</Layout>
