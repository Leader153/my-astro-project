---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import Heroimg from "../assets/Bagira-Yacht.jpeg";
import img1 from "../assets/Bagira-kokpit.jpg";
import midImg from "../assets/Bagira-salon.jpg";
import botImg from "../assets/Bagira-piple.jpg";
import FleetSelectionCta from "../components/FleetSelectionCta.astro";
import PremiumSwitch from "../components/PremiumSwitch.astro";
import YachtVideoCard from "../components/YachtVideoCard.astro";
import "../styles/pricing-card.css";
const isoUploadDate = new Date("2026-03-12").toISOString(); 
---

<Layout
  title="יאכטה בגירה (עד 12 איש) הרצליה | Leader הפלגות"
  description="השכרת יאכטה בגירה (Bagira) במרינה הרצליה לעד 12 איש. החל מ-760 ₪ לשעה. מושלמת לאירועי יוקרה. כולל סקיפר, שמפניה, בלונים ואבוב."
>
  <div class="service-page" dir="rtl">
    <section class="sp-hero">
      <Image
        src={Heroimg}
        alt="יאכטה בגירה בהרצליה"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg desktop-hero"
      />
      <Image
        src={Heroimg}
        alt="יאכטה בגירה בהרצליה"
        widths={[400, 768]}
        sizes="100vw"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        class="sp-hero-bg mobile-hero"
        style="object-position: 50% 50%;"
      />
    </section>

    <section class="sp-content">
      <div class="sp-inner">
        <h1>השכרת יאכטה בהרצליה – יאכטה מפרשית Bagira עד 12 איש</h1>
        <p>
          יאכטה בגירה היא בעלת תכנון פנים ייחודי, מאפשרת אירוח זוגות נוח ומפנק.
          קלה לתפעול ומתאימה במיוחד להפלגות סקיפר ליום אחד.
        </p>

        <h2>✨ בחירה קלאסית לפעילות בים</h2>
        <p>
          היא יאכטה מפרשית שנבנתה על ידי יצרנית היאכטות הצרפתית DUFOUR והגיע
          לישראל בהפלגה לאורך כל הים התיכון.
        </p>
        <p>
          שם הדגם <strong>GRAND LARGE 365</strong>.<br />
          אורך היאכטה 36 פיט (כ-11 מטר).<br />
          על היאכטה ניתן לעלות עד כ-12 מפליגים מלבד הסקיפר. בתוך היאכטה יש שני חדרי
          שינה, חדר שירותים ומלקחת גדול במיוחד, מטבח מאובזר וסלון.
        </p>
        <p>
          על הסיפון, בירכתיים, יש איזור ישיבה סביב שולחן ומזרון שיזוף בחרטום.
          היאכטה מצויידת במזגן, שירותים חשמליים, מערכת סאונד טובה עם רמקולים על
          הסיפון ובתוך היאכטה בסלון, ניתן להתחבר למערכת הסאונד עם כל נגן חיצוני
          (טלפונים, מחשב…).
        </p>

        <Image
          src={img1}
          alt="יאכטה בגירה מהצד"
          class="sp-gallery-img"
          style="aspect-ratio: 3/2; object-fit: cover;"
          format="webp"
        />

        <h2>💎 עיצוב וחוויה ייחודית</h2>
        <p>
          ביאכטה בגירה מספר המפליגים המותר הינו 12 מפליגים, ירכתיי הספינה נפתחים
          לירידה נוחה למים, חדר השינה והמקלחת מאפשרים אירוח נוח ומפנק להפלגות
          זוגיות אך מתאימה גם להפלגות קבוצתיות. היאכטה מושלמת להפלגות זוגיות,
          מגוון הפלגות הכולל עיסוי, ימי הולדת, הפלגות סקיפר ליום אחד, הפלגות
          גיבוש עובדים, הפלגות משפחתיות ועוד.
        </p>

        <Image
          src={midImg}
          alt="סיפון יאכטה בגירה"
          class="sp-gallery-img"
          style="aspect-ratio: 3/2; object-fit: cover;"
          format="webp"
        />

        <h2>⭐ מה מיוחד ביאכטה בגירה?</h2>
        <p>
          יאכטה בגירה הינה היאכטה החדשה ביותר בצי של ״לי-ים השכרת יאכטות״. עיצוב
          חדר השינה בחרטום הינו נדיר ומאפשר עמידה לצד המיטה הזוגית, כפי שבדר״כ
          ניתן לראות ביאכטות הרבה יותר גדולות. מתאים לשייט זוגי המשלב עיסוי
          וארוחה ממש כמו צימר על המים.
        </p>
        <p>
          בנוסף, חדר השירותים גדול ומרווח, בהשוואה ליאכטות בסדר גודל דומה, מאפשר
          מקלחת נוחה לאחר עיסוי או לאחר רחצה בים.
        </p>

        <Image
          src={botImg}
          alt="קוקפיט יאכטה בגירה"
          class="sp-gallery-img"
          style="aspect-ratio: 3/2; object-fit: cover;"
          format="webp"
        />

        <p class="sp-closing">
          רוצים להפליג? יאכטה בגירה מחכה לכם!<br />
          התקשרו להזמין עכשיו: 053-3403449
        </p>
      </div>
     
   <YachtVideoCard
  id="yacht-bagira-herzliya"
  videoUrl="https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20230624-WA0052_1_vsi0eh.mp4"
  posterUrl="https://res.cloudinary.com/dmbdadurw/video/upload/f_auto,q_auto/VID-20240216-WA0027_1_hbujam.jpg"
  videoName="Yacht Bagira Herzliya"
  videoDescription="יאכטה מפרשית עד 12 משתתפים מהרצליה"
  uploadDate={isoUploadDate}
  tagText="הרצליה"
  tagColor="#d4a017"
  icon="⛵"
  title="מחירון יאכטה בגירה"
  note="* מחיר כולל מע&quot;מ, תקף לסוף שבוע"
  whatsappNumber="972533403449"
  ragHint="[מידע לבוט על יאכטה בגירה] שם: יאכטה בגירה. מיקום: הרצליה. קיבולת: עד 12 מפליגים. מחירון מקוצר: שעה 760₪, שעה וחצי 930₪, שעתיים 1,190₪, 3 שעות 1,580₪, שעה נוספת 390₪. המחיר כולל: סקיפר, שתייה מים, שמפניה, בלונים, שלט, מוזיקה, ביטוח. בהפלגה של שעתיים ומעלה: אבוב. כאשר לקוח שואל על יאכטה זו, שלח לו את הקישור הישיר לדף: /yacht-bagira. ציין שיש שם וידאו, תמונות ומחירון מלא."
>
  <p><strong>מחירון השכרת יאכטה בגירה:</strong></p>
  <ul class="pricing-list no-bullets">
    <li><strong>שעה הפלגה:</strong> 760 ₪</li>
    <li><strong>שעה וחצי הפלגה:</strong> 930 ₪</li>
    <li><strong>שעתיים הפלגה:</strong> 1,190 ₪</li>
    <li><strong>3 שעות הפלגה:</strong> 1,580 ₪</li>
    <li>כל שעה נוספת: 390 ₪</li>
    <li>👑 עד 12 מפליגים מאושרים (עם סקיפר)</li>
  </ul>

  <h4 class="pricing-title">המחיר כולל:</h4>
  <ul class="pricing-list">
    <li>שלט מזל טוב</li>
    <li>בלונים בתוך היאכטה</li>
    <li>מוזיקה (רמקול בלוטוס)</li>
    <li>שתייה מים</li>
    <li>בקבוק שמפניה 🥂</li>
    <li>ביטוח לכל משתתף</li>
    <li>שירות של סקיפר מקצועי לאורך כל הדרך</li>
  </ul>

  <h4 class="pricing-title">בהזמנה של שעתיים:</h4>
  <ul class="pricing-list">
    <li>ירידה לים עם אבוב 🌊</li>
  </ul>
</YachtVideoCard>
      <PremiumSwitch
        href="/yachts-herzliya"
        title="בחזרה ליאכטות הרצליה"
        subtitle="לצפייה בצי שלנו ולבחירת היאכטה המושלמת"
      />
    </section>
  </div>
  <FleetSelectionCta ctaInstruction="נא להמשיך להזמנה או לצפות בעוד יאכטות:" />

  <!-- Schema.org Data API -->
