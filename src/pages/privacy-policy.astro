---
import Layout from "../layouts/Layout.astro";

const sections = [
  {
    id: "services",
    icon: "⚙️",
    title: "שירותים והתאמות",
    color: "blue",
    text: '<span class="brand-leader">לידר הפלגות &amp; שייט</span> (להלן: "החברה", "אנחנו" או "אנו") מכבדת את הפרטיות של כל לקוחותיה ומשתמשי השירותים שלה. השימוש באתר, במערכת ו/או בשירותים כפוף למדיניות הפרטיות זו (להלן "מדיניות הפרטיות"). "אתה" או "משתמש/ים" פירושו כל אדם המשתמש באתר, במערכת ו/או בשירותים. המונחים אשר לא הוגדרו במפורש במסמך זה, יפורשו בהתאם להגדרות שנקבעו בתנאי השימוש של החברה.',
  },
  {
    id: "statistics",
    icon: "📊",
    title: "נתונים סטטיסטיים",
    color: "sea",
    text: 'אנו עשויים לאסוף נתונים סטטיסטיים שהתקבלו כתוצאה מעיבוד מידע, בכלל זה מידע אישי המתקבל ממגוון משתמשים ("נתונים סטטיסטיים"). זאת בכדי להתאים את האתר, המערכת ו/או השירותים לצרכים שונים ועל מנת לשפר ולייעל את השירותים. אנו עשויים להעביר את הנתונים הסטטיסטיים לספקי השירות שלנו או לשותפינו העסקיים, בהתאם לתנאים המסחריים שאנו קובעים ועל פי שיקול דעתנו הבלעדי.',
  },
  {
    id: "analytics",
    icon: "📈",
    title: "ניתוח נתונים סטטיסטיים",
    color: "teal",
    text: 'אנו עשויים לנתח את הנתונים הסטטיסטיים באמצעות תוכנות המספקות שירותי מידע וניתוח סטטיסטי לרבות, אך ללא הגבלה, באמצעות Google Analytics ("כלים אנליטיים"). המידע הנאסף נועד לצרכי ניתוח, מחקר ובקרה. כמו כן, אנו משתמשים במידע שאנו מקבלים באמצעות הכלים האנליטיים לשיפור המערכת.',
  },
  {
    id: "transfer",
    icon: "🔄",
    title: "שימושים אחרים או העברת המידע שלך",
    color: "purple",
    text: "נשתף את המידע שלך בהתאם לאמור להלן, ואם נידרש לעשות כן לפי כל חוק, תקנה או צו בית משפט או בכדי לשתף פעולה עם חקירה של רשויות אכיפת החוק.",
  },
  {
    id: "partners",
    icon: "🤝",
    title: "שותפים עסקיים, ספקי שירות וקבלני משנה",
    color: "orange",
    text: "אנו עשויים לשתף מידע, כולל מידע אישי, עם לקוחותינו, כמו כן עם ספקי שירות, קבלני משנה, חברות קשורות, ושותפים עסקיים אשר עשויים להשתמש במידע כדי: (1) לסייע לנו לספק את השירותים; (2) לסייע להם בהבנת השימוש באתר; (3) פרסום מידע ותכנים מותאמים אישית. החברה תנקוט בצעדים כדי להבטיח רמה נאותה של הגנה למידע האישי.",
  },
  {
    id: "ownership",
    icon: "🏢",
    title: "העברת בעלות",
    color: "rose",
    text: 'אנו עשויים להעביר את מאגרי המידע שלנו המכילים מידע אישי לצד שלישי כלשהו ככל שהוא ירכוש את החברה, את נכסיה או חלק מאלו ו/או במהלך מו"מ על רכישת החברה ו/או נכסיה ו/או חלק מאלה.',
  },
  {
    id: "law",
    icon: "⚖️",
    title: "העברת מידע במסגרת אכיפת חוק",
    color: "navy",
    text: "אנו נשתף פעולה עם רשויות אכיפת החוק או כל צו שיפוטי הדורש או מנחה אותנו לגלות את זהות, התנהגות או תוכן דיגיטאלי של משתמש אשר נחשד בפעולות הנחזות למנוגדות לדין. כמו כן, אנו עשויים לשתף את המידע האישי שלך עם צדדים שלישיים, אם אנו מאמינים בתום לב שגילוי המידע הינו נאות ונועד להגן על הזכויות, הרכוש או הבטיחות שלנו.",
  },
  {
    id: "more-sharing",
    icon: "📤",
    title: "שיתוף מידע נוסף",
    color: "sea",
    text: "נעביר את המידע האישי שלך לצדדים שלישיים רלוונטיים במקרים שלהלן: (1) החברה תגלה כי אילו מפעולותיך מפרות את תנאי השימוש או נעשו לשם ביצוע תרמית; (2) החברה תעמוד בפני נקיטת צעדים משפטיים; (3) ההעברה נדרשת על פי דין, תקנה, צו בית משפט או צו מטעם רשות אכיפה כלשהיא.",
  },
  {
    id: "security",
    icon: "🔒",
    title: "כיצד אנו מגנים על מידע",
    color: "green",
    text: "אנו נוקטים באמצעי אבטחה העומדים בסטנדרטים המסחריים המקובלים בתעשייה, על מנת להגן על המידע האישי שנמסר לנו. למרות האמור לעיל, העברת מידע באמצעות האינטרנט אינה בטוחה לחלוטין. בהתאם לכך, איננו יכולים להבטיח את בטיחות הנתונים המועברים אלינו במלואה.",
  },
  {
    id: "notifications",
    icon: "🔔",
    title: "הודעות",
    color: "blue",
    text: "אנו שומרים לעצמנו את הזכות לשלוח לך הודעות הקשורות לשימוש באתר, במערכת ו/או בשירותים, לרבות הודעות שירות ומסרים מנהליים. אם אינך מעוניין לקבל הודעות כאלו, תוכל לבטל את חשבונך.",
  },
  {
    id: "children",
    icon: "👶",
    title: "ילדים",
    color: "teal",
    text: "החברה אינה אוספת במכוון מידע אודות משתמשים שגילם מתחת לגיל 13. במידה ונחשפת לכך שמשתמש מתחת לגיל 13 נרשם למערכת, הנך מתבקש להודיע לנו על כך ללא דיחוי.",
  },
  {
    id: "rights",
    icon: "✏️",
    title: "זכות עיון ושינוי מידע",
    color: "purple",
    text: "לזכות המשתמש עומדת האפשרות לבקש לעיין ו/או למחוק מידע שנאסף עליו על ידי החברה, בהתאם להוראות החוק. החברה תמחק ו/או תשנה מידע שנאסף על המשתמש בהתאם לבקשה אשר תתקבל בכתב מהמשתמש בכתובת danielflider78@gmail.com אם וככל שאפשרי ובהתאם להוראות החוק.",
  },
  {
    id: "cookies",
    icon: "🍪",
    title: "Cookies",
    color: "orange",
    text: 'אנחנו עשויים להשתמש ב"עוגיות" ("cookies" – קבצי טקסט קטנים אשר נשלחים לדפדפן במחשב בו אתה משתמש), על מנת לספק לך שירות מהיר, יעיל ומותאם אישית. יובהר כי ה"עוגיות" אינן מכילות כל מידע אשר מזהה אותך באופן אישי. ביכולתך לשנות את הגדרות הדפדפן שלך כך שלא ייאספו "עוגיות".',
  },
  {
    id: "retention",
    icon: "💾",
    title: "שמירת המידע",
    color: "rose",
    text: "אנו נשמור את המידע האישי אודותיך למשך הזמן הדרוש על מנת: לממש את מטרות השימוש במידע המפורטות במדיניות הפרטיות; לעמוד בהתחייבויות המשפטיות שלנו; לפתור סכסוכים; לאכוף את ההסכמים שלנו; או למשך פרק זמן ארוך יותר כפי שיידרש לפי הוראות הדין הרלוונטי.",
  },
  {
    id: "changes",
    icon: "🔄",
    title: "שינויים",
    color: "navy",
    text: "על ידי השימוש באתר, במערכת ו/או בשירותים, הנך מקבל את התנאים של מדיניות פרטיות זו. אם אינך מסכים לתנאים, אל תשמש באתר. אנו רשאים לשנות, מעת לעת, ועל פי שיקול דעתנו הבלעדי, את הוראות מדיניות הפרטיות. אם יבוצעו שינויים מהותיים, נעדכן אותך על כך מראש.",
  },
];
---

<Layout
  title="מדיניות פרטיות: השכרת יאכטה בראש שקט וביטחון מלא"
  description="הפרטיות שלכם בטוחה איתנו! ⚓ אנו שומרים על המידע בקפידה, בדיוק כמו על איכות ההפלגה 🐬. שוטו בראש שקט 🥂. התקשרו להזמין עכשיו!"
>
  <div class="privacy-page" dir="rtl">
    <!-- Hero -->
    <div class="page-hero">
      <div class="hero-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
      </div>
      <div class="hero-content">
        <div class="hero-icon-wrap">
          <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            width="44"
            height="44"
          >
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
        </div>
        <h1>מדיניות פרטיות</h1>
        <p class="hero-sub">
          <span class="brand-leader">לידר הפלגות &amp; שייט</span> – שמירה על הפרטיות
          שלך
        </p>
        <div class="hero-meta">
          <span class="meta-badge">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              width="14"
              height="14"
              ><rect x="3" y="4" width="18" height="18" rx="2"></rect><line
                x1="16"
                y1="2"
                x2="16"
                y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line
                x1="3"
                y1="10"
                x2="21"
                y2="10"></line></svg
            >
            עודכן לאחרונה: מאי 2024
          </span>
          <span class="meta-badge">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              width="14"
              height="14"
              ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
              ></path></svg
            >
            GDPR Compliant
          </span>
        </div>
      </div>
    </div>

    <div class="content-wrapper">
      <!-- Table of Contents -->
      <nav class="toc-card" aria-label="תוכן עניינים">
        <div class="toc-header">
          <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            width="20"
            height="20"
            ><line x1="8" y1="6" x2="21" y2="6"></line><line
              x1="8"
              y1="12"
              x2="21"
              y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line
              x1="3"
              y1="6"
              x2="3.01"
              y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line
              x1="3"
              y1="18"
              x2="3.01"
              y2="18"></line></svg
          >
          <span>תוכן עניינים</span>
        </div>
        <ol class="toc-list">
          {
            sections.map((s, i) => (
              <li>
                <a href={`#${s.id}`}>{s.title}</a>
              </li>
            ))
          }
          <li><a href="#contact">הערות ושאלות</a></li>
        </ol>
      </nav>

      <!-- Intro -->
      <div class="intro-card">
        <p>
          <strong
            ><span class="brand-leader">לידר הפלגות &amp; שייט</span></strong
          > מכבדת את הפרטיות של כל לקוחותיה. אנו שומרים על המידע שלכם בקפידה — כך
          שתוכלו ליהנות מהשכרת יאכטה בראש שקט וביטחון מלא. הפרטיות שלכם בטוחה איתנו,
          בדיוק כמו שאנו שומרים על איכות ההפלגה שלכם.
        </p>
        <p>
          מדיניות זו מפרטת כיצד אנו אוספים, משתמשים ומגינים על המידע האישי שלך.
          אנא קרא אותה בעיון לפני השימוש בשירותים שלנו.
        </p>
      </div>

      <!-- Sections -->
      <div class="sections-list">
        {
          sections.map((section) => (
            <div class={`section-card color-${section.color}`} id={section.id}>
              <div class="section-top">
                <div class="section-emoji">{section.icon}</div>
                <h2>{section.title}</h2>
              </div>
              <p set:html={section.text} />
            </div>
          ))
        }
      </div>

      <!-- Contact / Questions -->
      <div class="contact-card" id="contact">
        <div class="contact-left">
          <div class="contact-icon-wrap">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              width="32"
              height="32"
              ><path
                d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
              ></path></svg
            >
          </div>
          <div>
            <h2>הערות ושאלות</h2>
            <p>
              אם יש לך שאלות או הערות לגבי מדיניות הפרטיות שלנו, אנא צור קשר.
              וכשתרגישו בטוחים — התקשרו להזמין הפלגה!
            </p>
          </div>
        </div>
        <a href="mailto:danielflider78@gmail.com" class="contact-btn">
          <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            width="18"
            height="18"
            ><path
              d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
            ></path><polyline points="22,6 12,13 2,6"></polyline></svg
          >
          danielflider78@gmail.com
        </a>
      </div>

      <!-- Back to top -->
      <div class="back-links">
        <a href="/" class="back-link">← חזרה לדף הבית</a>
        <a href="/accessibility" class="back-link">הצהרת הנגישות ←</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;600;700;800&display=swap");

  /* ================================================
     VARIABLES
  ================================================ */
  .privacy-page {
    --navy: #08047e;
    --navy-light: #1a0fa8;
    --sea: #0f7ab0;
    --sea-light: #1da8e8;
    --gold: #d4a017;
    --gold-light: #f0c040;
    --bg: #f2f5fb;
    --white: #ffffff;
    --text-dark: #1a1a2e;
    --text-mid: #3a3a5c;
    --text-light: #6b6b8a;
    --radius: 16px;
    --shadow: 0 6px 28px rgba(8, 4, 126, 0.09);
    --shadow-md: 0 12px 40px rgba(8, 4, 126, 0.15);

    background: var(--bg);
    font-family: "Rubik", "Segoe UI", Arial, sans-serif;
    color: var(--text-dark);
  }

  /* ================================================
     HERO
  ================================================ */
  .page-hero {
    position: relative;
    background: linear-gradient(145deg, #05036a 0%, #0a0590 35%, #0f7ab0 100%);
    padding: 5.5rem 2rem 4.5rem;
    text-align: center;
    overflow: hidden;
  }

  /* Decorative floating shapes */
  .hero-shapes {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .shape {
    position: absolute;
    border-radius: 50%;
    opacity: 0.08;
    background: white;
    animation: float 8s ease-in-out infinite;
  }
  .shape-1 {
    width: 320px;
    height: 320px;
    top: -80px;
    right: -60px;
    animation-delay: 0s;
  }
  .shape-2 {
    width: 200px;
    height: 200px;
    bottom: -40px;
    left: 10%;
    animation-delay: 2.5s;
  }
  .shape-3 {
    width: 150px;
    height: 150px;
    top: 30%;
    left: 60%;
    animation-delay: 5s;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-18px) scale(1.04);
    }
  }

  /* Wave separator */
  .page-hero::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 60px;
    background: var(--bg);
    clip-path: ellipse(55% 60px at 50% 60px);
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 84px;
    height: 84px;
    background: rgba(255, 255, 255, 0.12);
    border: 2px solid rgba(255, 255, 255, 0.25);
    border-radius: 50%;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(8px);
    color: white;
  }

  .page-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: white;
    margin: 0 0 0.6rem;
    letter-spacing: -0.5px;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
  }

  .hero-sub {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 1.75rem;
  }

  .hero-meta {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .meta-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.35rem 0.85rem;
    border-radius: 20px;
    backdrop-filter: blur(4px);
  }

  /* ================================================
     CONTENT
  ================================================ */
  .content-wrapper {
    max-width: 960px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
